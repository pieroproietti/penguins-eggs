#!/bin/bash
# Uso: p4push [debian|arch|manjaro|fedora|opensuse|alpine|all]

# 1. Carica la configurazione globale e le funzioni libreria
CONFIG_FILE="$HOME/oa-tools/bin/p4config"
if [ ! -f "$CONFIG_FILE" ]; then 
    echo "❌ Errore: File p4config non trovato in $CONFIG_FILE"
    exit 1
fi
source "$CONFIG_FILE"

DISTRO=$1
if [ -z "$DISTRO" ]; then
    echo "Uso: $0 [distro|all]"
    exit 1
fi

push_to_vm() {
    local target_name=$1
    
    # Salvaguardia: evitiamo che la mother faccia un push su se stessa
    if [ "$target_name" == "mother" ]; then 
        return
    fi
    
    local var_name="VM_ID_${target_name}"
    local vmid=${!var_name}

    if [ -z "$vmid" ]; then 
        echo "❌ Distro '$target_name' non configurata in p4config!"
        return
    fi

    # 2. Calcoliamo l'IP al volo usando il VMID (es. 201 -> 192.168.1.201)
    local target_ip="192.168.1.${vmid}"

    echo "🚀 Sincronizzo oa-tools su $target_name ($target_ip)..."
    
    # --- RICHIAMO LA LIBRERIA CONDIVISA ---
    check_ssh_keys "$target_ip"
    
    # 3. Trasferimento incrementale e speculare
    rsync -avz --delete \
        --exclude='oa/oa' \
        --exclude='coa/coa' \
        --exclude='*.o' \
        --exclude='*.a' \
        --exclude='alpine-build/' \
        "$HOME/oa-tools/" "artisan@${target_ip}:/home/artisan/oa-tools/"
        
    echo "✅ Sincronizzazione completata su $target_name!"
}

# 4. Magia nera per il comando "all": troviamo le distro direttamente dal file
if [ "$DISTRO" == "all" ]; then
    # Estrae tutte le parole che seguono "VM_ID_" nel file p4config
    DISTROS=$(grep -oP '(?<=^VM_ID_)[^=]+' "$CONFIG_FILE")
    
    for d in $DISTROS; do
        push_to_vm "$d"
        echo "----------------------------------------"
    done
else
    push_to_vm "$DISTRO"
fi
