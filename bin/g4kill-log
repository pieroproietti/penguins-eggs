#!/bin/sh
MAX_RETRIES=3
FAILED_RUNS=""
TEMPDIR=$(mktemp -d)
SKIP_FILE="$TEMPDIR/skip_runs.txt"
touch "$SKIP_FILE"

cleanup() {
  rm -rf "$TEMPDIR"
}
trap cleanup EXIT

while true; do
  # Costruisci la clausola di esclusione per jq
  EXCLUDE_FILTER=""
  if [ -s "$SKIP_FILE" ]; then
    SKIP_IDS=$(tr '\n' ' ' < "$SKIP_FILE" | sed 's/ $//')
    # Esempio: .[] | select(.databaseId != 123 and .databaseId != 456) | .databaseId
    for id in $SKIP_IDS; do
      if [ -z "$EXCLUDE_FILTER" ]; then
        EXCLUDE_FILTER="select(.databaseId != $id"
      else
        EXCLUDE_FILTER="$EXCLUDE_FILTER and .databaseId != $id"
      fi
    done
    EXCLUDE_FILTER="$EXCLUDE_FILTER) | .databaseId"
  else
    EXCLUDE_FILTER=".[].databaseId"
  fi
  
  # Ottieni i run escludendo quelli già falliti
  RUNS=$(gh run list --limit 1000 --json databaseId --jq "$EXCLUDE_FILTER")
  
  if [ -z "$RUNS" ]; then
    break
  fi
  
  echo "$RUNS" | while read -r run_id; do
    retry_count=0
    success=false
    
    while [ $retry_count -lt $MAX_RETRIES ] && [ "$success" = false ]; do
      if gh run delete "$run_id" 2>/dev/null; then
        echo "✓ Cancellato run: $run_id"
        success=true
      else
        retry_count=$((retry_count + 1))
        if [ $retry_count -lt $MAX_RETRIES ]; then
          echo "⚠️  Tentativo $retry_count fallito per $run_id, riprovo tra 2 secondi..."
          sleep 2
        else
          echo "❌ Saltato definitivamente run $run_id dopo $MAX_RETRIES tentativi"
          echo "$run_id" >> "$SKIP_FILE"
          FAILED_RUNS="$FAILED_RUNS $run_id"
        fi
      fi
    done
  done
  
  # Small pause to avoid rate limiting
  sleep 1
done

echo "=========================="
echo "Tabula rasa completata!"

if [ -n "$FAILED_RUNS" ]; then
  echo "⚠️  I seguenti run NON sono stati cancellati:"
  for run_id in $FAILED_RUNS; do
    echo "  - $run_id"
  done
  echo ""
  echo "Questi run potrebbero essere già cancellati o avere permessi speciali."
  echo "Per verificare lo stato di un run:"
  echo "  gh run view $FAILED_RUNS"
fi
