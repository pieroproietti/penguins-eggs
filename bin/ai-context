#!/bin/bash

# 0. Colori per un output "carino" e coerente
RED="\033[1;31m"
BLUE="\033[1;34m"
YELLOW="\033[1;33m"
GREEN="\033[1;32m"
RESET="\033[0m"

# 1. Configurazione Remota (Proxmox)
REMOTE_USER="artisan"
REMOTE_HOST="192.168.1.2"
REMOTE_DIR="/home/artisan"

# 2. Controlla se è stata passata una directory come argomento
if [ -z "$1" ]; then
    echo -e "${RED}[ERRORE]${RESET} Devi specificare una directory!"
    echo "Uso: $0 <percorso_directory>"
    exit 1
fi

TARGET_DIR="${1%/}" # Rimuove l'eventuale slash finale

# 3. Controlla se la directory esiste
if [ ! -d "$TARGET_DIR" ]; then
    echo -e "${RED}[ERRORE]${RESET} La directory '$TARGET_DIR' non esiste!"
    exit 1
fi

# Crea un nome file di output basato sul nome della directory
DIR_NAME=$(basename "$TARGET_DIR")
OUT_FILE="ai_context_${DIR_NAME}.txt"

echo -e "${BLUE}[AI Context Builder]${RESET} Inizio assemblaggio da: ${YELLOW}$TARGET_DIR${RESET}"

# 4. Funzione di scansione e formattazione
assemble_context() {
    (
        echo "Linguaggio: Variabile / Modulo: $DIR_NAME"
        echo "Descrizione: Contesto generato automaticamente dalla directory $TARGET_DIR (ricorsivo)"
        echo "---"
        echo ""

        # Usa find per cercare tutti i file ricorsivamente, ordinandoli alfabeticamente.
        find "$TARGET_DIR" -type f -not -path '*/\.*' | sort | while read -r f; do
            echo "### 📄 FILE: $f"
            
            EXT="${f##*.}"
            if [[ "$f" != *.* ]]; then
                EXT="text"
            fi
            
            echo "\`\`\`$EXT"
            cat "$f"
            echo "\`\`\`"
            echo ""
        done
    ) > "$OUT_FILE"
}

# 5. Esecuzione
assemble_context

# Conta i file processati in modo robusto
COUNT=$(find "$TARGET_DIR" -type f -not -path '*/\.*' | wc -l)

if [ "$COUNT" -eq 0 ]; then
    echo -e "${YELLOW}[ATTENZIONE]${RESET} Nessun file trovato in $TARGET_DIR."
    rm -f "$OUT_FILE"
else
    echo -e "${GREEN}[OK]${RESET} Assemblati ${YELLOW}$COUNT${RESET} file in ${BLUE}$OUT_FILE${RESET}"
    echo -e " -> Trasferimento su Proxmox in corso..."
    
    # 6. Copia su Proxmox e pulizia
    scp "$OUT_FILE" "${REMOTE_USER}@${REMOTE_HOST}:${REMOTE_DIR}/"
    
    # Controlla se scp ha avuto successo (exit code 0)
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}[OK]${RESET} File copiato con successo su ${YELLOW}${REMOTE_HOST}${RESET}"
        rm -f "$OUT_FILE"
        echo -e " -> File locale eliminato. Nessuna traccia lasciata. 🕵️‍♂️"
    else
        echo -e "${RED}[ERRORE]${RESET} Trasferimento fallito. Il file locale è stato mantenuto in ${OUT_FILE}."
    fi
fi