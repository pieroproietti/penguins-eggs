#!/bin/bash
# Uso: p4create [debian|arch|manjaro|fedora|opensuse|alpine|all]

# 1. Carica la configurazione globale
CONFIG_FILE="$HOME/oa-tools/bin/p4config"
if [ ! -f "$CONFIG_FILE" ]; then 
    echo "❌ Errore: p4config non trovato in $CONFIG_FILE!"
    exit 1
fi
source "$CONFIG_FILE"

DISTRO=$1
if [ -z "$DISTRO" ]; then
    echo "Uso: $0 [distro|all]"
    exit 1
fi

create_vm() {
    local target_name=$1
    local var_name="VM_ID_${target_name}"
    local vmid=${!var_name}

    if [ -z "$vmid" ]; then 
        echo "❌ Distro '$target_name' non configurata in p4config!"
        return
    fi

    echo "🏗️  Creazione VM Master per $target_name (VMID: $vmid) sul nodo padre ($PVE_NODE)..."

    # Allineato con lo storage pool ZFS attivo sul padre
    local STORAGE_POOL="father-zfs" 
    
    # Adattiamo il disco: Alpine è una piuma (8G), gli altri hanno bisogno di spazio (20G)
    local DISK_SIZE="20"
    if [ "$target_name" == "alpine" ]; then
        DISK_SIZE="8"
    fi

    # 2. Invocazione remota tramite SSH a Proxmox
    # Abbiamo integrato qxl, seriale, firewall e il mount di virtfs
    ssh "$PVE_TARGET" "qm create $vmid \
      --name furnace-$target_name \
      --memory 4096 \
      --sockets 1 --cores 4 \
      --cpu host \
      --net0 virtio,bridge=vmbr0,firewall=1 \
      --scsihw virtio-scsi-pci \
      --scsi0 ${STORAGE_POOL}:${DISK_SIZE},discard=on \
      --boot order=scsi0 \
      --ostype l26 \
      --agent 1 \
      --serial0 socket \
      --vga qxl \
      --args '-virtfs local,path=/eggs/shared,mount_tag=eggs_shared,security_model=none,id=eggs_shared'"

    echo "✅ VM $vmid ($target_name) creata su $STORAGE_POOL con disco da ${DISK_SIZE}G!"
    echo "👉 Per installare, associa la tua ISO dal padre con:"
    echo "   qm set $vmid --ide2 local:iso/NOME_DELLA_TUA_ISO.iso,media=cdrom"
}

# 3. Supporto per la creazione massiva (Legge dinamicamente p4config)
if [ "$DISTRO" == "all" ]; then
    DISTROS=$(grep -oP '(?<=^VM_ID_)[^=]+' "$CONFIG_FILE")
    for d in $DISTROS; do
        create_vm "$d"
        echo "----------------------------------------"
    done
else
    create_vm "$DISTRO"
fi
