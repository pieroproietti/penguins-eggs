#!/bin/bash
# Uso: p4create [debian|arch|manjaro|fedora]

# 1. Carica configurazione dal percorso corretto del tuo monorepo
CONFIG_FILE="$HOME/oa-tools/bin/p4config"

if [ ! -f "$CONFIG_FILE" ]; then 
    echo "Errore: p4config non trovato in $CONFIG_FILE!"
    exit 1
fi
source "$CONFIG_FILE"

DISTRO=$1
if [ -z "$DISTRO" ]; then
    echo "Uso: p4create [debian|arch|manjaro|fedora]"
    exit 1
fi

VAR_NAME="VM_ID_${DISTRO}"
VMID=${!VAR_NAME}

if [ -z "$VMID" ]; then
    echo "Errore: Distro '$DISTRO' non configurata in p4config!"
    exit 1
fi

echo "🏗️  Creazione VM Master per $DISTRO (VMID: $VMID) sul Proxmox padre ($PVE_NODE)..."

# Allineato con lo storage pool ZFS attivo sul padre
STORAGE_POOL="father-zfs" 

# Esegui il qm create puntando allo storage corretto
ssh "$PVE_TARGET" "qm create $VMID \
  --name fucin-$DISTRO \
  --memory 4096 \
  --cores 4 \
  --cpu host \
  --net0 virtio,bridge=vmbr0 \
  --scsihw virtio-scsi-pci \
  --scsi0 ${STORAGE_POOL}:20,discard=on \
  --boot order=scsi0 \
  --ostype l26 \
  --agent 1"

echo "✅ VM $VMID creata su $STORAGE_POOL! Ora puoi procedere all'installazione minima."
