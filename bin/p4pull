#!/bin/bash
# Uso: p4pull (Eseguito dalle fucine per tirare giù i sorgenti dalla mother)

# 1. Carica la configurazione globale
CONFIG_FILE="$HOME/oa-tools/bin/p4config"
if [ ! -f "$CONFIG_FILE" ]; then 
    echo "❌ Errore: File p4config non trovato in $CONFIG_FILE"
    exit 1
fi
source "$CONFIG_FILE"

# Verifica che la mother sia configurata
if [ -z "$VM_ID_mother" ]; then
    echo "❌ Errore: VM_ID_mother non configurato in p4config!"
    exit 1
fi

MOTHER_IP="192.168.1.${VM_ID_mother}"

# --- NUOVO SCUDO: Sono sulla mother? ---
# Trova l'IP reale usato dalla macchina locale
LOCAL_IP=$(ip -4 route get 1 | awk '{print $7}' | head -n 1)

if [ "$LOCAL_IP" == "$MOTHER_IP" ]; then
    echo "🛡️  Scudo attivato: Sei già sulla MOTHER ($LOCAL_IP)!"
    echo "❌ Non puoi fare pull da te stesso. Usa 'p4push' per distribuire il codice."
    exit 1
fi
# ---------------------------------------

# Richiamo la libreria per controllare la password
check_ssh_keys "$MOTHER_IP"

echo "🔄 PULL in corso dalla mother ($MOTHER_IP)..."

# 2. Sincronizzazione speculare: MOTHER -> LOCALE
rsync -avz --delete \
    --exclude='oa/oa' \
    --exclude='coa/coa' \
    --exclude='*.o' \
    --exclude='*.a' \
    --exclude='alpine-build/' \
    "artisan@${MOTHER_IP}:/home/artisan/oa-tools/" "$HOME/oa-tools/"
    
echo "✅ Codice sorgente aggiornato con successo!"
g