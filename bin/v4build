#!/bin/bash

# Colori per il terminale
CYAN='\033[0;36m'
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

TARGET=$1

# Comando universale da lanciare dentro la fucina (adattalo se usi un comando diverso)
BUILD_CMD="cd /home/vagrant/oa-tools && ./m"

if [ -z "$TARGET" ]; then
    echo -e "${RED}Errore: Devi specificare una macchina o 'all'.${NC}"
    echo "Uso: v4build <debian|arch|manjaro|fedora|all>"
    exit 1
fi

# Funzione per lanciare il build su una singola VM
build_machine() {
    local machine=$1
    echo -e "${CYAN}====================================================${NC}"
    echo -e "${CYAN}🚀 Inizio build remoto su: ${machine}...${NC}"
    echo -e "${CYAN}====================================================${NC}"
    
    vagrant ssh "$machine" -c "$BUILD_CMD"
    
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}✅ Build completato con successo su ${machine}!${NC}\n"
    else
        echo -e "${RED}❌ Errore durante il build su ${machine}.${NC}\n"
    fi
}

if [ "$TARGET" == "all" ]; then
    # Array delle tue fucine
    MACHINES=("arch" "manjaro" "debian" "fedora")
    for vm in "${MACHINES[@]}"; do
        # Controlla se la VM è in esecuzione prima di sparare il comando
        if vagrant status "$vm" | grep -q "running"; then
            build_machine "$vm"
        else
            echo -e "${RED}⚠️ La macchina ${vm} è spenta. Salto.${NC}\n"
        fi
    done
else
    # Build su una singola macchina specificata
    build_machine "$TARGET"
fi
