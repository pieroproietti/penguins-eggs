#!/usr/bin/env bash

DISTRO=$1

if [ -z "$DISTRO" ]; then
    echo "⚠️  ERRORE: Specifica su quale distro vuoi forzare i DNS!"
    echo "Uso: $0 <debian|arch|fedora|manjaro>"
    exit 1
fi

echo "🌐 Forzatura dei DNS standard (8.8.8.8, 1.1.1.1) su: $DISTRO..."

# vagrant ssh esegue il comando direttamente dentro la VM come root.
# 1. Rimuove il file o il symlink di systemd-resolved
# 2. Scrive i nameserver standard in un resolv.conf puro e statico
vagrant ssh "$DISTRO" -c 'sudo rm -f /etc/resolv.conf && echo -e "nameserver 8.8.8.8\nnameserver 1.1.1.1" | sudo tee /etc/resolv.conf > /dev/null'

echo "✅ DNS aggiornati con successo su $DISTRO! La rete ora è libera."
