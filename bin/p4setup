#!/bin/bash
#
# p4autocomplete - Genera e installa l'autocompletamento per la suite p4 (User-local)
#

# Path standard XDG per gli autocompletamenti del singolo utente
COMPLETION_DIR="$HOME/.local/share/bash-completion/completions"
MASTER_FILE="p4-suite"
MASTER_PATH="$COMPLETION_DIR/$MASTER_FILE"

# Comandi della suite (aggiunto p4pull mancante)
COMMANDS=(p4config p4create p4deploy p4pull p4push p4reset p4ssh p4start p4stop)

echo "🔨 Preparazione dell'ambiente in $COMPLETION_DIR..."
mkdir -p "$COMPLETION_DIR"

echo "📦 Generazione della logica di autocompletamento..."

cat << 'EOF' > "$MASTER_PATH"
# Autocompletamento Bash per la suite di orchestrazione p4 (oa-tools)

_p4_suite_completion() {
    # Parola corrente che l'utente sta digitando
    local cur="${COMP_WORDS[COMP_CWORD]}"
    
    # Le nostre fucine (bersagli in ordine alfabetico)
    local fucine="alpine arch debian fedora manjaro opensuse"
    
    # Genera i suggerimenti filtrando le fucine in base a cosa è stato digitato finora
    COMPREPLY=( $(compgen -W "$fucine" -- "$cur") )
    
    return 0
}

# Lega la funzione di completamento a TUTTI gli script della suite
complete -F _p4_suite_completion p4config p4create p4deploy p4pull p4push p4reset p4ssh p4start p4stop
EOF

chmod 644 "$MASTER_PATH"

echo "🔗 Creazione dei collegamenti simbolici per il lazy-loading di bash..."
cd "$COMPLETION_DIR" || exit 1

for cmd in "${COMMANDS[@]}"; do
    ln -sf "$MASTER_FILE" "$cmd"
    echo "  -> $cmd collegato"
done

echo ""
echo "✅ Fatto! Autocompletamento installato localmente."
echo "🔄 Per attivarlo, digita in questo terminale:"
echo "   exec bash"
