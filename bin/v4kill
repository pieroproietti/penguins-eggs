#!/usr/bin/env bash

DISTRO=$1

if [ -z "$DISTRO" ]; then
    echo "⚠️  ERRORE: Specifica quale distro vuoi disintegrare!"
    echo "Uso: $0 <debian|arch|fedora|manjaro> (oppure 'all' per fare tabula rasa)"
    exit 1
fi

if [ "$DISTRO" == "all" ]; then
    echo "🔥 DISTRUZIONE TOTALE INIZIATA 🔥"
    vagrant destroy -f
    rm -rf .vagrant/
    echo "Tabula rasa completata!"
    exit 0
fi

echo "💣 Invocazione di Vagrant destroy per: $DISTRO..."
vagrant destroy -f "$DISTRO"

echo "🧹 Esecuzione pulizia d'urto su libvirt per sicurezza..."
DOMAIN="oa-tools_$DISTRO"
sudo virsh destroy "$DOMAIN" 2>/dev/null
sudo virsh undefine "$DOMAIN" 2>/dev/null
sudo virsh vol-delete --pool default "${DOMAIN}.qcow2" 2>/dev/null

echo "☠️  $DISTRO è stata piallata definitivamente."
