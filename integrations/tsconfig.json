{
  "compilerOptions": {
    "target": "es2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*",
    "plugins/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "plugins/**/command-*.ts"
  ],
  "ts-node": {
    "esm": true
  }
}
