#!/usr/bin/env bash

# Flag per interrompere subito lo script in caso di errori imprevisti
set -e

TARGET_DIR="/home/runner/work"

case "$1" in
    -d|--delete)
        if [ -d "$TARGET_DIR" ]; then
            echo "[oa-ci] Rimozione della directory simulata..."
            sudo rmdir -p "$TARGET_DIR" 2>/dev/null || sudo rm -rf "$TARGET_DIR"
            echo "[oa-ci] Ambiente CI ripulito. Ora sei tornato in locale."
        else
            echo "[oa-ci] La directory $TARGET_DIR non esiste già."
        fi
        ;;
    "")
        if [ -d "$TARGET_DIR" ]; then
            echo "[oa-ci] Il sensore radar è già attivo. Directory presente."
        else
            echo "[oa-ci] Creazione della directory fittizia per ingannare il sensore di coa..."
            sudo mkdir -p "$TARGET_DIR"
            # Cambia il proprietario per sicurezza, così coa può leggerla senza fare storie
            sudo chmod 755 /home/runner
            echo "[oa-ci] Fatto! Ora coa crederà di girare dentro GitHub Actions."
        fi
        ;;
    *)
        echo "Uso: $0 [-d | --delete]"
        echo "  (senza argomenti): Crea l'ambiente fittizio per emulare la CI"
        echo "  -d, --delete     : Rimuove l'ambiente fittizio e ripristina il locale"
        exit 1
        ;;
esac

