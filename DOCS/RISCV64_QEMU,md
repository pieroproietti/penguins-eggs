# RISCV64 QEMU

## installazione ISO originale
qemu-img create -f qcow2 disco-target.qcow2 10G
cp /usr/share/qemu-efi-riscv64/RISCV_VIRT_CODE.fd ./VARS.fd

qemu-system-riscv64 \
  -machine virt -cpu rv64 -m 4G -smp 2 \
  -display none -serial stdio \
  -drive if=pflash,format=raw,unit=0,file=/usr/share/qemu-efi-riscv64/RISCV_VIRT_CODE.fd,readonly=on \
  -drive if=pflash,format=raw,unit=1,file=./VARS.fd \
  -device virtio-blk-pci,drive=drive0 \
  -drive file=disco-target.qcow2,format=qcow2,if=none,id=drive0 \
  -device virtio-blk-pci,drive=drive1 \
  -drive file=debian-testing-riscv64-netinst.iso,format=raw,if=none,id=drive1 \
  -device virtio-rng-pci \
  -netdev user,id=net0 -device virtio-net-pci,netdev=net0

