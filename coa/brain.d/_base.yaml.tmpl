# ==============================================================================
# 🧩 TELAIO UNIVERSALE OA (EVOLUTION EDITION)
# ==============================================================================
remaster:

  # ----------------------------------------------------------------------------
  # 1. SETUP INIZIALE E MOUNT
  # ----------------------------------------------------------------------------
  - name: "coa-fs-setup"
    description: "Preparazione dell'ambiente di chroot e mount point"
    action: "oa_mount_logic"


  # ----------------------------------------------------------------------------
  # 2. PREPARAZIONE BOOTLOADERS
  # ----------------------------------------------------------------------------
  - name: "coa-bootloaders"
    description: "Staging degli assets per BIOS (ISOLINUX) e UEFI (GRUB/EFI)"
    action: "oa_shell"
    run_command: |
{{ include "common_bootloaders" . | indent 6 }}

  # ----------------------------------------------------------------------------
  # 3. GENERAZIONE MENU DI AVVIO E BRANDING
  # ----------------------------------------------------------------------------
  - name: "coa-live-menus"
    description: "Generazione dinamica dei menu di GRUB e ISOLINUX"
    action: "oa_shell"
    run_command: |
{{ include "common_live_menus" . | indent 6 }}

  # ----------------------------------------------------------------------------
  # 4. IDENTITÀ UTENTE
  # ----------------------------------------------------------------------------
  - name: "coa-identity"
    description: "Iniezione dell'utente live e purificazione password"
    action: "oa_users"

  # ----------------------------------------------------------------------------
  # 4.1 Sanitize host
  # ----------------------------------------------------------------------------
  - name: "Sanitizzazione universale dell'host (fstab e crypttab)"
    action: "oa_shell"
    chroot: true
    run_command: |
{{ include "sanitize_host" . | indent 6 }}

  # ----------------------------------------------------------------------------
  # 5. INITRAMFS LIVE
  # ----------------------------------------------------------------------------
  - name: "coa-initrd"
    description: "Generazione dell'Initramfs specifico per l'ambiente live"
    action: "oa_shell"
    chroot: true
    run_command: |
{{ include "initramfs_cmd" . | indent 6 }}

  # ----------------------------------------------------------------------------
  # 6. ESTRAZIONE KERNEL E PRIVILEGI
  # ----------------------------------------------------------------------------
  - name: "coa-kernel-copy"
    description: "Copia dinamica di kernel e initrd nella root ISO"
    action: "oa_shell"
    run_command: |
{{ include "common_kernel_copy" . | indent 6 }}    

  # ----------------------------------------------------------------------------
  # 7. PRIVILEGI USER live, AUTOLOGIN E TRUSTED DESKTOP LAUNCHER
  # ----------------------------------------------------------------------------
  - name: "coa-enable-live"
    description: "Configurazione privilegi, launcher fidato e autologin universale"
    action: "oa_shell"
    chroot: true
    run_command: |
{{ include "live_sudoers" . | indent 6 }}
{{ include "live_icon" . | indent 6 }}
{{ include "live_launcher" . | indent 6 }}
{{ include "live_trust_agent" . | indent 6 }}
{{ include "live_autologin" . | indent 6 }}

  # ----------------------------------------------------------------------------
  # 8. COMPRESSIONE FILESYSTEM.SQUASHFS
  # ----------------------------------------------------------------------------
  - name: "coa-squashfs"
    description: "Compressione del filesystem root in formato SquashFS"
    action: "oa_shell"
    run_command: |
{{ include "common_squashfs" . | indent 6 }}

  # ----------------------------------------------------------------------------
  # 9. PACCHETTIZZAZIONE ISO XORRISO
  # ----------------------------------------------------------------------------
  - name: "coa-xorriso"
    description: "Generazione finale dell'immagine ISO ibrida (xorriso)"
    action: "oa_shell"
    run_command: |
{{ include "common_xorriso" . | indent 6 }}

  # ----------------------------------------------------------------------------
  # 10. PULIZIA
  # ----------------------------------------------------------------------------
  - name: "coa-cleanup"
    description: "Smontaggio e pulizia dell'ambiente di lavoro"
    action: "oa_umount"

# ==============================================================================
# 🎯 CALAMARES INSTALLER HOOKS
# ==============================================================================
install:
  - name: "coa-finalize"
    description: "Finalizzazione del target e rigenerazione bootloader host"
    action: "oa_shell"
    run_command: |
{{ include "common_finalize" . | indent 6 }}
