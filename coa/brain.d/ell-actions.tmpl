{{ define "ell_bootloaders" }}
# --- 1. PREPARAZIONE STRUTTURA ---
- name: "coa-boot-dirs"
  description: "Creazione directory bootloader"
  action: "oa_ell"
  params:
    module: "shell"
    command: "mkdir -p /home/eggs/isodir/live /home/eggs/isodir/isolinux /home/eggs/isodir/boot/grub /home/eggs/isodir/EFI/BOOT"

# --- 2. COPIA ASSETS BIOS ---
- name: "coa-copy-isolinux"
  description: "Copia binari ISOLINUX"
  action: "oa_ell"
  params:
    module: "copy"
    src: "/tmp/coa/bootloaders/ISOLINUX/isolinux.bin"
    dest: "/home/eggs/isodir/isolinux/isolinux.bin"
    ignore_missing: true

- name: "coa-copy-syslinux-modules"
  description: "Copia moduli SYSLINUX"
  action: "oa_ell"
  params:
    module: "shell"
    command: "cp /tmp/coa/bootloaders/syslinux/modules/bios/*.c32 /home/eggs/isodir/isolinux/ 2>/dev/null || true"

# --- 3. LOGICA EFI ---
- name: "coa-copy-efi-binary"
  description: "Copia binario EFI"
  action: "oa_ell"
  params:
    module: "shell"
    command: |
      if [ -f "/tmp/coa/bootloaders/grub/x86_64-efi/monolithic/grubx64.efi" ]; then
          cp "/tmp/coa/bootloaders/grub/x86_64-efi/monolithic/grubx64.efi" /home/eggs/isodir/EFI/BOOT/BOOTX64.EFI
      fi

# --- 4. GENERAZIONE EFI.IMG ---
- name: "coa-gen-efi-img"
  description: "Generazione immagine FAT per EFI"
  action: "oa_ell"
  params:
    module: "shell"
    command: |
      dd if=/dev/zero of=/home/eggs/isodir/EFI/BOOT/efi.img bs=1M count=12
      mkfs.vfat /home/eggs/isodir/EFI/BOOT/efi.img
      mmd -i /home/eggs/isodir/EFI/BOOT/efi.img ::/EFI
      mmd -i /home/eggs/isodir/EFI/BOOT/efi.img ::/EFI/BOOT
      if [ -f /home/eggs/isodir/EFI/BOOT/BOOTX64.EFI ]; then
          mcopy -i /home/eggs/isodir/EFI/BOOT/efi.img /home/eggs/isodir/EFI/BOOT/BOOTX64.EFI ::/EFI/BOOT/BOOTX64.EFI
      fi

{{ end }}



{{ define "ell_enable_live" }}
# ============================================================================
# LIVE USER PRIVILEGES, AUTOLOGIN AND TRUSTED DESKTOP LAUNCHER
# ============================================================================

# 1. Configurazione Sudoers (Senza password)
- name: "coa-live-sudoers"
  description: "Configurazione sudoers per utente live"
  action: "oa_ell"
  chroot: true
  params:
    module: "template"
    dest: "/etc/sudoers.d/00-live"
    permissions: 288 # Esadecimale 0440
    content: |
      live ALL=(ALL) NOPASSWD:ALL

# 2. Desktop Launcher Universale
- name: "coa-live-launcher"
  description: "Desktop Launcher di installazione"
  action: "oa_ell"
  chroot: true
  params:
    module: "template"
    dest: "/usr/share/applications/install-system.desktop"
    permissions: 493 # Esadecimale 0755
    content: |
      [Desktop Entry]
      Type=Application
      Version=1.0
      Name=Install System
      GenericName=Live Installer
      Comment=Install this system to your hard disk
      Exec=sudo eggs sysinstall calamares
      Icon=penguins-eggs
      Terminal=false
      Categories=System;

# 3. Trust Agent (Script Bash dinamico creato da YAML)
- name: "coa-trust-agent-script"
  description: "Script per il trust dinamico del desktop launcher"
  action: "oa_ell"
  chroot: true
  params:
    module: "template"
    dest: "/usr/local/bin/oa-trust-desktop"
    permissions: 493 # Esadecimale 0755
    content: |
      #!/bin/bash
      # Trova la cartella Desktop corretta (Scrivania, Desktop, Bureau...)
      DESKTOP_DIR="$(xdg-user-dir DESKTOP 2>/dev/null || echo "$HOME/Desktop")"
      mkdir -p "$DESKTOP_DIR"
      
      LAUNCHER_SRC="/usr/share/applications/install-system.desktop"
      LAUNCHER_DEST="$DESKTOP_DIR/install-system.desktop"
      
      if [ -f "$LAUNCHER_SRC" ]; then
          cp "$LAUNCHER_SRC" "$LAUNCHER_DEST"
          chmod +x "$LAUNCHER_DEST"
      fi
      
      # Attesa del caricamento dell'ambiente grafico
      for i in {1..15}; do
          if pgrep -x xfdesktop >/dev/null || pgrep -x nautilus >/dev/null || pgrep -x nemo >/dev/null || pgrep -x caja >/dev/null || pgrep -f ding >/dev/null || pgrep -x plasmashell >/dev/null || pgrep -x pcmanfm >/dev/null || pgrep -x pcmanfm-qt >/dev/null; then
              break
          fi
          sleep 1
      done
      sleep 2
      
      # Applica il trust
      if ! pgrep -x plasmashell > /dev/null; then
          if [ -f "$LAUNCHER_DEST" ]; then
              gio set "$LAUNCHER_DEST" metadata::trusted yes 2>/dev/null
              gio set "$LAUNCHER_DEST" metadata::xfce-exe-checksum "$(sha256sum "$LAUNCHER_DEST" | awk '{print $1}')" 2>/dev/null
          fi
      fi

# 4. Trust Agent Autostart
- name: "coa-trust-agent-autostart"
  description: "Innesco XDG Autostart per il trust agent"
  action: "oa_ell"
  chroot: true
  params:
    module: "template"
    dest: "/etc/xdg/autostart/trust-installer.desktop"
    permissions: 420 # Esadecimale 0644
    content: |
      [Desktop Entry]
      Type=Application
      Name=Trust Installer
      Exec=/usr/local/bin/oa-trust-desktop
      Hidden=false
      NoDisplay=true
{{ end }}


{{ define "ell_live_menus" }}
  # ============================================================================
  # 3. BOOT MENU & ASSETS (GRUB & ISOLINUX)
  # ============================================================================

  # --- ASSETS: SPLASH SCREEN ---
  - name: "coa-copy-splash-grub"
    description: "Copia splash screen per GRUB"
    action: "oa_ell"
    params:
      module: "copy"
      src: "/etc/oa-tools.d/brain.d/assets/splash.png"
      dest: "/home/eggs/isodir/boot/grub/splash.png"
      ignore_missing: true

  - name: "coa-copy-splash-isolinux"
    description: "Copia splash screen per ISOLINUX"
    action: "oa_ell"
    params:
      module: "copy"
      src: "/etc/oa-tools.d/brain.d/assets/splash.png"
      dest: "/home/eggs/isodir/isolinux/splash.png"
      ignore_missing: true

  # --- ASSETS: FONT UNICODE ---
  # Priorità 2 (Fallback): Copia dagli assets
  - name: "coa-copy-font-assets"
    description: "Copia font GRUB da assets (fallback)"
    action: "oa_ell"
    params:
      module: "copy"
      src: "/etc/oa-tools.d/brain.d/assets/unicode.pf2"
      dest: "/home/eggs/isodir/boot/grub/font.pf2"
      ignore_missing: true

  # Priorità 1 (Principale): Copia dal sistema (sovrascrive se esiste)
  - name: "coa-copy-font-sys"
    description: "Copia font GRUB dal sistema"
    action: "oa_ell"
    params:
      module: "copy"
      src: "/usr/share/grub/unicode.pf2"
      dest: "/home/eggs/isodir/boot/grub/font.pf2"
      ignore_missing: true

  # --- TEMPLATES: GENERAZIONE MENU ---
  - name: "coa-grub-menu-main"
    description: "Generazione dinamica GRUB.cfg principale"
    action: "oa_ell"
    params:
      module: "template"
      dest: "/home/eggs/isodir/boot/grub/grub.cfg"
      content: |
        set timeout=5
        set default=2

        insmod efi_gop
        insmod efi_uga
        insmod all_video
        insmod gfxterm
        insmod png
        insmod part_gpt
        insmod part_msdos
        insmod fat
        insmod iso9660

        search --no-floppy --set=root --label OA_LIVE

        if loadfont /boot/grub/font.pf2; then
            set gfxmode=auto
            terminal_output gfxterm
        fi

        background_image /boot/grub/splash.png

        # ==========================================
        # COLORI MENU PRINCIPALE
        # ==========================================
        set menu_color_normal=white/black
        set menu_color_highlight=white/blue

        # ==========================================
        # COLORI EDITOR E TERMINALE
        # ==========================================
        set color_normal=white/black
        set color_highlight=white/blue

        menuentry "--- oa-tools ---" {
            true
        }
        menuentry "" {
            true
        }
        menuentry "Start [[ osRelease "PRETTY_NAME" ]]" {
            linux /live/vmlinuz {{ template "hook_boot_params" . }}
            initrd /live/initrd.img
        }
        menuentry "Start [[ osRelease "PRETTY_NAME" ]] - RAM mode" {
            linux /live/vmlinuz {{ template "hook_boot_params" . }} toram
            initrd /live/initrd.img
        }

  - name: "coa-isolinux-menu"
    description: "Generazione dinamica ISOLINUX.cfg"
    action: "oa_ell"
    params:
      module: "template"
      dest: "/home/eggs/isodir/isolinux/isolinux.cfg"
      content: |
        UI vesamenu.c32
        TIMEOUT 50
        DEFAULT live

        MENU BACKGROUND splash.png
        MENU TITLE oa-tools

        LABEL live
            MENU LABEL Start [[ osRelease "PRETTY_NAME" ]]
            LINUX /live/vmlinuz
            APPEND {{ template "hook_boot_params" . }}
            INITRD /live/initrd.img

        LABEL ram
            MENU LABEL Start [[ osRelease "PRETTY_NAME" ]] - RAM mode
            LINUX /live/vmlinuz
            APPEND {{ template "hook_boot_params" . }} toram
            INITRD /live/initrd.img

  - name: "coa-efi-trampoline"
    description: "Generazione Trampolino GRUB per EFI"
    action: "oa_ell"
    params:
      module: "template"
      dest: "/home/eggs/isodir/EFI/BOOT/grub.cfg"
      content: |
        search --set=root --file /live/filesystem.squashfs
        set prefix=($root)/boot/grub
        configfile $prefix/grub.cfg
{{ end }}