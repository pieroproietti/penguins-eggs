{{ define "boot_params" }}boot=live components quiet splash{{ end }}

{{ define "initramfs_cmd" }}
      update-initramfs -u -k all
{{ end }}

{{ define "find_kernel_initrd" }}
      KERNEL_PATH=$(ls -1 /home/eggs/liveroot/boot/vmlinuz-* 2>/dev/null | grep -v "rescue" | head -n 1)
      INITRD_PATH=$(ls -1 /home/eggs/liveroot/boot/initrd* 2>/dev/null | grep -v "rescue" | head -n 1)
{{ end }}

{{ define "squashfs_hooks" }}{{ end }}

{{ define "install_logic" }}
      update-initramfs -u
      if [ -d /sys/firmware/efi ]; then
          grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=oa-live --recheck
      else
          TARGET_DISK=$(grub-probe -t disk / 2>/dev/null || echo "/dev/sda")
          grub-install --target=i386-pc --recheck "$TARGET_DISK"
      fi
      update-grub
{{ end }}