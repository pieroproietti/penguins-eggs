# ==============================================================================
# ⛰️ MODULO ALPINE LINUX
# ==============================================================================
# ----------------------------------------------------------------------------
# 0. GRUPPO AMMINISTRATORE (sudo vs wheel)
# ----------------------------------------------------------------------------
{{ define "admin_group" }}wheel{{ end }}

# ----------------------------------------------------------------------------
# 3. GENERAZIONE MENU DI AVVIO E BRANDING
# ATTENZIONE: Questo blocco deve rimanere su una riga singola
# ----------------------------------------------------------------------------
{{ define "boot_params" }}modules=loop,squashfs,sd-mod,usb-storage quiet{{ end }}

# ----------------------------------------------------------------------------
# 5. INITRAMFS LIVE
# ----------------------------------------------------------------------------
{{ define "initramfs_cmd" }}
# 1. Modifichiamo mkinitfs.conf per includere moduli fondamentali per il boot live.
# Alpine usa la variabile 'features' invece di un file 'modules' come Debian.
if ! grep -q "squashfs" /etc/mkinitfs/mkinitfs.conf; then
    sed -i 's/features="/features="squashfs loop ext4 /' /etc/mkinitfs/mkinitfs.conf
fi

# 2. Alpine può avere kernel 'lts', 'virt', 'edge'. Troviamo la versione dinamicamente.
KVER=$(ls -1 /lib/modules/ | head -n 1)

# 3. Generiamo l'initramfs specifico per il boot live
# Usiamo -F per iniettare le feature al volo in caso il sed fallisca
mkinitfs -F "base squashfs loop ext4" -o /boot/initramfs-$KVER $KVER
{{ end }}

# ----------------------------------------------------------------------------
# 6. ESTRAZIONE KERNEL E PRIVILEGI
# ----------------------------------------------------------------------------
{{ define "find_kernel_initrd" }}
# Su Alpine i file si chiamano vmlinuz-[flavor] e initramfs-[flavor]
KERNEL_PATH=$(ls -1 /home/eggs/liveroot/boot/vmlinuz-* 2>/dev/null | head -n 1)
INITRD_PATH=$(ls -1 /home/eggs/liveroot/boot/initramfs-* 2>/dev/null | head -n 1)
{{ end }}

# ----------------------------------------------------------------------------
# 8. COMPRESSIONE FILESYSTEM.SQUASHFS
# ----------------------------------------------------------------------------
{{ define "squashfs_hooks" }}
# Su Alpine non serve l'hook per 'casper', la struttura live standard è sufficiente
{{ end }}

# ==============================================================================
# 🎯 CALAMARES INSTALLER HOOKS
# ==============================================================================
{{ define "install_logic" }}
# 1. Rigeneriamo l'initramfs pulito per il sistema installato sul disco
KVER=$(ls -1 /lib/modules/ | head -n 1)
mkinitfs -o /boot/initramfs-$KVER $KVER

# 2. Installazione GRUB (Ricordati che in APKBUILD abbiamo messo grub-efi tra i depends)
if [ -d /sys/firmware/efi ]; then
    grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=alpine --recheck
else
    TARGET_DISK=$(grub-probe -t disk / 2>/dev/null || echo "/dev/sda")
    grub-install --target=i386-pc --recheck "$TARGET_DISK"
fi

# 3. Alpine non ha 'update-grub', usiamo il binario nativo
grub-mkconfig -o /boot/grub/grub.cfg
{{ end }}
