# ==============================================================================
# ⛰️ MODULO ALPINE LINUX
# ==============================================================================
# ----------------------------------------------------------------------------
# 0. GRUPPO AMMINISTRATORE (sudo vs wheel)
# ----------------------------------------------------------------------------
{{ define "admin_group" }}wheel{{ end }}

# ----------------------------------------------------------------------------
# 3. GENERAZIONE MENU DI AVVIO E BRANDING
# ATTENZIONE: Questo blocco deve rimanere su una riga singola
# ----------------------------------------------------------------------------
{{ define "boot_params" }}modules=loop,squashfs,sd-mod,usb-storage alpinelivelabel=OA_LIVE alpinelivesquashfs=filesystem.squashfs quiet{{ end }}

# ----------------------------------------------------------------------------
# 5. INITRAMFS LIVE
# ----------------------------------------------------------------------------
{{ define "initramfs_cmd" }}
# 1. Creazione della struttura feature 'oa-sidecar'
FEATURE_DIR="/usr/share/mkinitfs/features.d/oa-sidecar"
mkdir -p "$FEATURE_DIR"

# 2. Scrittura del modulo di avvio (Sidecar)
# Utilizziamo la porta 'root=' che Alpine gestisce nativamente
cat << 'EOF' > "$FEATURE_DIR/init"
if [ "${KOPT_root#live:LABEL=}" != "$KOPT_root" ]; then
    LABEL="${KOPT_root#live:LABEL=}"
    ebegin "OA-Sidecar: Booting from $LABEL"
    
    # Forza scansione dispositivi (risolve il mistero della label invisibile)
    for dev in /dev/sd[a-z]*; do [ -b "$dev" ] && blkid -o export "$dev" > /dev/null 2>&1; done
    nlplug-findfs -p /sbin/mdev
    
    devicelive=$(findfs "LABEL=$LABEL")
    if [ -n "$devicelive" ]; then
        fstype=$(blkid | grep -m 1 "$LABEL" | sed -n 's/.*TYPE="\([^"]*\)".*/\1/p')
        mkdir -p /mnt /media/root-ro /media/root-rw/work /media/root-rw/root
        if mount -t "$fstype" -o ro "$devicelive" /mnt/ && \
           mount -t squashfs -o ro "filesystem.squashfs" /media/root-ro; then
            mount -t tmpfs root-tmpfs /media/root-rw
            mount -t overlay overlay -o lowerdir=/media/root-ro,upperdir=/media/root-rw/root,workdir=/media/root-rw/work $sysroot
            
            # Finalizzazione e switch_root
            ! [ -f "$sysroot"/etc/resolv.conf ] && [ -f /etc/resolv.conf ] && cp /etc/resolv.conf "$sysroot"/etc
            exec switch_root $switch_root_opts "$sysroot" $chart_init "$KOPT_init" $KOPT_init_args
        fi
    fi
    eend 1 "Sidecar boot failed"
fi
EOF

# 3. File dei moduli richiesto da mkinitfs
touch "$FEATURE_DIR/modules"

# 4. Configurazione mkinitfs (la tua eredità di eggs)
cat << 'EOF' > /tmp/oa-live.conf
modules="8139cp e1000e r8169 virtio-pci virtio_net tg3"
features="ata base ide scsi cdrom usb virtio ext4 blkid squashfs oa-sidecar"
EOF

# 5. Generazione finale
KVER=$(ls -1 /lib/modules/ | head -n 1)
mkinitfs -c /tmp/oa-live.conf -o /boot/initramfs-$KVER $KVER

# 6. Pulizia
rm -rf "$FEATURE_DIR"
rm -f /tmp/oa-live.conf
{{ end }}

# ----------------------------------------------------------------------------
# 6. ESTRAZIONE KERNEL E PRIVILEGI
# ----------------------------------------------------------------------------
{{ define "find_kernel_initrd" }}
# Su Alpine i file si chiamano vmlinuz-[flavor] e initramfs-[flavor]
KERNEL_PATH=$(ls -1 /home/eggs/liveroot/boot/vmlinuz-* 2>/dev/null | head -n 1)
INITRD_PATH=$(ls -1 /home/eggs/liveroot/boot/initramfs-* 2>/dev/null | head -n 1)
{{ end }}

# ----------------------------------------------------------------------------
# 8. COMPRESSIONE FILESYSTEM.SQUASHFS
# ----------------------------------------------------------------------------
{{ define "squashfs_hooks" }}
# Su Alpine non serve l'hook per 'casper', la struttura live standard è sufficiente
{{ end }}

# ==============================================================================
# 🎯 CALAMARES INSTALLER HOOKS
# ==============================================================================
{{ define "install_logic" }}
# 1. Rigeneriamo l'initramfs pulito per il sistema installato sul disco
KVER=$(ls -1 /lib/modules/ | head -n 1)
mkinitfs -o /boot/initramfs-$KVER $KVER

# 2. Installazione GRUB (Ricordati che in APKBUILD abbiamo messo grub-efi tra i depends)
if [ -d /sys/firmware/efi ]; then
    grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=alpine --recheck
else
    TARGET_DISK=$(grub-probe -t disk / 2>/dev/null || echo "/dev/sda")
    grub-install --target=i386-pc --recheck "$TARGET_DISK"
fi

# 3. Alpine non ha 'update-grub', usiamo il binario nativo
grub-mkconfig -o /boot/grub/grub.cfg
{{ end }}
