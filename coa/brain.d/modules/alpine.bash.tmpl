# ----------------------------------------------------------------------------
# 9. COPY KERNEL/INITRD
# ----------------------------------------------------------------------------
{{ define "distro_copy_kernel_cmd" }}
#!/bin/bash
set -e
LIVEROOT="/home/eggs/liveroot"
ISODIR="/home/eggs/isodir"
FLAVOR="$(uname -r | awk -F- '{print $NF}')"
cp "$LIVEROOT/boot/vmlinuz-$FLAVOR" "$ISODIR/live/vmlinuz"
cp "$LIVEROOT/boot/initramfs-penguins-eggs" "$ISODIR/live/initrd.img"
{{ end }}

# ----------------------------------------------------------------------------
# 8.1 HARDLINK TO isodir/live/filesystem.squashfs in arch, fedora, manjaro
# ----------------------------------------------------------------------------
{{ define "distro_hook_squashfs" -}}
# alpine: distro_hook_squashfs: no need operations
"true"
{{ end -}}

# ==============================================================================
# 🎯 INSTALLER
# ==============================================================================
{{ define "install_distro_initramfs" }}
# Inject target filesystem support into mkinitfs.conf if it's btrfs
if [ -f /etc/mkinitfs/mkinitfs.conf ]; then
    TARGET_FS=$(awk '$2 == "/" {print $3}' /etc/fstab)
    [ -z "$TARGET_FS" ] && TARGET_FS="ext4"
    if [ "$TARGET_FS" = "btrfs" ]; then
        if ! grep -E "^features=.*btrfs" /etc/mkinitfs/mkinitfs.conf >/dev/null; then
            sed -i -E 's/features="([^"]*)"/features="\1 btrfs"/g' /etc/mkinitfs/mkinitfs.conf
        fi
        if [ -x /sbin/rc-update ]; then
            rc-update add btrfs-scan boot || true
        fi
    fi
fi

# Rebuild initramfs for all installed kernel versions
for KDIR in /lib/modules/*; do
    [ -d "$KDIR" ] || continue
    KVER=$(basename "$KDIR")
    FLAVOR="${KVER##*-}"
    if [ -n "$FLAVOR" ]; then
        mkinitfs -o "/boot/initramfs-$FLAVOR" "$KVER"
    fi
done
{{ end }}

{{ define "install_distro_bootloader" }}
TARGET_FS=$(awk '$2 == "/" {print $3}' /etc/fstab)
[ -z "$TARGET_FS" ] && TARGET_FS="ext4"

# If the target filesystem is Btrfs, bind mount / to / inside chroot
# to allow grub-probe/grub-install to correctly detect the Btrfs subvolume layout.
if [ "$TARGET_FS" = "btrfs" ]; then
    mount --bind / /
fi

if [ -f /etc/default/grub ]; then
    # Replace rootfstype=...
    if grep -q "rootfstype=" /etc/default/grub; then
        sed -i -E "s/rootfstype=[^ \"]+/rootfstype=$TARGET_FS/g" /etc/default/grub
    else
        sed -i -E "s/(GRUB_CMDLINE_LINUX_DEFAULT=\"[^\"]*)/\1 rootfstype=$TARGET_FS/g" /etc/default/grub
    fi

    # Replace modules=...
    if grep -q "modules=" /etc/default/grub; then
        OLD_MODS=$(grep -oE "modules=[^\"]+" /etc/default/grub | head -n 1)
        if ! echo "$OLD_MODS" | grep -q "$TARGET_FS"; then
            if echo "$OLD_MODS" | grep -qE "(ext4|ext3|ext2|xfs|btrfs|zfs|f2fs)"; then
                sed -i -E "s/(modules=[^\"]*)(ext4|ext3|ext2|xfs|btrfs|zfs|f2fs)/\1$TARGET_FS/g" /etc/default/grub
            else
                sed -i -E "s/(modules=[^\"]+)/\1,$TARGET_FS/g" /etc/default/grub
            fi
        fi
    else
        sed -i -E "s/(GRUB_CMDLINE_LINUX_DEFAULT=\"[^\"]*)/\1 modules=sd-mod,usb-storage,$TARGET_FS/g" /etc/default/grub
    fi
fi

if [ -d /sys/firmware/efi ]; then
    # Tolerate NVRAM-only failures so the fallback below still runs.
    if [ "$TARGET_FS" = "btrfs" ]; then
        grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=alpine --recheck --no-nvram --modules="btrfs zstd" || echo "-> WARNING: grub-install failed, trying removable fallback anyway..."
    else
        grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=alpine --recheck --no-nvram || echo "-> WARNING: grub-install failed, trying removable fallback anyway..."
    fi

    # Removable fallback: firmware (notably some VM/OVMF setups) with no
    # NVRAM entry falls back to EFI/BOOT/BOOTX64.EFI.
    mkdir -p /boot/efi/EFI/BOOT
    [ -f /boot/efi/EFI/alpine/grubx64.efi ] && cp -f /boot/efi/EFI/alpine/grubx64.efi /boot/efi/EFI/BOOT/BOOTX64.EFI
else
    TARGET_DISK=$(grub-probe -t disk / 2>/dev/null || echo "/dev/sda")
    grub-install --target=i386-pc --recheck "$TARGET_DISK"
fi
grub-mkconfig -o /boot/grub/grub.cfg

# Cleanup the bind mount if we created it
if [ "$TARGET_FS" = "btrfs" ]; then
    umount -l /
fi
{{ end }}

