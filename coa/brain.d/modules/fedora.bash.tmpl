# ==============================================================================
# 🎩 MODULO FEDORA
# ==============================================================================
{{ define "distro_boot_params" }}root=live:LABEL=OA_LIVE rd.live.image rd.shell rd.debug selinux=0 cow_spacesize=2G{{ end }}

# ----------------------------------------------------------------------------
# 5. INITRAMFS LIVE
# ----------------------------------------------------------------------------
{{ define "distro_initramfs_cmd" }}
#!/bin/bash
set -e
# fedora: distro_initramfs_cmd
echo "Generazione initramfs live (dracut)..."
dracut -f --no-hostonly --add "dmsquash-live livenet" --add-drivers "sr_mod iso9660 squashfs loop overlay" /boot/oa-initrd.img 2>&1 | tail -1
{{ end }}

# ----------------------------------------------------------------------------
# 6. COPY KERNEL/INITRD
# ----------------------------------------------------------------------------
{{ define "distro_copy_kernel_cmd" }}
KERNEL_VERSION=$(uname -r)
echo "-> Copia Kernel Fedora ($KERNEL_VERSION)..."

# Usiamo i percorsi assoluti e sicuri, leggendo e scrivendo dove serve davvero
KERNEL_SRC="/home/eggs/liveroot/boot/vmlinuz-$KERNEL_VERSION"
INITRD_SRC="/home/eggs/liveroot/boot/oa-initrd.img"
DEST_DIR="/home/eggs/isodir/live"

# Controllo di sic sul KERNEL
if [ ! -f "$KERNEL_SRC" ] ; then
    echo "[ERRORE FATALE] Impossibile trovare il kernel in $KERNEL_SRC!"
    exit 1
fi

# Controllo di sicurezza sull'INITRD
if [ ! -f "$INITRD_SRC" ] ; then
    echo "[ERRORE FATALE] Impossibile trovare l'initrd in $INITRD_SRC! Dracut non lo ha generato."
    exit 1
fi

# Creiamo la directory di destinazione (se non esiste) e copiamo
mkdir -p "$DEST_DIR"

cp "$KERNEL_SRC" "$DEST_DIR/vmlinuz"
echo "-> Copia oa-initrd.img..."
cp "$INITRD_SRC" "$DEST_DIR/initrd.img"

echo "-> Copia completata con successo."
{{ end }}

# ----------------------------------------------------------------------------
# 8.1 HARDLINK TO isodir/live/filesystem.squashfs in arch, fedora, manjaro
# ----------------------------------------------------------------------------
{{ define "distro_hook_squashfs" }}
#!/bin/bash
set -e
# fedora: distro_hook_squashfs
mkdir -p /home/eggs/isodir/LiveOS
timeout=10
while [ ! -f /home/eggs/isodir/live/filesystem.squashfs ] && [ $timeout -gt 0 ]; do
    sleep 1
    timeout=$((timeout-1))
done
ln -f /home/eggs/isodir/live/filesystem.squashfs /home/eggs/isodir/LiveOS/squashfs.img
{{ end }}

# ==============================================================================
# 🎯 INSTALLER
# ==============================================================================
{{ define "install_distro_initramfs" }}
# 1. Fedora richiede un machine-id valido per dracut e systemd-boot
if [ ! -s /etc/machine-id ]; then
    systemd-machine-id-setup
fi
dracut -f --regenerate-all
{{ end }}

{{ define "install_distro_bootloader" }}
# 1. Autorelabel per SELinux (Senza questo, Fedora post-installazione muore)
echo "-F" > /.autorelabel
#touch /.autorelabel

# --- INIEZIONE KAMIKAZE (Fase 1) ---
# Aggiungiamo enforcing=0 per permettere il primo avvio indolore
if ! grep -q "enforcing=0" /etc/default/grub; then
    sed -i 's/GRUB_CMDLINE_LINUX="/GRUB_CMDLINE_LINUX="enforcing=0 /' /etc/default/grub
fi
# -----------------------------------

# 2. Gestione BLS (Boot Loader Specification)
sed -i 's/GRUB_ENABLE_BLSCFG=true/GRUB_ENABLE_BLSCFG=false/g' /etc/default/grub
if ! grep -q "GRUB_ENABLE_BLSCFG=false" /etc/default/grub; then
      echo "GRUB_ENABLE_BLSCFG=false" >> /etc/default/grub
fi

if [ -d /sys/firmware/efi ]; then
      # 3. IL TRUCCO FEDORA: Recuperiamo shimx64.efi nascosto sotto il mount point
      if [ ! -f /boot/efi/EFI/fedora/shimx64.efi ]; then
          echo "-> Recupero file EFI (shim/SecureBoot) originali di Fedora..."
          # Smonta temporaneamente la partizione EFI target
          umount /boot/efi 2>/dev/null
          
          # Ora vediamo il vero rootfs della live: copiamo i file di shim
          cp -r /boot/efi/EFI /tmp/efi-backup 2>/dev/null || true
          
          # Rimonta la partizione EFI target (assumendo che sia in fstab)
          mount /boot/efi
          
          # Ripristina shim nella partizione pulita
          if [ -d /tmp/efi-backup ]; then
              mkdir -p /boot/efi/EFI
              cp -r /tmp/efi-backup/* /boot/efi/EFI/ 2>/dev/null || true
          fi
      fi

      # 4. Installa GRUB
      grub2-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=fedora --recheck --force
      mkdir -p /boot/efi/EFI/fedora
      
      # 5. Fallback UEFI Assoluto (Garantisce l'avvio anche se la NVRAM fa i capricci)
      if [ -f /boot/efi/EFI/fedora/shimx64.efi ]; then
          mkdir -p /boot/efi/EFI/BOOT
          cp /boot/efi/EFI/fedora/shimx64.efi /boot/efi/EFI/BOOT/BOOTX64.EFI
          cp /boot/efi/EFI/fedora/grubx64.efi /boot/efi/EFI/BOOT/grubx64.efi
      fi

      # 6. Generazione configurazioni
      grub2-mkconfig -o /boot/grub2/grub.cfg
      grub2-mkconfig -o /boot/efi/EFI/fedora/grub.cfg
else
      # BIOS/Legacy
      TARGET_DISK=$(grub2-probe -t disk / 2>/dev/null || echo "/dev/sda")
      grub2-install --target=i386-pc --recheck "$TARGET_DISK"
      grub2-mkconfig -o /boot/grub2/grub.cfg
fi

# --- SERVIZIO KAMIKAZE (Fase 2: Creazione e Innesco) ---
echo "-> Preparazione servizio post-installazione per SELinux..."

# A. Creiamo lo script bash che farà la pulizia
cat << 'EOF' > /usr/local/bin/krill-selinux-cleanup.sh
#!/bin/bash
# Rimuove enforcing=0 dal file di configurazione base
sed -i 's/ enforcing=0//g' /etc/default/grub

# Su Fedora usiamo grubby per aggiornare i parametri del kernel in modo sicuro e senza rompere il BLS
if command -v grubby >/dev/null 2>&1; then
    grubby --remove-args="enforcing=0" --update-kernel=ALL
else
    grub2-mkconfig -o /boot/grub2/grub.cfg
fi

# Riattiva SELinux istantaneamente per questa sessione
#command -v setenforce >/dev/null 2>&1 && setenforce 1

# Autodistruzione
systemctl disable krill-selinux-cleanup.service
rm -f /etc/systemd/system/krill-selinux-cleanup.service
rm -f /usr/local/bin/krill-selinux-cleanup.sh
EOF

chmod +x /usr/local/bin/krill-selinux-cleanup.sh

# B. Creiamo il servizio systemd
cat << 'EOF' > /etc/systemd/system/krill-selinux-cleanup.service
[Unit]
Description=Krill SELinux Post-Install Cleanup
# IL SEGRETO: Esegui SOLO quando .autorelabel NON esiste più (cioè al secondo avvio)
ConditionPathExists=!/.autorelabel
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/krill-selinux-cleanup.sh
RemainAfterExit=no

[Install]
WantedBy=multi-user.target
EOF

# C. Armiamo l'innesco
systemctl enable krill-selinux-cleanup.service
# -------------------------------------------------------
{{ end }}