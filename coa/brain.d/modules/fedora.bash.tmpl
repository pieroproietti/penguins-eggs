# ==============================================================================
# 🎩 FEDORA MODULE
# ==============================================================================
{{ define "distro_boot_params" }}root=live:LABEL=OA_LIVE rd.live.image rd.shell rd.debug selinux=0 cow_spacesize=2G{{ end }}

# ----------------------------------------------------------------------------
# 5. LIVE INITRAMFS
# ----------------------------------------------------------------------------
{{ define "distro_initramfs_cmd" }}
#!/bin/bash
set -e
# fedora: distro_initramfs_cmd
echo "Generating live initramfs (dracut)..."
dracut -f --no-hostonly --add "dmsquash-live livenet" --add-drivers "sr_mod iso9660 squashfs loop overlay" /boot/oa-initrd.img 2>&1 | tail -1
{{ end }}

# ----------------------------------------------------------------------------
# 6. COPY KERNEL/INITRD
# ----------------------------------------------------------------------------
{{ define "distro_copy_kernel_cmd" }}
KERNEL_VERSION=$(uname -r)
echo "-> Copying Fedora Kernel ($KERNEL_VERSION)..."

# Using absolute and safe paths, reading and writing only where strictly needed
KERNEL_SRC="/home/eggs/liveroot/boot/vmlinuz-$KERNEL_VERSION"
INITRD_SRC="/home/eggs/liveroot/boot/oa-initrd.img"
DEST_DIR="/home/eggs/isodir/live"

# Safety check on KERNEL
if [ ! -f "$KERNEL_SRC" ] ; then
    echo "[FATAL ERROR] Cannot find kernel in $KERNEL_SRC!"
    exit 1
fi

# Safety check on INITRD
if [ ! -f "$INITRD_SRC" ] ; then
    echo "[FATAL ERROR] Cannot find initrd in $INITRD_SRC! Dracut did not generate it."
    exit 1
fi

# Create destination directory (if it doesn't exist) and copy
mkdir -p "$DEST_DIR"

cp "$KERNEL_SRC" "$DEST_DIR/vmlinuz"
echo "-> Copying oa-initrd.img..."
cp "$INITRD_SRC" "$DEST_DIR/initrd.img"

echo "-> Copy successfully completed."
{{ end }}

# ----------------------------------------------------------------------------
# 8.1 HARDLINK TO isodir/live/filesystem.squashfs in arch, fedora, manjaro
# ----------------------------------------------------------------------------
{{ define "distro_hook_squashfs" }}
#!/bin/bash
set -e
# fedora: distro_hook_squashfs
mkdir -p /home/eggs/isodir/LiveOS
timeout=10
while [ ! -f /home/eggs/isodir/live/filesystem.squashfs ] && [ $timeout -gt 0 ]; do
    sleep 1
    timeout=$((timeout-1))
done
ln -f /home/eggs/isodir/live/filesystem.squashfs /home/eggs/isodir/LiveOS/squashfs.img
{{ end }}

# ==============================================================================
# 🎯 INSTALLER
# ==============================================================================
{{ define "install_distro_initramfs" }}
# 1. Fedora requires a valid machine-id for dracut and systemd-boot
if [ ! -s /etc/machine-id ]; then
    systemd-machine-id-setup
fi
dracut -f --regenerate-all
{{ end }}

{{ define "install_distro_bootloader" }}
# 1. SELinux autorelabel (Without this, Fedora dies post-installation)
echo "-F" > /.autorelabel
#touch /.autorelabel

# --- KAMIKAZE INJECTION (Phase 1) ---
# Add enforcing=0 to allow a painless first boot
if ! grep -q "enforcing=0" /etc/default/grub; then
    sed -i 's/GRUB_CMDLINE_LINUX="/GRUB_CMDLINE_LINUX="enforcing=0 /' /etc/default/grub
fi
# -----------------------------------

# 2. BLS (Boot Loader Specification) Management
sed -i 's/GRUB_ENABLE_BLSCFG=true/GRUB_ENABLE_BLSCFG=false/g' /etc/default/grub
if ! grep -q "GRUB_ENABLE_BLSCFG=false" /etc/default/grub; then
      echo "GRUB_ENABLE_BLSCFG=false" >> /etc/default/grub
fi

if [ -d /sys/firmware/efi ]; then
      # 3. THE FEDORA TRICK: Recover shimx64.efi hidden under the mount point
      if [ ! -f /boot/efi/EFI/fedora/shimx64.efi ]; then
          echo "-> Recovering original Fedora EFI (shim/SecureBoot) files..."
          # Temporarily unmount the target EFI partition
          umount /boot/efi 2>/dev/null
          
          # Now we can see the real live rootfs: let's copy the shim files
          cp -r /boot/efi/EFI /tmp/efi-backup 2>/dev/null || true
          
          # Remount the target EFI partition (assuming it's in fstab)
          mount /boot/efi
          
          # Restore shim into the clean partition
          if [ -d /tmp/efi-backup ]; then
              mkdir -p /boot/efi/EFI
              cp -r /tmp/efi-backup/* /boot/efi/EFI/ 2>/dev/null || true
          fi
      fi

      # 4. Install GRUB
      grub2-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=fedora --recheck --force
      mkdir -p /boot/efi/EFI/fedora
      
      # 5. Absolute UEFI Fallback (Guarantees boot even if NVRAM acts up)
      if [ -f /boot/efi/EFI/fedora/shimx64.efi ]; then
          mkdir -p /boot/efi/EFI/BOOT
          cp /boot/efi/EFI/fedora/shimx64.efi /boot/efi/EFI/BOOT/BOOTX64.EFI
          cp /boot/efi/EFI/fedora/grubx64.efi /boot/efi/EFI/BOOT/grubx64.efi
      fi

      # 6. Generate configurations
      grub2-mkconfig -o /boot/grub2/grub.cfg
      grub2-mkconfig -o /boot/efi/EFI/fedora/grub.cfg
else
      # BIOS/Legacy
      TARGET_DISK=$(grub2-probe -t disk / 2>/dev/null || echo "/dev/sda")
      grub2-install --target=i386-pc --recheck "$TARGET_DISK"
      grub2-mkconfig -o /boot/grub2/grub.cfg
fi


# --- KAMIKAZE SERVICE (Phase 2: Bulletproof Version) ---
echo "-> Preparing post-installation service for GRUB cleanup..."

# A. Create bash script for text-only cleanup
cat << 'EOF' > /usr/local/bin/krill-selinux-cleanup.sh
#!/bin/bash
# 1. Imposta un ambiente sicuro e traccia l'output in un log
export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
exec > /var/log/krill-selinux-cleanup.log 2>&1

echo "[$(date)] Inizio pulizia parametri SELinux da GRUB..."

# 2. Rimuove enforcing=0 dal file di configurazione base
sed -i 's/ enforcing=0//g' /etc/default/grub
sed -i 's/enforcing=0 //g' /etc/default/grub
sed -i 's/enforcing=0//g' /etc/default/grub

echo "[$(date)] File /etc/default/grub aggiornato. Esecuzione grub2-mkconfig..."

# 3. Safely update the bootloader (Force grub2-mkconfig since BLS is disabled)
grub2-mkconfig -o /boot/grub2/grub.cfg
if [ -d /boot/efi/EFI/fedora ]; then
    grub2-mkconfig -o /boot/efi/EFI/fedora/grub.cfg
fi

echo "[$(date)] GRUB rigenerato con successo. Disabilitazione servizio..."

# 4. Surgical self-destruction (Sicura)
# ATTENZIONE: systemctl disable è sufficiente. 
# NON cancellare il file .service con rm -f, altrimenti systemd andrà in crash
# e interromperà brutalmente questo script prima della fine!
systemctl disable krill-selinux-cleanup.service

echo "[$(date)] Operazione Kamikaze completata."
EOF

chmod +x /usr/local/bin/krill-selinux-cleanup.sh

# B. Create the systemd service
cat << 'EOF' > /etc/systemd/system/krill-selinux-cleanup.service
[Unit]
Description=Krill SELinux Post-Install Cleanup
# Triggers only when relabeling has finished its job
ConditionPathExists=!/.autorelabel
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/krill-selinux-cleanup.sh
RemainAfterExit=no

[Install]
WantedBy=multi-user.target
EOF

# C. Arm the trigger
systemctl enable krill-selinux-cleanup.service
# -------------------------------------------------------
{{ end }}
