# ==============================================================================
# 🎩 MODULO FEDORA
# ==============================================================================
{{ define "distro_admin_group" }}wheel{{ end }}
{{ define "distro_boot_params" }}root=live:LABEL=${VOL_ID} rd.live.image selinux=0 cow_spacesize=2G{{ end }}

# ----------------------------------------------------------------------------
# 5. INITRAMFS LIVE
# ----------------------------------------------------------------------------
{{ define "distro_initramfs_cmd" }}
#!/bin/bash
set -e
# fedora: distro_initramfs_cmd
dracut -f -v --no-hostonly --add "dmsquash-live livenet" /boot/initramfs-fedora.img
{{ end }}

# ----------------------------------------------------------------------------
# 6. COPY KERNEL/INITRD
# ----------------------------------------------------------------------------
{{ define "distro_copy_kernel_cmd" }}
#!/bin/bash
set -e
# fedora: distro_copy_kernel_cmd

KERNEL_VERSION=$(uname -r)
echo "-> Copia Kernel Fedora ($KERNEL_VERSION)..."

KERNEL_SRC="/boot/vmlinuz-$KERNEL_VERSION"
INITRD_SRC="/boot/initramfs-$KERNEL_VERSION.img"

# Controllo di sicurezza
if [ ! -f "$KERNEL_SRC" ] || [ ! -f "$INITRD_SRC" ]; then
    echo "[ERRORE FATALE] Impossibile trovare i file di boot per Fedora ($KERNEL_VERSION) in /boot!"
    exit 1
fi

# Copia nella isodir
cp "$KERNEL_SRC" /home/eggs/isodir/live/vmlinuz
cp "$INITRD_SRC" /home/eggs/isodir/live/initrd.img

echo "-> Copia completata con successo."
{{ end }}

# ----------------------------------------------------------------------------
# 8. COMPRESSIONE FILESYSTEM.SQUASHFS
# ----------------------------------------------------------------------------
{{ define "distro_hook_squashfs" }}
#!/bin/bash
set -e
# fedora: distro_hook_squashfs
mkdir -p /home/eggs/isodir/LiveOS
timeout=10
while [ ! -f /home/eggs/isodir/live/filesystem.squashfs ] && [ $timeout -gt 0 ]; do
    sleep 1
    timeout=$((timeout-1))
done
ln -f /home/eggs/isodir/live/filesystem.squashfs /home/eggs/isodir/LiveOS/squashfs.img
{{ end }}

# ==============================================================================
# 🎯 CALAMARES INSTALLER HOOKS
# ==============================================================================
{{ define "distro_hook_install_logic" }}
#!/bin/bash
set -e
# fedora: distro_hook_install_logic
rm -f /etc/sudoers.d/00-live
sed -i 's/GRUB_ENABLE_BLSCFG=true/GRUB_ENABLE_BLSCFG=false/g' /etc/default/grub
if ! grep -q "GRUB_ENABLE_BLSCFG=false" /etc/default/grub; then
      echo "GRUB_ENABLE_BLSCFG=false" >> /etc/default/grub
fi

dracut -f --regenerate-all

if [ -d /sys/firmware/efi ]; then
      grub2-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=fedora --recheck --force
      grub2-mkconfig -o /boot/grub2/grub.cfg
      mkdir -p /boot/efi/EFI/fedora
      grub2-mkconfig -o /boot/efi/EFI/fedora/grub.cfg
else
      TARGET_DISK=$(grub2-probe -t disk / 2>/dev/null || echo "/dev/sda")
      grub2-install --target=i386-pc --recheck "$TARGET_DISK"
      grub2-mkconfig -o /boot/grub2/grub.cfg
fi
{{ end }}
