# ==============================================================================
# 🎩 MODULO FEDORA
# ==============================================================================
{{ define "distro_boot_params" }}root=live:LABEL=OA_LIVE rd.live.image rd.shell rd.debug selinux=0 cow_spacesize=2G{{ end }}

# ----------------------------------------------------------------------------
# 5. INITRAMFS LIVE
# ----------------------------------------------------------------------------
{{ define "distro_initramfs_cmd" }}
#!/bin/bash
set -e
# fedora: distro_initramfs_cmd
echo "Generazione initramfs live (dracut)..."
dracut -f --no-hostonly --add "dmsquash-live livenet" --add-drivers "sr_mod iso9660 squashfs loop overlay" /boot/oa-initrd.img 2>&1 | tail -1
{{ end }}

# ----------------------------------------------------------------------------
# 6. COPY KERNEL/INITRD
# ----------------------------------------------------------------------------
{{ define "distro_copy_kernel_cmd" }}
KERNEL_VERSION=$(uname -r)
echo "-> Copia Kernel Fedora ($KERNEL_VERSION)..."

# Usiamo i percorsi assoluti e sicuri, leggendo e scrivendo dove serve davvero
KERNEL_SRC="/home/eggs/liveroot/boot/vmlinuz-$KERNEL_VERSION"
INITRD_SRC="/home/eggs/liveroot/boot/oa-initrd.img"
DEST_DIR="/home/eggs/isodir/live"

# Controllo di sic sul KERNEL
if [ ! -f "$KERNEL_SRC" ] ; then
    echo "[ERRORE FATALE] Impossibile trovare il kernel in $KERNEL_SRC!"
    exit 1
fi

# Controllo di sicurezza sull'INITRD
if [ ! -f "$INITRD_SRC" ] ; then
    echo "[ERRORE FATALE] Impossibile trovare l'initrd in $INITRD_SRC! Dracut non lo ha generato."
    exit 1
fi

# Creiamo la directory di destinazione (se non esiste) e copiamo
mkdir -p "$DEST_DIR"

cp "$KERNEL_SRC" "$DEST_DIR/vmlinuz"
echo "-> Copia oa-initrd.img..."
cp "$INITRD_SRC" "$DEST_DIR/initrd.img"

echo "-> Copia completata con successo."
{{ end }}

# ----------------------------------------------------------------------------
# 8.1 HARDLINK TO isodir/live/filesystem.squashfs in arch, fedora, manjaro
# ----------------------------------------------------------------------------
{{ define "distro_hook_squashfs" }}
#!/bin/bash
set -e
# fedora: distro_hook_squashfs
mkdir -p /home/eggs/isodir/LiveOS
timeout=10
while [ ! -f /home/eggs/isodir/live/filesystem.squashfs ] && [ $timeout -gt 0 ]; do
    sleep 1
    timeout=$((timeout-1))
done
ln -f /home/eggs/isodir/live/filesystem.squashfs /home/eggs/isodir/LiveOS/squashfs.img
{{ end }}

# ==============================================================================
# 🎯 INSTALLER
# ==============================================================================
{{ define "install_distro_initramfs" }}
dracut -f --regenerate-all
{{ end }}

{{ define "install_distro_bootloader" }}
# Rilevamento automatico e dispatch del bootloader
if [ -d /sys/firmware/efi ] && command -v bootctl &> /dev/null; then
    {{ include "install_distro_systemd_boot" . }}
elif command -v limine &> /dev/null; then
    {{ include "install_distro_limine" . }}
else
    {{ include "install_distro_grub" . }}
fi
{{ end }}

{{ define "install_distro_grub" }}
sed -i 's/GRUB_ENABLE_BLSCFG=true/GRUB_ENABLE_BLSCFG=false/g' /etc/default/grub
if ! grep -q "GRUB_ENABLE_BLSCFG=false" /etc/default/grub; then
      echo "GRUB_ENABLE_BLSCFG=false" >> /etc/default/grub
fi
if [ -d /sys/firmware/efi ]; then
      grub2-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=fedora --recheck --force
      grub2-mkconfig -o /boot/grub2/grub.cfg
      mkdir -p /boot/efi/EFI/fedora
      grub2-mkconfig -o /boot/efi/EFI/fedora/grub.cfg
else
      TARGET_DISK=$(grub2-probe -t disk / 2>/dev/null || echo "/dev/sda")
      grub2-install --target=i386-pc --recheck "$TARGET_DISK"
      grub2-mkconfig -o /boot/grub2/grub.cfg
fi
{{ end }}

{{ define "install_distro_systemd_boot" }}
echo "-> Installazione di systemd-boot (bootctl) su Fedora..."
bootctl install --esp-path=/boot/efi

mkdir -p /boot/efi/loader/entries

KERNEL_FILE=$(ls -1 /boot/vmlinuz-* 2>/dev/null | grep -v rescue | head -n 1 | xargs basename)
INITRD_FILE=$(ls -1 /boot/initramfs-*.img /boot/initrd-*.img 2>/dev/null | grep -v rescue | head -n 1 | xargs basename)

cp /boot/$KERNEL_FILE /boot/efi/
cp /boot/$INITRD_FILE /boot/efi/

ROOT_PART=$(grep " / " /etc/fstab | grep -v "^#" | awk '{print $1}')
ROOT_FSTYPE=$(findmnt -n -o FSTYPE /)
ROOTFLAGS=""
if [ "$ROOT_FSTYPE" = "btrfs" ]; then
    ROOTFLAGS="rootflags=subvol=@"
fi

cat <<EOF > /boot/efi/loader/entries/oa-linux.conf
title   OA Linux (Fedora)
linux   /$KERNEL_FILE
initrd  /$INITRD_FILE
options root=$ROOT_PART rw $ROOTFLAGS
EOF

cat <<EOF > /boot/efi/loader/loader.conf
default oa-linux.conf
timeout 5
console-mode max
editor yes
EOF
{{ end }}

{{ define "install_distro_limine" }}
echo "-> Installazione di Limine bootloader su Fedora..."
if [ -d /sys/firmware/efi ]; then
    # UEFI
    mkdir -p /boot/efi/EFI/BOOT
    cp /usr/share/limine/BOOTX64.EFI /boot/efi/EFI/BOOT/
    
    KERNEL_FILE=$(ls -1 /boot/vmlinuz-* 2>/dev/null | grep -v rescue | head -n 1)
    INITRD_FILE=$(ls -1 /boot/initramfs-*.img /boot/initrd-*.img 2>/dev/null | grep -v rescue | head -n 1)
    ROOT_PART=$(grep " / " /etc/fstab | grep -v "^#" | awk '{print $1}')
    ROOT_FSTYPE=$(findmnt -n -o FSTYPE /)
    ROOTFLAGS=""
    if [ "$ROOT_FSTYPE" = "btrfs" ]; then
        ROOTFLAGS="rootflags=subvol=@"
    fi
    
    cat <<EOF > /boot/efi/limine.conf
timeout: 5
/OA Linux (Fedora)
    protocol: linux
    kernel_path: boot://$KERNEL_FILE
    initramfs_path: boot://$INITRD_FILE
    cmdline: root=$ROOT_PART rw $ROOTFLAGS
EOF
else
    # BIOS/Legacy
    TARGET_DISK=$(grub2-probe -t disk / 2>/dev/null || echo "/dev/sda")
    limine bios-install "$TARGET_DISK"
    
    KERNEL_FILE=$(ls -1 /boot/vmlinuz-* 2>/dev/null | grep -v rescue | head -n 1)
    INITRD_FILE=$(ls -1 /boot/initramfs-*.img /boot/initrd-*.img 2>/dev/null | grep -v rescue | head -n 1)
    ROOT_PART=$(grep " / " /etc/fstab | grep -v "^#" | awk '{print $1}')
    ROOT_FSTYPE=$(findmnt -n -o FSTYPE /)
    ROOTFLAGS=""
    if [ "$ROOT_FSTYPE" = "btrfs" ]; then
        ROOTFLAGS="rootflags=subvol=@"
    fi
    
    cat <<EOF > /boot/limine.conf
timeout: 5
/OA Linux (Fedora)
    protocol: linux
    kernel_path: boot://$KERNEL_FILE
    initramfs_path: boot://$INITRD_FILE
    cmdline: root=$ROOT_PART rw $ROOTFLAGS
EOF
fi
{{ end }}

