# ==============================================================================
# 🎩 FEDORA MODULE
# ==============================================================================
{{ define "distro_boot_params" }}root=live:LABEL=OA_LIVE rd.live.image rd.shell rd.debug selinux=0 cow_spacesize=2G{{ end }}

# ----------------------------------------------------------------------------
# 5. LIVE INITRAMFS
# ----------------------------------------------------------------------------
{{ define "distro_initramfs_cmd" }}
#!/bin/bash
set -e
# fedora: distro_initramfs_cmd
echo "Generating live initramfs (dracut)..."
dracut -f --no-hostonly --add "dmsquash-live livenet" --add-drivers "sr_mod iso9660 squashfs loop overlay" /boot/oa-initrd.img 2>&1 | tail -1
{{ end }}

# ----------------------------------------------------------------------------
# 6. COPY KERNEL/INITRD
# ----------------------------------------------------------------------------
{{ define "distro_copy_kernel_cmd" }}
KERNEL_VERSION=$(uname -r)
echo "-> Copying Fedora Kernel ($KERNEL_VERSION)..."

# Using absolute and safe paths, reading and writing only where strictly needed
KERNEL_SRC="/home/eggs/liveroot/boot/vmlinuz-$KERNEL_VERSION"
INITRD_SRC="/home/eggs/liveroot/boot/oa-initrd.img"
DEST_DIR="/home/eggs/isodir/live"

# Safety check on KERNEL
if [ ! -f "$KERNEL_SRC" ] ; then
    echo "[FATAL ERROR] Cannot find kernel in $KERNEL_SRC!"
    exit 1
fi

# Safety check on INITRD
if [ ! -f "$INITRD_SRC" ] ; then
    echo "[FATAL ERROR] Cannot find initrd in $INITRD_SRC! Dracut did not generate it."
    exit 1
fi

# Create destination directory (if it doesn't exist) and copy
mkdir -p "$DEST_DIR"

cp "$KERNEL_SRC" "$DEST_DIR/vmlinuz"
echo "-> Copying oa-initrd.img..."
cp "$INITRD_SRC" "$DEST_DIR/initrd.img"

echo "-> Copy successfully completed."
{{ end }}

# ----------------------------------------------------------------------------
# 8.1 HARDLINK TO isodir/live/filesystem.squashfs in arch, fedora, manjaro
# ----------------------------------------------------------------------------
{{ define "distro_hook_squashfs" }}
#!/bin/bash
set -e
# fedora: distro_hook_squashfs
mkdir -p /home/eggs/isodir/LiveOS
timeout=10
while [ ! -f /home/eggs/isodir/live/filesystem.squashfs ] && [ $timeout -gt 0 ]; do
    sleep 1
    timeout=$((timeout-1))
done
ln -f /home/eggs/isodir/live/filesystem.squashfs /home/eggs/isodir/LiveOS/squashfs.img
{{ end }}

# ==============================================================================
# 🎯 INSTALLER
# ==============================================================================
{{ define "install_distro_initramfs" }}
# 1. Fedora requires a valid machine-id for dracut and systemd-boot
if [ ! -s /etc/machine-id ]; then
    systemd-machine-id-setup
fi
dracut -f --regenerate-all
{{ end }}

{{ define "install_distro_bootloader" }}
# 1. SELinux autorelabel (Without this, Fedora dies post-installation)
echo "-F" > /.autorelabel
#touch /.autorelabel

# --- KAMIKAZE SERVICE (Phase 2: Final Reset Version) ---
echo "-> Preparing post-installation service for GRUB cleanup..."

# A. Create bash script for text-only cleanup and final reboot
cat << 'EOF' > /usr/local/bin/krill-selinux-cleanup.sh
#!/bin/bash
# 1. Set a safe environment and trace the output to a log
export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
exec > /var/log/krill-selinux-cleanup.log 2>&1

echo "[$(date)] Starting SELinux parameter cleanup from GRUB..."

# 2. Remove enforcing=0 from the base configuration file
sed -i 's/ enforcing=0//g' /etc/default/grub
sed -i 's/enforcing=0 //g' /etc/default/grub
sed -i 's/enforcing=0//g' /etc/default/grub

echo "[$(date)] /etc/default/grub updated. Executing grub2-mkconfig..."

# 3. Safely update the bootloader (Force grub2-mkconfig since BLS is disabled)
grub2-mkconfig -o /boot/grub2/grub.cfg
if [ -d /boot/efi/EFI/fedora ]; then
    grub2-mkconfig -o /boot/efi/EFI/fedora/grub.cfg
fi

echo "[$(date)] GRUB successfully regenerated. Disabling service..."

# 4. Surgical self-destruction (Safe)
systemctl disable krill-selinux-cleanup.service

echo "[$(date)] Kamikaze operation completed. Executing final reboot..."

# 5. The Final Touch: Notify the user and reboot the machine
wall "Krill: Post-installation and SELinux configuration completed. Final reboot in progress..."
sleep 2
systemctl reboot
EOF

chmod +x /usr/local/bin/krill-selinux-cleanup.sh

# B. Create the systemd service
cat << 'EOF' > /etc/systemd/system/krill-selinux-cleanup.service
[Unit]
Description=Krill SELinux Post-Install Cleanup
# Triggers only when relabeling has finished its job
ConditionPathExists=!/.autorelabel
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/krill-selinux-cleanup.sh
RemainAfterExit=no

[Install]
WantedBy=multi-user.target
EOF

# C. Arm the trigger
systemctl enable krill-selinux-cleanup.service
# -------------------------------------------------------

{{ end }}
