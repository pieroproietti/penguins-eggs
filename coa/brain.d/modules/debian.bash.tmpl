# ==============================================================================
# 🌀 MODULO DEBIAN / UBUNTU
# ==============================================================================
# ----------------------------------------------------------------------------
# 0. GRUPPO AMMINISTRATORE (sudo vs wheel)
# ----------------------------------------------------------------------------
{{ define "admin_group" }}sudo{{ end }}

# ----------------------------------------------------------------------------
# 3. GENERAZIONE MENU DI AVVIO E BRANDING
# ATTENZIONE: Questo blocco deve rimanere su una riga singola
# ----------------------------------------------------------------------------
{{ define "boot_params" }}boot=live components rootwait{{ end }}

# ----------------------------------------------------------------------------
# 5. INITRAMFS LIVE
# ----------------------------------------------------------------------------
{{ define "initramfs_cmd" }}
# 1. Forziamo l'initramfs a includere la maggior parte dei moduli (disabilitiamo 'dep')
sed -i 's/^MODULES=.*/MODULES=most/' /etc/initramfs-tools/initramfs.conf

# 2. Iniettiamo i moduli assicurandoci della sintassi corretta (col trattino!)
for mod in fat vfat nls_cp437 nls_iso8859-1 nls_utf8; do
    if ! grep -q "^${mod}$" /etc/initramfs-tools/modules; then
        echo "$mod" >> /etc/initramfs-tools/modules
    fi
done

# (Opzionale ma consigliato per Ubuntu)
# Assicuriamoci che initramfs-tools legga le modifiche
depmod -a $(ls /lib/modules/ | head -n 1) 2>/dev/null || true

# 3. Forziamo Debian a non cercare dischi di swap fantasma (evita timeout di 30s al boot)
echo "RESUME=none" > /etc/initramfs-tools/conf.d/resume
update-initramfs -u -k all
{{ end }}

# ----------------------------------------------------------------------------
# 6. ESTRAZIONE KERNEL E PRIVILEGI
# ----------------------------------------------------------------------------
{{ define "find_kernel_initrd" }}
KERNEL_PATH=$(ls -1 /home/eggs/liveroot/boot/vmlinuz-* 2>/dev/null | grep -v "rescue" | head -n 1)
INITRD_PATH=$(ls -1 /home/eggs/liveroot/boot/initrd* 2>/dev/null | grep -v "rescue" | head -n 1)
{{ end }}

# ----------------------------------------------------------------------------
# 8. COMPRESSIONE FILESYSTEM.SQUASHFS
# ----------------------------------------------------------------------------
{{ define "squashfs_hooks" }}
# mkdir -p /home/eggs/isodir/casper
# ln -f /home/eggs/isodir/live/filesystem.squashfs /home/eggs/isodir/casper/filesystem.squashfs
{{ end }}

# ==============================================================================
# 🎯 CALAMARES INSTALLER HOOKS
# ==============================================================================
{{ define "install_logic" }}
# Applichiamo il fix anche sul sistema installato prima di generare l'initramfs
echo "RESUME=none" > /etc/initramfs-tools/conf.d/resume
update-initramfs -u

if [ -d /sys/firmware/efi ]; then
    grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=oa-live --recheck
else
    TARGET_DISK=$(grub-probe -t disk / 2>/dev/null || echo "/dev/sda")
    grub-install --target=i386-pc --recheck "$TARGET_DISK"
fi
update-grub
{{ end }}