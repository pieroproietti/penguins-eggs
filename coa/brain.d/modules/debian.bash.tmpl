# ==============================================================================
# 🌀 MODULO DEBIAN / UBUNTU
# ==============================================================================
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# DECLARATIVE COSTANTS 
# ----------------------------------------------------------------------------
{{ define "distro_boot_params" }}boot=live components cow_spacesize=2G{{ end }}

# ----------------------------------------------------------------------------
# 5. INITRAMFS LIVE
# ----------------------------------------------------------------------------
{{ define "distro_initramfs_cmd" }}
# debian: distro_initramfs_cmd: no need operations
"true"
{{ end -}}

# ----------------------------------------------------------------------------
# 6. COPY KERNEL/INITRD
# ----------------------------------------------------------------------------
{{ define "distro_copy_kernel_cmd" }}
#!/bin/bash
set -e
# debian: distro_copy_kernel_cmd

KERNEL_VERSION=$(uname -r)
echo "-> Copia Kernel Debian/Ubuntu ($KERNEL_VERSION)..."

cp "/boot/vmlinuz-$KERNEL_VERSION" /home/eggs/isodir/live/vmlinuz
cp "/boot/initrd.img-$KERNEL_VERSION" /home/eggs/isodir/live/initrd.img
{{ end }}

# ----------------------------------------------------------------------------
# 8.1 HARDLINK TO isodir/live/filesystem.squashfs in arch, fedora, manjaro
# ----------------------------------------------------------------------------
{{ define "distro_hook_squashfs" -}}
# debian: distro_hook_squashfs: no need operations
"true"
{{ end -}}



# ==============================================================================
# 🎯 INSTALLER
# ==============================================================================
{{ define "install_distro_initramfs" }}
echo "RESUME=none" > /etc/initramfs-tools/conf.d/resume
update-initramfs -u
{{ end }}

{{ define "install_distro_bootloader" }}
if [ -d /sys/firmware/efi ]; then
    grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=oa-live --recheck

    # Removable fallback: firmware (notably some VM/OVMF setups) with no
    # NVRAM entry falls back to EFI/BOOT/BOOTX64.EFI.
    mkdir -p /boot/efi/EFI/BOOT
    [ -f /boot/efi/EFI/oa-live/grubx64.efi ] && cp -f /boot/efi/EFI/oa-live/grubx64.efi /boot/efi/EFI/BOOT/BOOTX64.EFI
else
    TARGET_DISK=$(grub-probe -t disk / 2>/dev/null || echo "/dev/sda")
    grub-install --target=i386-pc --recheck "$TARGET_DISK"
fi
update-grub
{{ end }}

