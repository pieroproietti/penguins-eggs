# ==============================================================================
# 🏹 MODULO ARCH LINUX
# ==============================================================================
# ----------------------------------------------------------------------------
# 0. GRUPPO AMMINISTRATORE (sudo vs wheel)
# ----------------------------------------------------------------------------
{{ define "admin_group" }}wheel{{ end }}

# ----------------------------------------------------------------------------
# 3. GENERAZIONE MENU DI AVVIO E BRANDING
# ----------------------------------------------------------------------------
{{ define "hook_boot_params" }}archisobasedir=arch archisolabel=OA_LIVE cow_spacesize=2G{{ end }}

# ----------------------------------------------------------------------------
# 5. INITRAMFS LIVE
# ----------------------------------------------------------------------------
{{ define "hook_initramfs_cmd" }}
mv /etc/mkinitcpio.conf /etc/mkinitcpio.conf.bak
cat << 'EOF' > /etc/mkinitcpio.conf
MODULES=(loop dm-snapshot btrfs)
HOOKS=(base udev microcode modconf kms archiso archiso_loop_mnt archiso_pxe_common archiso_pxe_nbd archiso_pxe_http archiso_pxe_nfs block filesystems keyboard keymap consolefont filesystems fsck)
COMPRESSION="zstd"      
EOF
mkinitcpio -P
mv /etc/mkinitcpio.conf.bak /etc/mkinitcpio.conf
{{ end }}

# ----------------------------------------------------------------------------
# 6. ESTRAZIONE KERNEL E PRIVILEGI
# ----------------------------------------------------------------------------
{{ define "hook_kernel_paths" }}
KERNEL_PATH=$(ls -1 /home/eggs/liveroot/boot/vmlinuz-* 2>/dev/null | grep -v "fallback" | head -n 1)
INITRD_PATH=$(ls -1 /home/eggs/liveroot/boot/initramfs* 2>/dev/null | grep -v "fallback" | head -n 1)
{{ end }}

# ----------------------------------------------------------------------------
# 8. COMPRESSIONE FILESYSTEM.SQUASHFS
# ----------------------------------------------------------------------------
{{ define "hook_squashfs" }}
mkdir -p /home/eggs/isodir/arch/x86_64
timeout=10
while [ ! -f /home/eggs/isodir/live/filesystem.squashfs ] && [ $timeout -gt 0 ]; do
    sleep 1
    timeout=$((timeout-1))
done
ln -f /home/eggs/isodir/live/filesystem.squashfs /home/eggs/isodir/arch/x86_64/airootfs.sfs
{{ end }}

# ==============================================================================
# 🎯 CALAMARES INSTALLER HOOKS
# ==============================================================================
{{ define "hook_install_logic" }}
mkinitcpio -P
if [ -d /sys/firmware/efi ]; then
      grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=oa-live --recheck
else
      TARGET_DISK=$(grub-probe -t disk / 2>/dev/null || echo "/dev/sda")
      grub-install --target=i386-pc --recheck "$TARGET_DISK"
fi
grub-mkconfig -o /boot/grub/grub.cfg
{{ end }}
