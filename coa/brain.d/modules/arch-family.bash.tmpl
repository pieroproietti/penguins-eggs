# ==============================================================================
# 🏹 MASTER-MODULE ARCH FAMILY (arch-family.bash.tmpl)
# Includes: Arch Linux, Manjaro, Garuda, and derivatives (EndeavourOS, etc.)
# ==============================================================================

# ----------------------------------------------------------------------------
# DECLARATIVE CONSTANTS (Live Boot Parameters)
# ----------------------------------------------------------------------------
{{ define "distro_boot_params" }}
{{- if or (eq .DistroID "garuda") (eq .DistroID "endeavouros") -}}
root=live:CDLABEL=OA_LIVE rd.live.image rd.live.dir=arch/x86_64 rd.live.squashimg=airootfs.sfs rd.live.overlay.size=2048 quiet
{{- else if eq .Family "manjaro" -}}
misobasedir=manjaro misolabel=OA_LIVE cow_spacesize=2G
{{- else -}}
archisobasedir=arch archisolabel=OA_LIVE cow_spacesize=2G
{{- end -}}
{{ end }}

# ----------------------------------------------------------------------------
# 5. LIVE INITRAMFS
# ----------------------------------------------------------------------------
{{ define "distro_initramfs_cmd" }}
#!/bin/bash
set -e

echo "-> Preparing Initramfs configuration for Live (Arch Family)..."

{{ if or (eq .DistroID "garuda") (eq .DistroID "endeavouros") }}
    # ==========================================
    # GARUDA/ENDEAVOUROS BRANCH (Dracut)
    # ==========================================
    echo "-> Garuda/EndeavourOS Linux detected: Generating Live via dracut"
    
    # 1. Controllo dipendenze opzionali: Dracut
    if ! command -v dracut > /dev/null 2>&1; then
        echo "-> dracut missing. Installing on the fly..."
        pacman -Sy --noconfirm dracut || { echo "[FATAL ERROR] Unable to install dracut"; exit 1; }
    fi
    
    # We are already in chroot, so dracut works directly on /boot
    # Adding -N to disable host-only mode (crucial for live environments)
    dracut -N -f --add "dmsquash-live" "/boot/oa-initrd.img"

{{ else }}
    # ==========================================
    # ARCH / MANJARO BRANCH (mkinitcpio)
    # ==========================================
    
    # 2. Controllo dipendenze di rete comuni per mkinitcpio
    if ! pacman -Qq mkinitcpio-nfs-utils > /dev/null 2>&1; then
        echo "-> mkinitcpio-nfs-utils missing. Installing on the fly..."
        pacman -Sy --noconfirm mkinitcpio-nfs-utils || { echo "[WARNING] Unable to install mkinitcpio-nfs-utils"; }
    fi

    cp /etc/mkinitcpio.conf /etc/mkinitcpio.conf.bak
    mkdir -p /etc/mkinitcpio.conf.d.bak /usr/lib/mkinitcpio.conf.d.bak
    [ "$(ls -A /etc/mkinitcpio.conf.d/ 2>/dev/null)" ] && mv /etc/mkinitcpio.conf.d/*.conf /etc/mkinitcpio.conf.d.bak/
    [ "$(ls -A /usr/lib/mkinitcpio.conf.d/ 2>/dev/null)" ] && mv /usr/lib/mkinitcpio.conf.d/*.conf /usr/lib/mkinitcpio.conf.d.bak/

    trap '
    mv /etc/mkinitcpio.conf.bak /etc/mkinitcpio.conf
    [ "$(ls -A /etc/mkinitcpio.conf.d.bak/ 2>/dev/null)" ] && mv /etc/mkinitcpio.conf.d.bak/*.conf /etc/mkinitcpio.conf.d/
    [ "$(ls -A /usr/lib/mkinitcpio.conf.d.bak/ 2>/dev/null)" ] && mv /usr/lib/mkinitcpio.conf.d.bak/*.conf /usr/lib/mkinitcpio.conf.d/
    rm -rf /etc/mkinitcpio.conf.d.bak /usr/lib/mkinitcpio.conf.d.bak
    ' EXIT

    {{ if eq .Family "manjaro" }}
        # 3. Controllo dipendenze opzionali: Manjaro
        # WARNING: -Qq checks for the exact name
        if ! pacman -Qq manjaro-tools-iso > /dev/null 2>&1; then 
            echo "-> manjaro-tools-iso missing. Installing on the fly..."
            pacman -Sy --noconfirm manjaro-tools-iso || { echo "[FATAL ERROR] Unable to install manjaro-tools-iso"; exit 1; }
        fi
        cat << 'EOF' > /etc/mkinitcpio.conf
MODULES=(loop dm-snapshot btrfs sr_mod isofs)
HOOKS=(base udev microcode modconf kms miso miso_loop_mnt block keyboard keymap consolefont filesystems)
COMPRESSION="zstd"
EOF
    {{ else }}
        # 4. Controllo dipendenze opzionali: Arch Puro
        if ! pacman -Qq archiso > /dev/null 2>&1; then 
            echo "-> archiso missing. Installing on the fly..."
            pacman -Sy --noconfirm archiso || { echo "[FATAL ERROR] Unable to install archiso"; exit 1; }
        fi
        
        if ! pacman -Qq mkinitcpio-archiso > /dev/null 2>&1; then 
            echo "-> mkinitcpio-archiso missing. Installing on the fly..."
            pacman -Sy --noconfirm mkinitcpio-archiso || { echo "[FATAL ERROR] Unable to install mkinitcpio-archiso"; exit 1; }
        fi
        
        cat << 'EOF' > /etc/mkinitcpio.conf
MODULES=(loop dm-snapshot btrfs sr_mod isofs)
HOOKS=(base udev microcode modconf kms archiso archiso_loop_mnt block filesystems keyboard keymap consolefont)
COMPRESSION="zstd"
EOF
    {{ end }}
    
    # Must match distro_copy_kernel_cmd's kernel selection (uname -r): with
    # both a regular and an -lts kernel installed, picking the alphabetically
    # first /lib/modules entry silently built the initramfs for the wrong one.
    KERNEL_VERSION=$(uname -r)
    
    echo "-> Generating unique live initramfs for kernel $KERNEL_VERSION..."
    mkinitcpio -c /etc/mkinitcpio.conf -k "$KERNEL_VERSION" -g "/boot/oa-initrd.img"
{{ end }}
{{ end }}

# ----------------------------------------------------------------------------
# 6. COPY KERNEL/INITRD (Unified Search Algorithm)
# ----------------------------------------------------------------------------
{{ define "distro_copy_kernel_cmd" }}
#!/bin/bash
set -e

LIVEROOT="/home/eggs/liveroot"
ISODIR="/home/eggs/isodir"
KERNEL_VERSION=$(uname -r)
KVER_MAJOR_MINOR=$(echo "$KERNEL_VERSION" | cut -d. -f1,2)
ARCH=$(uname -m)

echo "-> Copying Kernel and Initramfs for the Arch family ($KERNEL_VERSION)..."

PKGBASE_FILE="$LIVEROOT/lib/modules/$KERNEL_VERSION/pkgbase"
if [ ! -f "$PKGBASE_FILE" ]; then
    echo "[WARNING] pkgbase file missing in $PKGBASE_FILE! Attempting logical fallback."
fi
PKG_NAME=$(cat "$PKGBASE_FILE" 2>/dev/null || echo "linux")

# Unified smart search - ORA SUPPORTA ANCHE ENDEAVOUROS
if [ -f "$LIVEROOT/boot/vmlinuz-$PKG_NAME" ]; then
    KERNEL_SRC="$LIVEROOT/boot/vmlinuz-$PKG_NAME"
elif [ -f "$LIVEROOT/boot/vmlinuz-${KVER_MAJOR_MINOR}-${ARCH}" ]; then
    KERNEL_SRC="$LIVEROOT/boot/vmlinuz-${KVER_MAJOR_MINOR}-${ARCH}"
elif [ -f "$LIVEROOT/usr/lib/modules/$KERNEL_VERSION/vmlinuz" ]; then
    # <<< IL SALVAVITA PER ENDEAVOUROS (e systemd-boot in generale) <<<
    echo "-> Found kernel inside modules directory (systemd-boot layout detected)"
    KERNEL_SRC="$LIVEROOT/usr/lib/modules/$KERNEL_VERSION/vmlinuz"
else
    echo "-> Standard patterns not found, searching for a valid vmlinuz in /boot..."
    KERNEL_SRC=$(find "$LIVEROOT/boot" -maxdepth 1 -name "vmlinuz-*" -type f -print -quit)
fi

if [ -z "$KERNEL_SRC" ] || [ ! -f "$KERNEL_SRC" ]; then
    echo "[FATAL ERROR] Unable to determine the kernel file in $LIVEROOT!"
    exit 1
fi

echo "-> Copying from: $KERNEL_SRC"
cp "$KERNEL_SRC" "$ISODIR/live/vmlinuz"

# L'initrd non è un problema, perché nella sezione 5 dracut lo genera a forza in /boot/oa-initrd.img
if [ ! -f "$LIVEROOT/boot/oa-initrd.img" ]; then
    echo "[FATAL ERROR] oa-initrd.img not found in $LIVEROOT/boot!"
    exit 1
fi

echo "-> Copying oa-initrd.img..."
cp "$LIVEROOT/boot/oa-initrd.img" "$ISODIR/live/initrd.img"

# Cleanup
rm -f "$LIVEROOT/boot/initramfs-oa-initrd.img"
rm -f "$LIVEROOT/boot/oa-initrd.img"
echo "-> Bulletproof copy completed successfully."
{{ end }}

# ----------------------------------------------------------------------------
# 8.1 SQUASHFS STRUCTURE (ISO channels)
# ----------------------------------------------------------------------------
{{ define "distro_hook_squashfs" }}
#!/bin/bash
set -e

echo "-> Preparing filesystem.squashfs hardlink..."
timeout=10
while [ ! -f /home/eggs/isodir/live/filesystem.squashfs ] && [ $timeout -gt 0 ]; do
    sleep 1; timeout=$((timeout-1))
done

if [ ! -f /home/eggs/isodir/live/filesystem.squashfs ]; then
    echo "[FATAL ERROR] filesystem.squashfs not found after timeout!"
    exit 1
fi

{{ if eq .Family "manjaro" }}
    mkdir -p /home/eggs/isodir/manjaro/x86_64
    ln -f /home/eggs/isodir/live/filesystem.squashfs /home/eggs/isodir/manjaro/x86_64/livefs.sfs
    echo "-> livefs.sfs hardlink created for Manjaro."
{{ else }}
    mkdir -p /home/eggs/isodir/arch/x86_64
    ln -f /home/eggs/isodir/live/filesystem.squashfs /home/eggs/isodir/arch/x86_64/airootfs.sfs
    echo "-> airootfs.sfs hardlink created for Arch/Garuda/EndeavourOS."
{{ end }}
{{ end }}

# ==============================================================================
# 🎯 FINAL DISK INSTALLER (Executed in Chroot)
# ==============================================================================
{{ define "install_distro_initramfs" }}
{{ if or (eq .DistroID "garuda") (eq .DistroID "endeavouros") }}
    echo "-> Regenerating initramfs on Garuda/EndeavourOS via dracut..."
    
    KVER_DIR=$(uname -r)
    if [ ! -d "/lib/modules/$KVER_DIR" ]; then
        # Fall back if uname -r doesn't match an installed kernel (e.g. an
        # unrebooted upgrade) - matches whichever kernel is actually present.
        KVER_DIR=$(ls -1 /lib/modules/ | grep -v "extramodules" | head -n 1)
    fi
    if [ -z "$KVER_DIR" ]; then
        echo "[FATAL ERROR] Unable to determine the kernel in the chroot."
        exit 1
    fi

    INITRD_TARGET="/boot/initramfs-$KVER_DIR.img"

    # Clear stale initramfs-*.img so the bootloader steps' unordered
    # `find | head -n1` can't pick a non-btrfs leftover instead of ours.
    find /boot -maxdepth 1 -name "initramfs-*.img" ! -name "*fallback*" ! -name "$(basename "$INITRD_TARGET")" -delete

    # -N (no-hostonly) is vital to generate the image correctly from within the chroot
    # Explicit outfile: Garuda's dracut.conf.d defaults to a BLS path that doesn't exist yet.
    if ! dracut -N -f --add "btrfs" --kver "$KVER_DIR" "$INITRD_TARGET"; then
        echo "[FATAL ERROR] dracut failed to generate $INITRD_TARGET"
        exit 1
    fi
    if [ ! -f "$INITRD_TARGET" ]; then
        echo "[FATAL ERROR] dracut reported success but $INITRD_TARGET is missing"
        exit 1
    fi

{{ else }}
    echo "-> Regenerating mkinitcpio-based initramfs..."
    ROOT_FSTYPE=$(awk '$2 == "/" {print $3}' /etc/fstab)
    if [ "$ROOT_FSTYPE" = "btrfs" ]; then
        if ! grep -q "^HOOKS=.*btrfs" /etc/mkinitcpio.conf; then
            sed -i '/^HOOKS=/ s/\bfilesystems\b/btrfs filesystems/' /etc/mkinitcpio.conf
        fi
    fi
    mkinitcpio -P
{{ end }}
{{ end }}

# ==============================================================================
# 🎯 BOOTLOADER DISPATCHER
# ==============================================================================
{{ define "install_distro_bootloader" }}
echo "-> Automatic detection and bootloader dispatch..."

if [ -d /sys/firmware/efi ]; then
    echo "-> UEFI environment detected."
    if command -v limine &> /dev/null; then
        {{ include "install_distro_limine" . }}
    elif command -v bootctl &> /dev/null; then
        {{ include "install_distro_systemd_boot" . }}
    else
        {{ include "install_distro_grub" . }}
    fi
else
    echo "-> BIOS/Legacy environment detected. Forcing GRUB."
    {{ include "install_distro_grub" . }}
fi
{{ end }}

{{ define "install_distro_grub" }}
echo "-> Installing GRUB..."

if ! command -v grub-install &> /dev/null; then
    echo "-> grub package is missing. Installing it on the fly..."
    pacman -Sy --noconfirm grub || { echo "[WARNING] Failed to install grub"; }
fi

if [ -d /sys/firmware/efi ] && grep -q "/boot/efi" /proc/mounts; then
    echo "-> UEFI installation..."
    if ! grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id={{ .DistroID }} --recheck; then
        # NVRAM-registration can fail (e.g. OVMF/VM firmware) even though the
        # EFI binary was written correctly; only abort if it genuinely wasn't.
        [ -f "/boot/efi/EFI/{{ .DistroID }}/grubx64.efi" ] || { echo "[FATAL ERROR] grub-install failed and no EFI binary was written"; exit 1; }
        echo "-> WARNING: grub-install failed (likely NVRAM-only); EFI binary is present, continuing with removable fallback."
    fi

    mkdir -p /boot/efi/EFI/BOOT
    [ -f "/boot/efi/EFI/{{ .DistroID }}/grubx64.efi" ] && cp -f "/boot/efi/EFI/{{ .DistroID }}/grubx64.efi" /boot/efi/EFI/BOOT/BOOTX64.EFI
else
    echo "-> BIOS/Legacy installation..."
    ROOT_PART_FSTAB=$(awk '$2 == "/" {print $1}' /etc/fstab)
    if [[ "$ROOT_PART_FSTAB" == UUID=* ]] || [[ "$ROOT_PART_FSTAB" == LABEL=* ]]; then
        ROOT_DEV=$(findfs "$ROOT_PART_FSTAB" 2>/dev/null || echo "/dev/sda1")
    else
        ROOT_DEV=${ROOT_PART_FSTAB:-"/dev/sda1"}
    fi
    
    if [[ "$ROOT_DEV" == *nvme* ]] || [[ "$ROOT_DEV" == *mmcblk* ]] || [[ "$ROOT_DEV" == *loop* ]]; then
        TARGET_DISK=$(echo "$ROOT_DEV" | sed -E 's/p[0-9]+$//')
    else
        TARGET_DISK=$(echo "$ROOT_DEV" | sed -E 's/[0-9]+$//')
    fi
    [ -z "$TARGET_DISK" ] && TARGET_DISK="/dev/sda"
    
    echo "-> Target disk: $TARGET_DISK"
    grub-install --target=i386-pc --recheck "$TARGET_DISK"
fi

ROOT_FSTYPE=$(awk '$2 == "/" {print $3}' /etc/fstab)
if [ "$ROOT_FSTYPE" = "btrfs" ]; then
    echo "-> Btrfs configuration detected. Creating /boot symlink at the root level..."
    ROOT_PART_FSTAB=$(awk '$2 == "/" {print $1}' /etc/fstab)
    if [[ "$ROOT_PART_FSTAB" == UUID=* ]] || [[ "$ROOT_PART_FSTAB" == LABEL=* ]]; then
        ROOT_DEV=$(findfs "$ROOT_PART_FSTAB")
    else
        ROOT_DEV=$ROOT_PART_FSTAB
    fi
    mkdir -p /tmp/btrfs-raw
    mount "$ROOT_DEV" /tmp/btrfs-raw
    ln -sf @/boot /tmp/btrfs-raw/boot
    umount /tmp/btrfs-raw
    rmdir /tmp/btrfs-raw
fi

# =====================================================================
# FIX PER GRUB SU ENDEAVOUROS / SYSTEMD-BOOT LAYOUT
# Controlliamo se c'è un kernel in /boot. Se manca, lo peschiamo dai moduli.
# =====================================================================
if ! ls /boot/vmlinuz-* 1> /dev/null 2>&1; then
    echo "-> Nessun kernel trovato in /boot. Cerco nei moduli (layout systemd-boot)..."
    KERNEL_PATH="/usr/lib/modules/$(uname -r)/vmlinuz"
    [ -f "$KERNEL_PATH" ] || KERNEL_PATH=$(find /usr/lib/modules -name "vmlinuz" -type f | head -n 1)

    if [ -n "$KERNEL_PATH" ]; then
        # Recupera il nome della versione (es. 6.1.12-arch1-1)
        KVER=$(basename $(dirname "$KERNEL_PATH"))
        echo "-> Copio il kernel in /boot/vmlinuz-$KVER per GRUB..."
        cp "$KERNEL_PATH" "/boot/vmlinuz-$KVER"
    else
        echo "[WARNING] Nessun kernel trovato da copiare in /boot per GRUB. La configurazione potrebbe fallire."
    fi
fi

# Ora GRUB troverà sicuramente il kernel in /boot!
grub-mkconfig -o /boot/grub/grub.cfg
{{ end }}

{{ define "install_distro_systemd_boot" }}
echo "-> Installing systemd-boot (bootctl)..."
bootctl install --esp-path=/boot/efi
mkdir -p /boot/efi/loader/entries

# Ricerca intelligente del kernel (supporto per layout classico e systemd-boot),
# preferendo la versione realmente in esecuzione se più kernel sono installati.
KERNEL_PATH="/usr/lib/modules/$(uname -r)/vmlinuz"
if [ ! -f "$KERNEL_PATH" ]; then
    KERNEL_PATH=$(find /boot -maxdepth 1 -name "vmlinuz-*" -type f | head -n 1)
fi
if [ ! -f "$KERNEL_PATH" ]; then
    KERNEL_PATH=$(find /usr/lib/modules -name "vmlinuz" -type f | head -n 1)
fi

# L'initrd generato poco prima da dracut o mkinitcpio sarà in /boot
INITRD_PATH=$(find /boot -maxdepth 1 -name "initramfs-*.img" ! -name "*fallback*" -type f | head -n 1)

if [ -z "$KERNEL_PATH" ] || [ -z "$INITRD_PATH" ]; then
    echo "[FATAL ERROR] Unable to determine the installed kernel or initrd in the chroot."
    exit 1
fi

KERNEL_FILE=$(basename "$KERNEL_PATH")
INITRD_FILE=$(basename "$INITRD_PATH")

cp "$KERNEL_PATH" "/boot/efi/$KERNEL_FILE"
cp "$INITRD_PATH" "/boot/efi/$INITRD_FILE"

UCODE_LINE=""
if [ -f /boot/amd-ucode.img ]; then
    cp /boot/amd-ucode.img /boot/efi/
    UCODE_LINE="initrd  /amd-ucode.img"
elif [ -f /boot/intel-ucode.img ]; then
    cp /boot/intel-ucode.img /boot/efi/
    UCODE_LINE="initrd  /intel-ucode.img"
fi

ROOT_PART=$(grep " / " /etc/fstab | grep -v "^#" | awk '{print $1}')
ROOT_FSTYPE=$(awk '$2 == "/" {print $3}' /etc/fstab)
ROOTFLAGS=""
if [ "$ROOT_FSTYPE" = "btrfs" ]; then
    ROOTFLAGS="rootflags=subvol=@"
fi

PRETTY_NAME=$(grep ^PRETTY_NAME= /etc/os-release | cut -d= -f2 | tr -d '"')
if [ -z "$PRETTY_NAME" ]; then
    PRETTY_NAME="Arch Linux"
fi

cat <<EOF > /boot/efi/loader/entries/oa-linux.conf
title   $PRETTY_NAME
linux   /$KERNEL_FILE
${UCODE_LINE}
initrd  /$INITRD_FILE
options root=$ROOT_PART rw $ROOTFLAGS
EOF

cat <<EOF > /boot/efi/loader/loader.conf
default oa-linux.conf
timeout 5
console-mode max
editor yes
EOF
{{ end }}

{{ define "install_distro_limine" }}
echo "-> Installing Limine bootloader (UEFI)..."

# Ricerca intelligente del kernel, preferendo la versione realmente in esecuzione.
KERNEL_PATH="/usr/lib/modules/$(uname -r)/vmlinuz"
if [ ! -f "$KERNEL_PATH" ]; then
    KERNEL_PATH=$(find /boot -maxdepth 1 -name "vmlinuz-*" -type f | head -n 1)
fi
if [ ! -f "$KERNEL_PATH" ]; then
    KERNEL_PATH=$(find /usr/lib/modules -name "vmlinuz" -type f | head -n 1)
fi

INITRD_PATH=$(find /boot -maxdepth 1 -name "initramfs-*.img" ! -name "*fallback*" -type f | head -n 1)

if [ -z "$KERNEL_PATH" ] || [ -z "$INITRD_PATH" ]; then
    echo "[FATAL ERROR] Unable to determine the kernel or initrd for Limine."
    exit 1
fi

KERNEL_FILE=$(basename "$KERNEL_PATH")
INITRD_FILE=$(basename "$INITRD_PATH")

ROOT_PART=$(grep " / " /etc/fstab | grep -v "^#" | awk '{print $1}')
ROOT_FSTYPE=$(awk '$2 == "/" {print $3}' /etc/fstab)
ROOTFLAGS=""
if [ "$ROOT_FSTYPE" = "btrfs" ]; then
    ROOTFLAGS="rootflags=subvol=@"
fi

mkdir -p /boot/efi/EFI/BOOT
cp /usr/share/limine/BOOTX64.EFI /boot/efi/EFI/BOOT/

# Limine ha bisogno che il kernel sia accessibile, se usiamo /boot/efi come ESP,
# dovremmo copiare i file lì, oppure assicurarci che la partizione /boot sia letta.
# Assumiamo che i percorsi boot:// puntino alla partizione corretta, ma per 
# consistenza e sicurezza con EndeavourOS usiamo i path completi che abbiamo trovato:
PRETTY_NAME=$(grep ^PRETTY_NAME= /etc/os-release | cut -d= -f2 | tr -d '"')
if [ -z "$PRETTY_NAME" ]; then
    PRETTY_NAME="Arch Linux"
fi

cat <<EOF > /boot/efi/limine.conf
timeout: 5
/$PRETTY_NAME
    protocol: linux
    kernel_path: boot://${KERNEL_PATH#/boot/}
    initramfs_path: boot://${INITRD_PATH#/boot/}
    cmdline: root=$ROOT_PART rw $ROOTFLAGS
EOF
{{ end }}
