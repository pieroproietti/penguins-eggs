# Include: Arch Linux, Manjaro, Garuda e derivate (EndeavourOS, ecc.)
# ==============================================================================

# ----------------------------------------------------------------------------
# CONSTANTI DICHIARATIVE (Parametri di Boot della Live)
# ----------------------------------------------------------------------------
{{ define "distro_boot_params" }}
{{- if eq .DistroID "garuda" -}}
root=live:CDLABEL=OA_LIVE rd.live.image rd.live.dir=arch/x86_64 rd.live.squashimg=airootfs.sfs rd.live.overlay.size=2048 quiet
{{- else if eq .DistroID "manjaro" -}}
misobasedir=manjaro misolabel=OA_LIVE cow_spacesize=2G
{{- else -}}
archisobasedir=arch archisolabel=OA_LIVE cow_spacesize=2G
{{- end -}}
{{ end }}

# ----------------------------------------------------------------------------
# 5. INITRAMFS LIVE
# ----------------------------------------------------------------------------
{{ define "distro_initramfs_cmd" }}
#!/bin/bash
set -e

echo "-> Preparazione configurazione Initramfs per Live (Famiglia Arch)..."

{{ if eq .DistroID "garuda" }}
    # ==========================================
    # RAMO GARUDA (Dracut)
    # ==========================================
    echo "-> Rilevato Garuda Linux: Generazione Live via dracut"
    
    # Siamo già in chroot, quindi dracut lavora direttamente su /boot
    # Aggiungiamo -N per disabilitare la modalità host-only (fondamentale per le live)
    dracut -N -f --add "dmsquash-live" "/boot/oa-initrd.img"

{{ else }}
    # ==========================================
    # RAMO ARCH / MANJARO (mkinitcpio)
    # ==========================================
    cp /etc/mkinitcpio.conf /etc/mkinitcpio.conf.bak
    mkdir -p /etc/mkinitcpio.conf.d.bak /usr/lib/mkinitcpio.conf.d.bak
    [ "$(ls -A /etc/mkinitcpio.conf.d/ 2>/dev/null)" ] && mv /etc/mkinitcpio.conf.d/*.conf /etc/mkinitcpio.conf.d.bak/
    [ "$(ls -A /usr/lib/mkinitcpio.conf.d/ 2>/dev/null)" ] && mv /usr/lib/mkinitcpio.conf.d/*.conf /usr/lib/mkinitcpio.conf.d.bak/

    trap '
    mv /etc/mkinitcpio.conf.bak /etc/mkinitcpio.conf
    [ "$(ls -A /etc/mkinitcpio.conf.d.bak/ 2>/dev/null)" ] && mv /etc/mkinitcpio.conf.d.bak/*.conf /etc/mkinitcpio.conf.d/
    [ "$(ls -A /usr/lib/mkinitcpio.conf.d.bak/ 2>/dev/null)" ] && mv /usr/lib/mkinitcpio.conf.d.bak/*.conf /usr/lib/mkinitcpio.conf.d/
    rm -rf /etc/mkinitcpio.conf.d.bak /usr/lib/mkinitcpio.conf.d.bak
    ' EXIT

    {{ if eq .DistroID "manjaro" }}
        if ! pacman -Qs manjaro-tools-iso > /dev/null; then 
            echo "[ERRORE FATALE] manjaro-tools-iso non installato."
            exit 1
        fi
        cat << 'EOF' > /etc/mkinitcpio.conf
MODULES=(loop dm-snapshot btrfs)
HOOKS=(base udev microcode modconf kms miso miso_loop_mnt miso_pxe_common miso_pxe_nbd miso_pxe_http miso_pxe_nfs block keyboard keymap consolefont filesystems fsck)
COMPRESSION="zstd"
EOF
    {{ else }}
        if ! pacman -Qs archiso > /dev/null; then 
            echo "[ERRORE FATALE] archiso non installato."
            exit 1
        fi
        cat << 'EOF' > /etc/mkinitcpio.conf
MODULES=(loop dm-snapshot btrfs)
HOOKS=(base udev microcode modconf kms archiso archiso_loop_mnt archiso_pxe_common archiso_pxe_nbd archiso_pxe_http archiso_pxe_nfs block filesystems keyboard keymap consolefont fsck)
COMPRESSION="zstd"      
EOF
    {{ end }}
    
    KERNEL_VERSION=$(uname -r)
    echo "-> Generazione initramfs live univoco..."
    mkinitcpio -c /etc/mkinitcpio.conf -k "$KERNEL_VERSION" -g "/boot/oa-initrd.img"
{{ end }}
{{ end }}


# ----------------------------------------------------------------------------
# 6. COPIA KERNEL/INITRD (Algoritmo di Ricerca Unificato)
# ----------------------------------------------------------------------------
{{ define "distro_copy_kernel_cmd" }}
#!/bin/bash
set -e

LIVEROOT="/home/eggs/liveroot"
ISODIR="/home/eggs/isodir"
KERNEL_VERSION=$(uname -r)
KVER_MAJOR_MINOR=$(echo "$KERNEL_VERSION" | cut -d. -f1,2)
ARCH=$(uname -m)

echo "-> Copia Kernel e Initramfs per la famiglia Arch ($KERNEL_VERSION)..."

PKGBASE_FILE="$LIVEROOT/lib/modules/$KERNEL_VERSION/pkgbase"
if [ ! -f "$PKGBASE_FILE" ]; then
    echo "[AVVISO] File pkgbase mancante in $PKGBASE_FILE! Tento fallback logico."
fi
PKG_NAME=$(cat "$PKGBASE_FILE" 2>/dev/null || echo "linux")

# Ricerca intelligente unificata
if [ -f "$LIVEROOT/boot/vmlinuz-$PKG_NAME" ]; then
    KERNEL_SRC="$LIVEROOT/boot/vmlinuz-$PKG_NAME"
elif [ -f "$LIVEROOT/boot/vmlinuz-${KVER_MAJOR_MINOR}-${ARCH}" ]; then
    KERNEL_SRC="$LIVEROOT/boot/vmlinuz-${KVER_MAJOR_MINOR}-${ARCH}"
else
    echo "-> Pattern standard non trovati, cerco un vmlinuz valido in /boot..."
    KERNEL_SRC=$(find "$LIVEROOT/boot" -maxdepth 1 -name "vmlinuz-*" -type f -print -quit)
fi

if [ -z "$KERNEL_SRC" ] || [ ! -f "$KERNEL_SRC" ]; then
    echo "[ERRORE FATALE] Impossibile determinare il file del kernel in $LIVEROOT/boot!"
    exit 1
fi

echo "-> Copia da: $KERNEL_SRC"
cp "$KERNEL_SRC" "$ISODIR/live/vmlinuz"

if [ ! -f "$LIVEROOT/boot/oa-initrd.img" ]; then
    echo "[ERRORE FATALE] oa-initrd.img non trovato in $LIVEROOT/boot!"
    exit 1
fi

echo "-> Copia oa-initrd.img..."
cp "$LIVEROOT/boot/oa-initrd.img" "$ISODIR/live/initrd.img"

# Pulizia
rm -f "$LIVEROOT/boot/initramfs-oa-initrd.img"
rm -f "$LIVEROOT/boot/oa-initrd.img"
echo "-> Copia blindata completata con successo."
{{ end }}

# ----------------------------------------------------------------------------
# 8.1 STRUTTURA SQUASHFS (I canali della ISO)
# ----------------------------------------------------------------------------
{{ define "distro_hook_squashfs" }}
#!/bin/bash
set -e

echo "-> Preparazione hardlink filesystem.squashfs..."
timeout=10
while [ ! -f /home/eggs/isodir/live/filesystem.squashfs ] && [ $timeout -gt 0 ]; do
    sleep 1; timeout=$((timeout-1))
done

if [ ! -f /home/eggs/isodir/live/filesystem.squashfs ]; then
    echo "[ERRORE FATALE] filesystem.squashfs non trovato dopo il timeout!"
    exit 1
fi

{{ if eq .DistroID "manjaro" }}
    mkdir -p /home/eggs/isodir/manjaro/x86_64
    ln -f /home/eggs/isodir/live/filesystem.squashfs /home/eggs/isodir/manjaro/x86_64/livefs.sfs
    echo "-> Hardlink livefs.sfs creato per Manjaro."
{{ else }}
    mkdir -p /home/eggs/isodir/arch/x86_64
    ln -f /home/eggs/isodir/live/filesystem.squashfs /home/eggs/isodir/arch/x86_64/airootfs.sfs
    echo "-> Hardlink airootfs.sfs creato per Arch/Garuda."
{{ end }}
{{ end }}

# ==============================================================================
# 🎯 INSTALLATORE SUL DISCO FINALE (Eseguito in Chroot)
# ==============================================================================
{{ define "install_distro_initramfs" }}
{{ if eq .DistroID "garuda" }}
    echo "-> Rigenerazione initramfs su Garuda tramite dracut..."
    
    KVER_DIR=$(ls -1 /lib/modules/ | grep -v "extramodules" | head -n 1)
    if [ -z "$KVER_DIR" ]; then
        echo "[ERRORE FATALE] Impossibile determinare il kernel nel chroot."
        exit 1
    fi
    
    # -N (no-hostonly) vitale per generare l'immagine correttamente da dentro il chroot
    dracut -N -f --add "btrfs" --kver "$KVER_DIR"
    
{{ else }}
    echo "-> Rigenerazione initramfs su base mkinitcpio..."
    ROOT_FSTYPE=$(findmnt -n -o FSTYPE /)
    if [ "$ROOT_FSTYPE" = "btrfs" ]; then
        if ! grep -q "^HOOKS=.*btrfs" /etc/mkinitcpio.conf; then
            sed -i '/^HOOKS=/ s/\bfilesystems\b/btrfs filesystems/' /etc/mkinitcpio.conf
        fi
    fi
    mkinitcpio -P
{{ end }}
{{ end }}

# ==============================================================================
# 🎯 DISPATCHER BOOTLOADER
# ==============================================================================
{{ define "install_distro_bootloader" }}
echo "-> Rilevamento automatico e dispatch del bootloader..."

{{ if or (eq .DistroID "garuda") (eq .DistroID "manjaro") }}
    echo "-> Rilevato {{ .DistroID }}: Forzo l'installazione di GRUB per mantenere le funzionalità native"
    {{ include "install_distro_grub" . }}
{{ else }}
    # Per Arch puro o altre derivate
    if [ -d /sys/firmware/efi ] && command -v bootctl &> /dev/null; then
        {{ include "install_distro_systemd_boot" . }}
    elif command -v limine &> /dev/null; then
        {{ include "install_distro_limine" . }}
    else
        {{ include "install_distro_grub" . }}
    fi
{{ end }}
{{ end }}

{{ define "install_distro_grub" }}
echo "-> Installazione di GRUB..."

# Controllo assoluto e inconfutabile: chiediamo al kernel se la partizione è montata
if grep -q "/boot/efi" /proc/mounts; then
    echo "-> Partizione EFI montata. Procedo con installazione UEFI (con flag --removable per macchine virtuali)..."
    
    # IL FLAG --removable È LA CHIAVE: forza la creazione di EFI/BOOT/BOOTX64.EFI
    grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id={{ .DistroID }} --recheck --removable
else
    echo "-> Partizione EFI non rilevata. Tento installazione BIOS/Legacy..."
    TARGET_DISK=$(grub-probe -t disk / 2>/dev/null || echo "/dev/sda")
    grub-install --target=i386-pc --recheck "$TARGET_DISK"
fi

grub-mkconfig -o /boot/grub/grub.cfg
{{ end }}

{{ define "install_distro_systemd_boot" }}
echo "-> Installazione di systemd-boot (bootctl)..."
bootctl install --esp-path=/boot/efi
mkdir -p /boot/efi/loader/entries

# Rilevamento blindato del kernel senza dipendere da pkgbase
KERNEL_FILE=$(find /boot -maxdepth 1 -name "vmlinuz-*" -type f -exec basename {} \; | head -n 1)
INITRD_FILE=$(find /boot -maxdepth 1 -name "initramfs-*.img" ! -name "*fallback*" -type f -exec basename {} \; | head -n 1)

if [ -z "$KERNEL_FILE" ] || [ -z "$INITRD_FILE" ]; then
    echo "[ERRORE FATALE] Impossibile determinare il kernel installato nel chroot."
    exit 1
fi

cp "/boot/$KERNEL_FILE" /boot/efi/
cp "/boot/$INITRD_FILE" /boot/efi/

UCODE_LINE=""
if [ -f /boot/amd-ucode.img ]; then
    cp /boot/amd-ucode.img /boot/efi/
    UCODE_LINE="initrd  /amd-ucode.img"
elif [ -f /boot/intel-ucode.img ]; then
    cp /boot/intel-ucode.img /boot/efi/
    UCODE_LINE="initrd  /intel-ucode.img"
fi

ROOT_PART=$(grep " / " /etc/fstab | grep -v "^#" | awk '{print $1}')
ROOT_FSTYPE=$(findmnt -n -o FSTYPE /)
ROOTFLAGS=""
if [ "$ROOT_FSTYPE" = "btrfs" ]; then
    ROOTFLAGS="rootflags=subvol=@"
fi

cat <<EOF > /boot/efi/loader/entries/oa-linux.conf
title   OA Linux
linux   /$KERNEL_FILE$UCODE_LINE
initrd  /$INITRD_FILE
options root=$ROOT_PART rw$ROOTFLAGS
EOF

cat <<EOF > /boot/efi/loader/loader.conf
default oa-linux.conf
timeout 5
console-mode max
editor yes
EOF
{{ end }}

{{ define "install_distro_limine" }}
echo "-> Installazione di Limine bootloader..."

# Rilevamento blindato del kernel condiviso con systemd-boot
KERNEL_FILE=$(find /boot -maxdepth 1 -name "vmlinuz-*" -type f -exec basename {} \; | head -n 1)
INITRD_FILE=$(find /boot -maxdepth 1 -name "initramfs-*.img" ! -name "*fallback*" -type f -exec basename {} \; | head -n 1)

if [ -z "$KERNEL_FILE" ] || [ -z "$INITRD_FILE" ]; then
    echo "[ERRORE FATALE] Impossibile determinare il kernel per Limine."
    exit 1
fi

ROOT_PART=$(grep " / " /etc/fstab | grep -v "^#" | awk '{print $1}')
ROOT_FSTYPE=$(findmnt -n -o FSTYPE /)
ROOTFLAGS=""
if [ "$ROOT_FSTYPE" = "btrfs" ]; then
    ROOTFLAGS="rootflags=subvol=@"
fi

if [ -d /sys/firmware/efi ]; then
    # UEFI
    mkdir -p /boot/efi/EFI/BOOT
    cp /usr/share/limine/BOOTX64.EFI /boot/efi/EFI/BOOT/
    
    cat <<EOF > /boot/efi/limine.conf
timeout: 5
/OA Linux
    protocol: linux
    kernel_path: boot://$KERNEL_FILE
    initramfs_path: boot://$INITRD_FILE
    cmdline: root=$ROOT_PART rw$ROOTFLAGS
EOF
else
    # BIOS/Legacy
    TARGET_DISK=$(grub-probe -t disk / 2>/dev/null || echo "/dev/sda")
    limine bios-install "$TARGET_DISK"
    
    cat <<EOF > /boot/limine.conf
timeout: 5
/OA Linux
    protocol: linux
    kernel_path: boot://$KERNEL_FILE
    initramfs_path: boot://$INITRD_FILE
    cmdline: root=$ROOT_PART rw$ROOTFLAGS
EOF
fi
{{ end }}
