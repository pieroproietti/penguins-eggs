# ==============================================================================
# 🦎 MODULO OPENSUSE SLOWROLL
# ==============================================================================

# ----------------------------------------------------------------------------
# DECLARATIVE COSTANTS 
# ----------------------------------------------------------------------------
{{ define "distro_boot_params" }}root=live:LABEL=OA_LIVE rd.live.image rd.shell rd.debug selinux=0 cow_spacesize=2G{{ end }}

# ----------------------------------------------------------------------------
# 5. INITRAMFS LIVE (Cambia il nome dell'immagine finale)
# ----------------------------------------------------------------------------
{{ define "distro_initramfs_cmd" }}
#!/bin/bash
set -e
# opensuse: distro_initramfs_cmd
echo "Generazione initramfs live (dracut)..."
# ATTENZIONE: Aggiunti i driver per i controller fisici e virtuali (AHCI, VirtIO, IDE)
dracut -f --no-hostonly --add "dmsquash-live livenet" --add-drivers "sr_mod iso9660 squashfs loop overlay ahci virtio_blk virtio_pci virtio_scsi cdrom ata_piix sd_mod" /boot/oa-initrd.img
{{ end }}

# ----------------------------------------------------------------------------
# 6. COPY KERNEL/INITRD
# ----------------------------------------------------------------------------
{{ define "distro_copy_kernel_cmd" }}
#!/bin/bash
set -e
# opensuse: distro_copy_kernel_cmd

KERNEL_VERSION=$(uname -r)
echo "-> Copia Kernel openSUSE ($KERNEL_VERSION)..."

# Usiamo i percorsi assoluti e sicuri, leggendo e scrivendo dove serve davvero
KERNEL_SRC="/home/eggs/liveroot/boot/vmlinuz-$KERNEL_VERSION"
INITRD_SRC="/home/eggs/liveroot/boot/oa-initrd.img"
DEST_DIR="/home/eggs/isodir/live"

# Controllo di sicurezza sul KERNEL
if [ ! -f "$KERNEL_SRC" ] ; then
    echo "[ERRORE FATALE] Impossibile trovare il kernel in $KERNEL_SRC!"
    exit 1
fi

# Controllo di sicurezza sull'INITRD
if [ ! -f "$INITRD_SRC" ] ; then
    echo "[ERRORE FATALE] Impossibile trovare l'initrd in $INITRD_SRC! Dracut non lo ha generato."
    exit 1
fi

# Creiamo la directory di destinazione (se non esiste) e copiamo
mkdir -p "$DEST_DIR"

cp "$KERNEL_SRC" "$DEST_DIR/vmlinuz"
echo "-> Copia oa-initrd.img..."
cp "$INITRD_SRC" "$DEST_DIR/initrd.img"

echo "-> Copia completata con successo."
{{ end }}

# ----------------------------------------------------------------------------
# 8.1 HARDLINK TO isodir/live/filesystem.squashfs in arch, fedora, manjaro
# ----------------------------------------------------------------------------
{{ define "distro_hook_squashfs" }}
#!/bin/bash
set -e
# opensuse: distro_hook_squashfs
mkdir -p /home/eggs/isodir/LiveOS
ln -f /home/eggs/isodir/live/filesystem.squashfs /home/eggs/isodir/LiveOS/squashfs.img
{{ end }}

# ==============================================================================
# 🎯 INSTALLER
# ==============================================================================
{{ define "install_distro_initramfs" }}
dracut -f --regenerate-all
{{ end }}

{{ define "install_distro_bootloader" }}
# Disabilita SELinux per evitare errori di permessi all'avvio (Permission denied su bash/sh)
if [ -f /etc/selinux/config ]; then
      sed -i 's/^SELINUX=.*/SELINUX=disabled/g' /etc/selinux/config
fi

if [ -f /etc/default/grub ]; then
      if ! grep -q "selinux=0" /etc/default/grub; then
            sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT="/GRUB_CMDLINE_LINUX_DEFAULT="selinux=0 /g' /etc/default/grub
      fi
fi

# Rilevamento automatico e dispatch del bootloader
if command -v limine &> /dev/null; then
    {{ include "install_distro_limine" . }}
else
    {{ include "install_distro_grub" . }}
fi
{{ end }}

{{ define "install_distro_grub" }}
# Rileva Btrfs e crea il symlink di boot al livello root del filesystem
if [ "$(findmnt -n -o FSTYPE /)" = "btrfs" ]; then
      echo "-> Configurazione Btrfs rilevata. Creazione del symlink /boot al livello root..."
      ROOT_DEV=$(findmnt -n -o SOURCE /)
      mkdir -p /tmp/btrfs-raw
      mount "$ROOT_DEV" /tmp/btrfs-raw
      ln -sf @/boot /tmp/btrfs-raw/boot
      umount /tmp/btrfs-raw
      rmdir /tmp/btrfs-raw
fi

if [ -d /sys/firmware/efi ]; then
      grub2-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=opensuse --recheck --force
      
      # Fallback UEFI Absolute (Garantisce l'avvio anche se la NVRAM fa i capricci)
      mkdir -p /boot/efi/EFI/BOOT
      if [ -f /boot/efi/EFI/opensuse/shim.efi ]; then
          cp /boot/efi/EFI/opensuse/shim.efi /boot/efi/EFI/BOOT/BOOTX64.EFI
          if [ -f /boot/efi/EFI/opensuse/grubx64.efi ]; then
              cp /boot/efi/EFI/opensuse/grubx64.efi /boot/efi/EFI/BOOT/grubx64.efi
          elif [ -f /boot/efi/EFI/opensuse/grub.efi ]; then
              cp /boot/efi/EFI/opensuse/grub.efi /boot/efi/EFI/BOOT/grubx64.efi
          fi
      else
          if [ -f /boot/efi/EFI/opensuse/grubx64.efi ]; then
              cp /boot/efi/EFI/opensuse/grubx64.efi /boot/efi/EFI/BOOT/BOOTX64.EFI
          elif [ -f /boot/efi/EFI/opensuse/grub.efi ]; then
              cp /boot/efi/EFI/opensuse/grub.efi /boot/efi/EFI/BOOT/BOOTX64.EFI
          fi
      fi

      grub2-mkconfig -o /boot/grub2/grub.cfg
      mkdir -p /boot/efi/EFI/opensuse
      grub2-mkconfig -o /boot/efi/EFI/opensuse/grub.cfg
else
      TARGET_DISK=$(grub2-probe -t disk / 2>/dev/null || echo "/dev/sda")
      grub2-install --target=i386-pc --recheck "$TARGET_DISK"
      grub2-mkconfig -o /boot/grub2/grub.cfg
fi
{{ end }}

{{ define "install_distro_systemd_boot" }}
echo "-> Installazione di systemd-boot (bootctl) su openSUSE..."
bootctl install --esp-path=/boot/efi

mkdir -p /boot/efi/loader/entries

KERNEL_FILE=$(ls -1 /boot/vmlinuz-* 2>/dev/null | grep -v rescue | head -n 1 | xargs basename)
INITRD_FILE=$(ls -1 /boot/initramfs-* /boot/initrd-* 2>/dev/null | grep -v rescue | grep -v oa-initrd | head -n 1 | xargs basename)

cp -L /boot/$KERNEL_FILE /boot/efi/
cp -L /boot/$INITRD_FILE /boot/efi/

ROOT_PART=$(grep " / " /etc/fstab | grep -v "^#" | awk '{print $1}')
ROOT_FSTYPE=$(awk '$2 == "/" {print $3}' /etc/fstab)
ROOTFLAGS=""
if [ "$ROOT_FSTYPE" = "btrfs" ]; then
    ROOTFLAGS="rootflags=subvol=@"
fi

PRETTY_NAME=$(grep ^PRETTY_NAME= /etc/os-release | cut -d= -f2 | tr -d '"')
if [ -z "$PRETTY_NAME" ]; then
    PRETTY_NAME="openSUSE"
fi

cat <<EOF > /boot/efi/loader/entries/oa-linux.conf
title   $PRETTY_NAME
linux   /$KERNEL_FILE
initrd  /$INITRD_FILE
options root=$ROOT_PART rw $ROOTFLAGS
EOF

cat <<EOF > /boot/efi/loader/loader.conf
default oa-linux.conf
timeout 5
console-mode max
editor yes
EOF
{{ end }}

{{ define "install_distro_limine" }}
echo "-> Installazione di Limine bootloader su openSUSE..."
if [ -d /sys/firmware/efi ]; then
    # UEFI
    mkdir -p /boot/efi/EFI/BOOT
    cp /usr/share/limine/BOOTX64.EFI /boot/efi/EFI/BOOT/
    
    KERNEL_PATH=$(ls -1 /boot/vmlinuz-* 2>/dev/null | grep -v rescue | head -n 1)
    INITRD_PATH=$(ls -1 /boot/initramfs-* /boot/initrd-* 2>/dev/null | grep -v rescue | grep -v oa-initrd | head -n 1)
    KERNEL_FILE=$(basename "$KERNEL_PATH")
    INITRD_FILE=$(basename "$INITRD_PATH")

    cp "$KERNEL_PATH" "/boot/efi/$KERNEL_FILE" 2>/dev/null || true
    cp "$INITRD_PATH" "/boot/efi/$INITRD_FILE" 2>/dev/null || true

    ROOT_PART=$(grep " / " /etc/fstab | grep -v "^#" | awk '{print $1}')
    ROOT_FSTYPE=$(awk '$2 == "/" {print $3}' /etc/fstab)
    ROOTFLAGS=""
    if [ "$ROOT_FSTYPE" = "btrfs" ]; then
        ROOTFLAGS="rootflags=subvol=@"
    fi
    
    PRETTY_NAME=$(grep ^PRETTY_NAME= /etc/os-release | cut -d= -f2 | tr -d '"')
    if [ -z "$PRETTY_NAME" ]; then
        PRETTY_NAME="openSUSE"
    fi

    cat <<EOF > /boot/efi/limine.conf
timeout: 5

/: $PRETTY_NAME
    protocol: linux
    kernel_path: boot:///$KERNEL_FILE
    module_path: boot:///$INITRD_FILE
    cmdline: root=$ROOT_PART rw $ROOTFLAGS
EOF
    cp /boot/efi/limine.conf /boot/efi/EFI/BOOT/limine.conf
else
    # BIOS/Legacy
    TARGET_DISK=$(grub2-probe -t disk / 2>/dev/null || echo "/dev/sda")
    limine bios-install "$TARGET_DISK"
    
    KERNEL_PATH=$(ls -1 /boot/vmlinuz-* 2>/dev/null | grep -v rescue | head -n 1)
    INITRD_PATH=$(ls -1 /boot/initramfs-* /boot/initrd-* 2>/dev/null | grep -v rescue | grep -v oa-initrd | head -n 1)
    KERNEL_FILE=$(basename "$KERNEL_PATH")
    INITRD_FILE=$(basename "$INITRD_PATH")

    ROOT_PART=$(grep " / " /etc/fstab | grep -v "^#" | awk '{print $1}')
    ROOT_FSTYPE=$(awk '$2 == "/" {print $3}' /etc/fstab)
    ROOTFLAGS=""
    if [ "$ROOT_FSTYPE" = "btrfs" ]; then
        ROOTFLAGS="rootflags=subvol=@"
    fi
    
    PRETTY_NAME=$(grep ^PRETTY_NAME= /etc/os-release | cut -d= -f2 | tr -d '"')
    if [ -z "$PRETTY_NAME" ]; then
        PRETTY_NAME="openSUSE"
    fi

    cat <<EOF > /boot/limine.conf
timeout: 5

/: $PRETTY_NAME
    protocol: linux
    kernel_path: boot:///$KERNEL_FILE
    module_path: boot:///$INITRD_FILE
    cmdline: root=$ROOT_PART rw $ROOTFLAGS
EOF
fi
{{ end }}

