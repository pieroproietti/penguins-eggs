# ==============================================================================
# 🦎 MODULO OPENSUSE SLOWROLL
# ==============================================================================

# ----------------------------------------------------------------------------
# DECLARATIVE COSTANTS 
# ----------------------------------------------------------------------------
{{ define "distro_boot_params" }}root=live:LABEL=${VOL_ID} rd.live.image rd.shell rd.debug selinux=0 cow_spacesize=2G{{ end }}

# ----------------------------------------------------------------------------
# 5. INITRAMFS LIVE (Cambia il nome dell'immagine finale)
# ----------------------------------------------------------------------------
{{ define "distro_initramfs_cmd" }}
#!/bin/bash
set -e
# opensuse: distro_initramfs_cmd
echo "Generazione initramfs live (dracut)..."
dracut -f --no-hostonly --add "dmsquash-live livenet" --add-drivers "sr_mod iso9660 squashfs loop overlay" /boot/oa-initrd.img 2>&1 | tail -1
{{ end }}

# ----------------------------------------------------------------------------
# 6. COPY KERNEL/INITRD
# ----------------------------------------------------------------------------
{{ define "distro_copy_kernel_cmd" }}
#!/bin/bash
set -e
# opensuse: distro_copy_kernel_cmd

KERNEL_VERSION=$(uname -r)
echo "-> Copia Kernel openSUSE ($KERNEL_VERSION)..."

KERNEL_SRC="/boot/vmlinuz-$KERNEL_VERSION"

# Controllo di sicurezza
if [ ! -f "$KERNEL_SRC" ] ; then
    echo "[ERRORE FATALE] Impossibile trovare i file di boot per openSUSE ($KERNEL_VERSION) in /boot!"
    exit 1
fi

# Copia nella isodir
cp "$KERNEL_SRC" /home/eggs/isodir/live/vmlinuz
echo "-> Copia oa-initrd.img..."
cp "$LIVEROOT/boot/oa-initrd.img" "$ISODIR/live/initrd.img"

# 3. Pulizia della scena del crimine dal chroot
rm -f "$LIVEROOT/boot/oa-initrd.img"

echo "-> Copia completata con successo."
{{ end }}

# ----------------------------------------------------------------------------
# 8.1 HARDLINK TO isodir/live/filesystem.squashfs in arch, fedora, manjaro
# ----------------------------------------------------------------------------
{{ define "distro_hook_squashfs" }}
#!/bin/bash
set -e
# opensuse: distro_hook_squashfs
mkdir -p /home/eggs/isodir/LiveOS
ln -f /home/eggs/isodir/live/filesystem.squashfs /home/eggs/isodir/LiveOS/squashfs.img
{{ end }}

# ==============================================================================
# 🎯 CALAMARES INSTALLER HOOKS (La vera nuova strategia)
# ==============================================================================
{{ define "distro_hook_install_logic" }}
#!/bin/bash
set -e
# opensuse: distro_hook_install_logic
rm -f /etc/sudoers.d/00-live
# SUSE non usa BLSCFG di default come Fedora, ma rigeneriamo dracut sul ferro
dracut -f --regenerate-all

if [ -d /sys/firmware/efi ]; then
      # openSUSE vuole il bootloader-id specifico per non sovrascrivere altri sistemi
      grub2-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=opensuse --recheck --force
      
      # ATTENZIONE: Su SUSE il grub.cfg standard sta in /boot/grub2/grub.cfg 
      # e quello EFI punta lì tramite un piccolo stub in /boot/efi/EFI/opensuse/grub.cfg
      grub2-mkconfig -o /boot/grub2/grub.cfg
      mkdir -p /boot/efi/EFI/opensuse
      grub2-mkconfig -o /boot/efi/EFI/opensuse/grub.cfg
else
      TARGET_DISK=$(grub2-probe -t disk / 2>/dev/null || echo "/dev/sda")
      grub2-install --target=i386-pc --recheck "$TARGET_DISK"
      grub2-makeconfig -o /boot/grub2/grub.cfg
fi
{{ end }}
