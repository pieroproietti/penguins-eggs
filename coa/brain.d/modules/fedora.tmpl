{{ define "kernel_copy_logic" }}
      # Trova l'ultimo kernel evitando versioni rescue
      VMLINUZ=$(ls -v /home/eggs/liveroot/boot/vmlinuz-* | grep -v "rescue" | tail -n 1)
      cp "$VMLINUZ" /home/eggs/isodir/live/vmlinuz
      cp /home/eggs/liveroot/boot/initramfs-fedora.img /home/eggs/isodir/live/initrd.img
{{ end }}

{{ define "initramfs_cmd" }}
      dracut -f -v --no-hostonly --add "dmsquash-live livenet" /boot/initramfs-fedora.img
{{ end }}

{{ define "live_menus_logic" }}
      set -e
      # 1. Variabili e Identità
      VOL_ID="OA_LIVE"
      BOOT_PARAMS="root=live:LABEL=${VOL_ID} rd.live.image selinux=0 quiet splash"
      WORK_DIR="/home/eggs/isodir"
      ASSETS_DIR="/etc/oa-tools.d/brain.d/assets"
      
      # Recupero del nome reale dell'host per il branding
      PRETTY=$(grep "PRETTY_NAME" /home/eggs/liveroot/etc/os-release | cut -d'"' -f2 || echo "OA Live")

      # 2. Creazione Directory (Sempre prima di copiare!)
      mkdir -p ${WORK_DIR}/boot/grub
      mkdir -p ${WORK_DIR}/isolinux
      mkdir -p ${WORK_DIR}/EFI/BOOT

      # 3. COPIA ASSETS (Spostata all'inizio per sicurezza)
      # Copia dello splash screen
      if [ -f "${ASSETS_DIR}/splash.png" ]; then
          cp "${ASSETS_DIR}/splash.png" ${WORK_DIR}/boot/grub/splash.png
          cp "${ASSETS_DIR}/splash.png" ${WORK_DIR}/isolinux/splash.png
          echo "✅ Splash screen copiato con successo."
      else
          echo "⚠️ ATTENZIONE: splash.png non trovato in ${ASSETS_DIR}"
      fi

      # Copia del font Unicode
      if [ -f "/usr/share/grub/unicode.pf2" ]; then
          cp /usr/share/grub/unicode.pf2 ${WORK_DIR}/boot/grub/font.pf2
      elif [ -f "${ASSETS_DIR}/unicode.pf2" ]; then
          cp "${ASSETS_DIR}/unicode.pf2" ${WORK_DIR}/boot/grub/font.pf2
      fi

      # 4. Generazione GRUB.cfg
      cat <<EOF > ${WORK_DIR}/boot/grub/grub.cfg
      set timeout=5
      set default=2

      insmod efi_gop
      insmod efi_uga
      insmod all_video
      insmod gfxterm
      insmod png

      # Fondamentale: imposta la root per trovare i file nella ISO
      search --no-floppy --set=root --label ${VOL_ID}

      # Caricamento Font e Terminale Grafico
      if loadfont /boot/grub/font.pf2; then
          set gfxmode=auto
          terminal_output gfxterm
      fi

      # Immagine di sfondo (Percorso assoluto basato sulla root della ISO)
      background_image /boot/grub/splash.png
      
      # Colori per contrasto su sfondo chiaro
      set menu_color_normal=black/black
      set menu_color_highlight=white/black

      # --- ELEMENTI ESTETICI ---
      # 0. Voce Titolo (non selezionabile o comunque inerte)
      menuentry "--- Penguins eggs (COA/OA Edition) ---" {
          true
      }

      # 1. Voce Vuota (Separatore)
      menuentry "" {
          true
      }

      # 2. Voce reale
      menuentry "Start $PRETTY" {
          linux /live/vmlinuz ${BOOT_PARAMS}
          initrd /live/initrd.img
      }

      menuentry "Start $PRETTY - RAM mode" {
          linux /live/vmlinuz ${BOOT_PARAMS} toram
          initrd /live/initrd.img
      }
      EOF

      # 5. Generazione ISOLINUX.cfg
      cat <<EOF > ${WORK_DIR}/isolinux/isolinux.cfg
      UI vesamenu.c32
      TIMEOUT 50
      DEFAULT live

      # In Isolinux lo splash deve essere nella stessa cartella o percorso relativo
      MENU BACKGROUND splash.png
      MENU TITLE Penguins eggs (COA/OA edition)

      LABEL live
          MENU LABEL Start $PRETTY
          LINUX /live/vmlinuz
          APPEND initrd=/live/initrd.img ${BOOT_PARAMS}

      LABEL ram
          MENU LABEL Start $PRETTY - RAM mode
          LINUX /live/vmlinuz
          APPEND initrd=/live/initrd.img ${BOOT_PARAMS} toram
      EOF

      # 6. Generazione Trampolino EFI
      cat <<EOF > ${WORK_DIR}/EFI/BOOT/grub.cfg
      search --set=root --file /live/filesystem.squashfs
      set prefix=(\$root)/boot/grub
      configfile \$prefix/grub.cfg
      EOF
{{ end }}

{{ define "boot_assets_extra" }}
      # Fedora ha bisogno di percorsi specifici? Aggiungili qui.
{{ end }}

{{ define "squashfs_hooks" }}
      mkdir -p /home/eggs/isodir/LiveOS
      ln -f /home/eggs/isodir/live/filesystem.squashfs /home/eggs/isodir/LiveOS/squashfs.img
{{ end }}


{{ define "install_logic" }}
      # 1. Disabilitiamo il BLS per usare il menu GRUB universale e a prova di bomba
      sed -i 's/GRUB_ENABLE_BLSCFG=true/GRUB_ENABLE_BLSCFG=false/g' /etc/default/grub
      if ! grep -q "GRUB_ENABLE_BLSCFG=false" /etc/default/grub; then
          echo "GRUB_ENABLE_BLSCFG=false" >> /etc/default/grub
      fi

      # 2. Rigenerazione initramfs con dracut
      dracut -f --regenerate-all

      # 3. Installazione GRUB (Bivio UEFI / BIOS Legacy)
      if [ -d /sys/firmware/efi ]; then
          # Fedora blocca grub2-install su EFI per il Secure Boot. Forziamo l'installazione.
          grub2-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=fedora --recheck --force
          
          # Genera il file principale con i menu completi (BLS disabilitato)
          grub2-mkconfig -o /boot/grub2/grub.cfg
          
          # Rigenera lo stub nel percorso EFI
          mkdir -p /boot/efi/EFI/fedora
          grub2-mkconfig -o /boot/efi/EFI/fedora/grub.cfg
      else
          # BIOS Legacy
          TARGET_DISK=$(grub2-probe -t disk / 2>/dev/null || echo "/dev/sda")
          grub2-install --target=i386-pc --recheck "$TARGET_DISK"
          grub2-mkconfig -o /boot/grub2/grub.cfg
      fi
{{ end }}
