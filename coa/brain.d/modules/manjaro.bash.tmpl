# ----------------------------------------------------------------------------
# 5. INITRAMFS LIVE
# ----------------------------------------------------------------------------
{{ define "distro_initramfs_cmd" }}
#!/bin/bash
set -e
# manjaro: distro_initramfs_cmd

if ! pacman -Qs manjaro-tools-iso > /dev/null; then
    echo "[ERRORE FATALE] manjaro-tools-iso non installato."
    exit 1
fi

echo "-> Preparazione mkinitcpio.conf per Live..."

cp /etc/mkinitcpio.conf /etc/mkinitcpio.conf.bak
mkdir -p /etc/mkinitcpio.conf.d.bak /usr/lib/mkinitcpio.conf.d.bak
[ "$(ls -A /etc/mkinitcpio.conf.d/ 2>/dev/null)" ] && mv /etc/mkinitcpio.conf.d/*.conf /etc/mkinitcpio.conf.d.bak/
[ "$(ls -A /usr/lib/mkinitcpio.conf.d/ 2>/dev/null)" ] && mv /usr/lib/mkinitcpio.conf.d/*.conf /usr/lib/mkinitcpio.conf.d.bak/

trap '
mv /etc/mkinitcpio.conf.bak /etc/mkinitcpio.conf
[ "$(ls -A /etc/mkinitcpio.conf.d.bak/ 2>/dev/null)" ] && mv /etc/mkinitcpio.conf.d.bak/*.conf /etc/mkinitcpio.conf.d/
[ "$(ls -A /usr/lib/mkinitcpio.conf.d.bak/ 2>/dev/null)" ] && mv /usr/lib/mkinitcpio.conf.d.bak/*.conf /usr/lib/mkinitcpio.conf.d/
rm -rf /etc/mkinitcpio.conf.d.bak /usr/lib/mkinitcpio.conf.d.bak
' EXIT

cat << 'EOF' > /etc/mkinitcpio.conf
MODULES=(loop dm-snapshot btrfs)
HOOKS=(base udev microcode modconf kms miso miso_loop_mnt miso_pxe_common miso_pxe_nbd miso_pxe_http miso_pxe_nfs block keyboard keymap consolefont filesystems fsck)
COMPRESSION="zstd"
EOF

KERNEL_VERSION=$(uname -r)

echo "-> Generazione initramfs live univoco..."
mkinitcpio -c /etc/mkinitcpio.conf -k "$KERNEL_VERSION" -g "/boot/oa-initrd.img"
{{ end }}

# ----------------------------------------------------------------------------
# 6. COPY KERNEL/INITRD
# ----------------------------------------------------------------------------
{{ define "distro_copy_kernel_cmd" }}
#!/bin/bash
set -e
# manjaro: distro_copy_kernel_cmd

LIVEROOT="/home/eggs/liveroot"
ISODIR="/home/eggs/isodir"

KERNEL_VERSION=$(uname -r)
# Estraiamo major e minor version (es: "6.6") per gestire lo standard Manjaro
KVER_MAJOR_MINOR=$(echo "$KERNEL_VERSION" | cut -d. -f1,2)
ARCH=$(uname -m)

echo "-> Copia Kernel Manjaro/Derivate ($KERNEL_VERSION)..."

PKGBASE_FILE="$LIVEROOT/lib/modules/$KERNEL_VERSION/pkgbase"
if [ ! -f "$PKGBASE_FILE" ]; then
    echo "[ERRORE] File pkgbase mancante in $PKGBASE_FILE!"
    exit 1
fi

PKG_NAME=$(cat "$PKGBASE_FILE")

# 1. Ricerca intelligente del file del Kernel
KERNEL_SRC=""

# Tentativo 1: Standard Arch Linux (es. vmlinuz-linux)
if [ -f "$LIVEROOT/boot/vmlinuz-$PKG_NAME" ]; then
    KERNEL_SRC="$LIVEROOT/boot/vmlinuz-$PKG_NAME"

# Tentativo 2: Standard Manjaro (es. vmlinuz-6.6-x86_64)
elif [ -f "$LIVEROOT/boot/vmlinuz-${KVER_MAJOR_MINOR}-${ARCH}" ]; then
    KERNEL_SRC="$LIVEROOT/boot/vmlinuz-${KVER_MAJOR_MINOR}-${ARCH}"

# Tentativo 3: Fallback estremo
else
    echo "-> Pattern standard non trovati, cerco un vmlinuz valido in /boot..."
    KERNEL_SRC=$(find "$LIVEROOT/boot" -maxdepth 1 -name "vmlinuz-*" -type f -print -quit)
fi

if [ -z "$KERNEL_SRC" ] || [ ! -f "$KERNEL_SRC" ]; then
    echo "[ERRORE FATALE] Impossibile determinare il file del kernel in $LIVEROOT/boot!"
    exit 1
fi

echo "-> Copia $(basename "$KERNEL_SRC")..."
cp "$KERNEL_SRC" "$ISODIR/live/vmlinuz"

# 2. Copia dell'initramfs inequivocabile
if [ ! -f "$LIVEROOT/boot/oa-initrd.img" ]; then
    echo "[ERRORE FATALE] oa-initrd.img non trovato in $LIVEROOT/boot!"
    exit 1
fi

echo "-> Copia oa-initrd.img..."
cp "$LIVEROOT/boot/oa-initrd.img" "$ISODIR/live/initrd.img"

# 3. Pulizia della scena del crimine dal chroot
rm -f "$LIVEROOT/boot/initramfs-oa-initrd.img"
rm -f "$LIVEROOT/boot/oa-initrd.img"

echo "-> Copia blindata completata con successo."
{{ end }}

# ----------------------------------------------------------------------------
# 8.1 HARDLINK TO isodir/live/filesystem.squashfs in arch, fedora, manjaro
# ----------------------------------------------------------------------------
{{ define "distro_hook_squashfs" }}
#!/bin/bash
set -e
# manjaro: distro_hook_squashfs
mkdir -p /home/eggs/isodir/manjaro/x86_64
timeout=10
while [ ! -f /home/eggs/isodir/live/filesystem.squashfs ] && [ $timeout -gt 0 ]; do
    sleep 1
    timeout=$((timeout-1))
done
ln -f /home/eggs/isodir/live/filesystem.squashfs /home/eggs/isodir/manjaro/x86_64/livefs.sfs
{{ end }}

# ==============================================================================
# 🎯 CALAMARES INSTALLER HOOKS
# ==============================================================================
{{ define "distro_hook_install_logic" }}
#!/bin/bash
set -e
# manjaro: distro_hook_install_logic
rm -f /etc/sudoers.d/00-live
mkinitcpio -P
if [ -d /sys/firmware/efi ]; then
      grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=oa-live --recheck
else
      TARGET_DISK=$(grub-probe -t disk / 2>/dev/null || echo "/dev/sda")
      grub-install --target=i386-pc --recheck "$TARGET_DISK"
fi
grub-mkconfig -o /boot/grub/grub.cfg
{{ end }}