# ==============================================================================
# 🧩 FILE: base.yaml.tmpl
# 🎯 ROLE: Main orchestration plan (YAML) for oa-tools framework
# ==============================================================================
# ----------------------------------------------------------------------------
# impostazioni che possono essere sovrascritte dall'utente
# ----------------------------------------------------------------------------
settings:
  remaster:
    user: "live"
    password: "evolution"
    work_dir: "/home/eggs"
    compression:
      algorithm: "zstd"
      level: 3

remaster:
# ----------------------------------------------------------------------------
# 1. INITIAL SETUP AND MOUNT
# ----------------------------------------------------------------------------
  - name: "mount-logic"
    description: "Chroot environment and mount point preparation"
    module: "mount_logic"

# ----------------------------------------------------------------------------
# 2. BOOTLOADERS PREPARATION
# ----------------------------------------------------------------------------
  # --- 2.1 PREPARAZIONE E COPIA BOOTLOADER ---
  - name: "prepare-bootloader"
    description: "Crea directory e copia assets bootloader (BIOS/UEFI)"
    module: "shell"
    params:
      command: "/etc/oa-tools.d/scripts/prepare-bootloader.sh /home/eggs/isodir /tmp/coa/bootloaders"

  # --- 2.2. GENERAZIONE EFI.IMG ---
  - name: "generate-efi.img"
    description: "Generazione immagine FAT per EFI"
    module: "shell"
    params:
      command: |
        dd if=/dev/zero of=/home/eggs/isodir/EFI/BOOT/efi.img bs=1M count=12
        mkfs.vfat /home/eggs/isodir/EFI/BOOT/efi.img
        mmd -i /home/eggs/isodir/EFI/BOOT/efi.img ::/EFI
        mmd -i /home/eggs/isodir/EFI/BOOT/efi.img ::/EFI/BOOT
        if [ -f /home/eggs/isodir/EFI/BOOT/BOOTX64.EFI ]; then
            mcopy -i /home/eggs/isodir/EFI/BOOT/efi.img /home/eggs/isodir/EFI/BOOT/BOOTX64.EFI ::/EFI/BOOT/BOOTX64.EFI
        fi

# ----------------------------------------------------------------------------
# 3. LIVE MENUS
# ----------------------------------------------------------------------------
  # --- 3. PREPARAZIONE ASSETS: SPLASH E FONT ---
  - name: "copy-assets"
    description: "Copia splash screen e configurazione font GRUB/ISOLINUX"
    module: "shell"
    params:
      command: |
        # 1. Copia Splash Screen (con ignoranza dei file mancanti)
        [ -f "/etc/oa-tools.d/brain.d/assets/splash.png" ] && cp -f /etc/oa-tools.d/brain.d/assets/splash.png /home/eggs/isodir/boot/grub/splash.png
        [ -f "/etc/oa-tools.d/brain.d/assets/splash.png" ] && cp -f /etc/oa-tools.d/brain.d/assets/splash.png /home/eggs/isodir/isolinux/splash.png

        # 2. Gestione Font GRUB
        if [ -f "/usr/share/grub/unicode.pf2" ]; then
            cp -f /usr/share/grub/unicode.pf2 /home/eggs/isodir/boot/grub/font.pf2
        elif [ -f "/etc/oa-tools.d/brain.d/assets/unicode.pf2" ]; then
            cp -f /etc/oa-tools.d/brain.d/assets/unicode.pf2 /home/eggs/isodir/boot/grub/font.pf2
        fi

  # 3.1. --- GENERAZIONE MENU DI BOOT (Heredoc Script) ---
  - name: "generate-boot-menus"
    description: "Generazione dinamica GRUB, ISOLINUX e trampolino EFI"
    module: "shell"
    chroot: false
    "params": 
      "command": "/etc/oa-tools.d/scripts/generate-menus.sh \"/home/eggs/isodir\" \"boot=live components cow_spacesize=2G\""


# ----------------------------------------------------------------------------
# 4. USER IDENTITY
# ----------------------------------------------------------------------------
  - name: "Indentity"
    description: "Live user injection and password sanitization"
    module: "users"

# ----------------------------------------------------------------------------
# 4.1 Sanitize host
# ----------------------------------------------------------------------------
## -- 4.1 sanitize host
  - name: "sanitize-system-files"
    description: "Sanitizzazione fstab e crypttab per il sistema live"
    module: "shell"
    chroot: false
    params:
      command: |
        # Operiamo direttamente sul path noto
        echo "# UNCONFIGURED FSTAB" > /home/eggs/liveroot/etc/fstab
        echo "# UNCONFIGURED CRYPTTAB" > /home/eggs/liveroot/etc/crypttab
        chmod 644 /home/eggs/liveroot/etc/fstab /home/eggs/liveroot/etc/crypttab

# ----------------------------------------------------------------------------
# 5. LIVE INITRAMFS
# ----------------------------------------------------------------------------
  - name: "initramfs"
    description: "Live environment-specific Initramfs generation"
    module: "shell"
    chroot: true
    live_root: "INJECTED_BY_PLANNER"
    params:
      command: |
{{ include "distro_initramfs_cmd" . | indent 8 }}

# ----------------------------------------------------------------------------
# 6. COPIA DEL KERNEL ED INITRAMFS
# ----------------------------------------------------------------------------
  - name: "copy-kernel-initrd"
    description: "Universal copy of kernel and initramfs to live ISO directory"
    module: "shell"
    chroot: false
    params:
      command: "/etc/oa-tools.d/scripts/copy-kernel-initrd.sh"

# ----------------------------------------------------------------------------
# 7. LIVE USER PRIVILEGES, AUTOLOGIN AND TRUSTED DESKTOP LAUNCHER
# ----------------------------------------------------------------------------
  ## 7. LIVE USER PRIVILEGES, AUTOLOGIN AND TRUSTED DESKTOP LAUNCHER
  # 7.1. Configurazione Sudoers (Senza password)
  - name: "conf-live-sudoers"
    description: "Configurazione sudoers per utente live"
    module: "template"
    chroot: true
    params:
      dest: "/etc/sudoers.d/00-live"
      permissions: 288 # Esadecimale 0440
      content: |
        live ALL=(ALL) NOPASSWD:ALL

  # 7.2. Desktop Launcher Universale
  - name: "create-live-launcher"
    description: "Desktop Launcher di installazione"
    module: "template"
    chroot: true
    params:
      dest: "/usr/share/applications/install-system.desktop"
      permissions: 493 # Esadecimale 0755
      content: |
        [Desktop Entry]
        Type=Application
        Version=1.0
        Name=Install System
        GenericName=Live Installer
        Comment=Install this system to your hard disk
        Exec=sudo eggs sysinstall calamares
        Icon=penguins-eggs
        Terminal=false
        Categories=System;

  # 7.3. Trust Agent (Copying the script to liveroot)
  - name: "trust-agent-script"
    description: "Copia dello script per il trust dinamico del desktop launcher"
    module: "shell"
    chroot: false 
    params:
      command: |
        cp /etc/oa-tools.d/scripts/trust-desktop.sh /home/eggs/liveroot/usr/local/bin/trust-desktop
        chmod 755 /home/eggs/liveroot/usr/local/bin/trust-desktop

  # 7.4. Trust Agent Autostart
  - name: "trust-agent-autostart"
    description: "Innesco XDG Autostart per il trust agent"
    module: "template"
    chroot: true
    params:
      dest: "/etc/xdg/autostart/trust-installer.desktop"
      permissions: 420 # Esadecimale 0644
      content: |
        [Desktop Entry]
        Type=Application
        Name=Trust Installer
        Exec=/usr/local/bin/trust-desktop
        Hidden=false
        NoDisplay=true


# ----------------------------------------------------------------------------
# 7.1 autologin-gui
# ----------------------------------------------------------------------------
  - name: autologin-gui
    description: "Creazione di autologin per utente live"
    module: "autologin-gui"
    params:
      user: "live"
      is_gui: true

# ----------------------------------------------------------------------------
# 7.5 egg-icon
# ----------------------------------------------------------------------------
  - name: "eggs-icon"
    description: "Creazione Icona Uovo (SVG 3D Golden Edition)"
    module: "template"
    params:
      dest: "/usr/share/icons/hicolor/scalable/apps/penguins-eggs.svg"
      permissions: 0644
      content: |
        <svg width="64" height="64" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
        <defs>
            <radialGradient id="eggGrad" cx="30%" cy="30%" r="65%">
            <stop offset="0%" stop-color="#ffe066" />
            <stop offset="50%" stop-color="#f0ad4e" />
            <stop offset="100%" stop-color="#b87311" />
            </radialGradient>
        </defs>
        <ellipse cx="32" cy="59" rx="18" ry="3" fill="rgba(0,0,0,0.2)" />
        <path d="M 32 4 C 18 4, 8 24, 8 42 C 8 55, 18 60, 32 60 C 46 60, 56 55, 56 42 C 56 24, 46 4, 32 4 Z" fill="url(#eggGrad)" />
        </svg>

# ----------------------------------------------------------------------------
# 8. FILESYSTEM.SQUASHFS COMPRESSION
# ----------------------------------------------------------------------------
  - name: "mksquashfs"
    module: "mksquashfs"
    params:
      algorithm: "zstd"
      level: "3"
      live_root: "/home/eggs/liveroot"
      dest_file: "/home/eggs/isodir/live/filesystem.squashfs"
      excludes_file: "/tmp/coa/excludes.list"
  
# ----------------------------------------------------------------------------
# 8.1 Hard link to /home/eggs/isodir/live/filesystem.squashfs in arch, fedora, manjaro
# ----------------------------------------------------------------------------
  - name: "distro_hook_squashfs"
    description: "Hard link to /home/eggs/isodir/live/filesystem.squashfs in arch, fedora, manjaro"
    module: "shell"
    chroot: false
    params:
{{ include "distro_hook_squashfs" . | indent 8 }}

# ----------------------------------------------------------------------------
# 9. ISO XORRISO PACKAGING
# ----------------------------------------------------------------------------
  - name: "xorriso"
    module: "xorriso"
    params:
      output_file: "INJECTED_BY_PLANNER"
      source_dir: "INJECTED_BY_PLANNER"
      isolinux_bin: "isolinux/isolinux.bin"
      isolinux_cat: "isolinux/boot.cat"
      efi_img: "EFI/BOOT/efi.img"
      isohdpfx: "/tmp/coa/bootloaders/ISOLINUX/isohdpfx.bin"

# ----------------------------------------------------------------------------
# 10. CLEANUP
# ----------------------------------------------------------------------------
#  - name: "cleanup"
#    description: "unmount on the plan"
#    module: "umount"
#    work_dir: "INJECTED_BY_PLANNER"

# ==============================================================================
# 🎯 CALAMARES INSTALLER HOOKS
# ==============================================================================
install:
  - name: "coa-finalize"
    description: "Target finalization and host bootloader regeneration"
    module: "shell"
    params: 
      command: |
{{ include "distro_hook_install_logic" . | indent 8 }}

