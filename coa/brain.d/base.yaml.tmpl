# ==============================================================================
# 🧩 OA UNIVERSAL FRAMEWORK (EVOLUTION EDITION)
# ==============================================================================



# ----------------------------------------------------------------------------
# impostazioni che possono essere sovrascritte dall'utente
# ----------------------------------------------------------------------------
settings:
  remaster:
    user: "live"
    password: "evolution"
    work_dir: "/home/eggs"
    compression:
      algorithm: "zstd"
      level: 3

remaster:

  # ----------------------------------------------------------------------------
  # 1. INITIAL SETUP AND MOUNT
  # ----------------------------------------------------------------------------
  - name: "coa-fs-setup"
    description: "Chroot environment and mount point preparation"
    action: "oa_mount_logic"

# ----------------------------------------------------------------------------
# 2. BOOTLOADERS PREPARATION
# ----------------------------------------------------------------------------
{{ include "ell_bootloaders" . | indent 2 }}


  # ----------------------------------------------------------------------------
  # 3. LIVE MENUS
  # ----------------------------------------------------------------------------
{{ include "ell_live_menus" . | indent 2 }}

  # ----------------------------------------------------------------------------
  # 4. USER IDENTITY
  # ----------------------------------------------------------------------------
  - name: "coa-identity"
    description: "Live user injection and password sanitization"
    action: "oa_users"

  # ----------------------------------------------------------------------------
  # 4.1 SANITIZE HOST
  # ----------------------------------------------------------------------------
  - name: "coa-sanitize-host"
    description: "Remove /etc/fstab from live"
    action: "oa_shell"
    run_command: |
{{ include "core_sanitize_host" . | indent 6 }}

  # ----------------------------------------------------------------------------
  # 5. LIVE INITRAMFS
  # ----------------------------------------------------------------------------
  - name: "coa-initrd"
    description: "Live environment-specific Initramfs generation"
    action: "oa_shell"
    chroot: true
    run_command: |
{{ include "hook_initramfs_cmd" . | indent 6 }}


  # ----------------------------------------------------------------------------
  # 6. KERNEL AND PRIVILEGE EXTRACTION
  # ----------------------------------------------------------------------------
  - name: "coa-kernel-copy"
    description: "Dynamic kernel and initrd copy to ISO root"
    action: "oa_shell"
    run_command: |
{{ include "core_kernel_copy" . | indent 6 }}

  # ----------------------------------------------------------------------------
  # 7. LIVE USER PRIVILEGES, AUTOLOGIN AND TRUSTED DESKTOP LAUNCHER
  # ----------------------------------------------------------------------------
{{ include "ell_enable_live" . | indent 2 }}

  - name: "coa-live-icon"
    description: "Creazione Icona Uovo (SVG 3D Golden Edition)"
    action: "oa_ell"
    params:
      module: "template"
      dest: "/usr/share/icons/hicolor/scalable/apps/penguins-eggs.svg"
      permissions: 0644
      content: |
        <svg width="64" height="64" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
        <defs>
            <radialGradient id="eggGrad" cx="30%" cy="30%" r="65%">
            <stop offset="0%" stop-color="#ffe066" />
            <stop offset="50%" stop-color="#f0ad4e" />
            <stop offset="100%" stop-color="#b87311" />
            </radialGradient>
        </defs>
        <ellipse cx="32" cy="59" rx="18" ry="3" fill="rgba(0,0,0,0.2)" />
        <path d="M 32 4 C 18 4, 8 24, 8 42 C 8 55, 18 60, 32 60 C 46 60, 56 55, 56 42 C 56 24, 46 4, 32 4 Z" fill="url(#eggGrad)" />
        </svg>

  # ----------------------------------------------------------------------------
  # 7.1 coa-autologin-gui
  # ----------------------------------------------------------------------------
  - name: coa-autologin-gui
    description: "Creazione di autologin per utente live"
    action: "oa_ell"
    params:
      user: "live"
      is_gui: true


  # ----------------------------------------------------------------------------
  # 8. FILESYSTEM.SQUASHFS COMPRESSION
  # ----------------------------------------------------------------------------
  - name: "coa-squashfs"
    description: "Root filesystem compression into SquashFS format"
    action: "oa_shell"
    run_command: |
{{ include "core_squashfs" . | indent 6 }}
{{ include "hook_squashfs" . | indent 6 }}

  # ----------------------------------------------------------------------------
  # 9. ISO XORRISO PACKAGING
  # ----------------------------------------------------------------------------
  - name: "coa-xorriso"
    description: "Final hybrid ISO image generation (xorriso)"
    action: "oa_shell"
    run_command: |
{{ include "core_xorriso" . | indent 6 }}

  # ----------------------------------------------------------------------------
  # 10. CLEANUP
  # ----------------------------------------------------------------------------
  - name: "coa-cleanup"
    description: "Environment unmounting and cleanup"
    action: "oa_umount"


# ==============================================================================
# 🎯 CALAMARES INSTALLER HOOKS
# ==============================================================================
install:
  - name: "coa-finalize"
    description: "Target finalization and host bootloader regeneration"
    action: "oa_shell"
    run_command: |
{{ include "core_finalize" . | indent 6 }}