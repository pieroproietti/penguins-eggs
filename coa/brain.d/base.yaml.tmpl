# ==============================================================================
# 🧩 TELAIO UNIVERSALE OA (EVOLUTION EDITION)
# ==============================================================================
remaster:

  # ----------------------------------------------------------------------------
  # 1. SETUP INIZIALE E MOUNT
  # ----------------------------------------------------------------------------
  - name: "coa-fs-setup"
    description: "Preparazione dell'ambiente di chroot e mount point"
    action: "oa_mount_logic"


  # ----------------------------------------------------------------------------
  # 2. PREPARAZIONE BOOTLOADERS
  # ----------------------------------------------------------------------------
  - name: "coa-bootloaders"
    description: "Staging degli assets per BIOS (ISOLINUX) e UEFI (GRUB/EFI)"
    action: "oa_shell"
    run_command: |
      mkdir -p /home/eggs/isodir/live /home/eggs/isodir/isolinux /home/eggs/isodir/boot/grub /home/eggs/isodir/EFI/BOOT
      
      # Copia assets BIOS
      cp /tmp/coa/bootloaders/ISOLINUX/isolinux.bin /home/eggs/isodir/isolinux/ 2>/dev/null || true
      cp /tmp/coa/bootloaders/syslinux/modules/bios/*.c32 /home/eggs/isodir/isolinux/ 2>/dev/null || true
      
      # Copia del binario EFI (Percorso corretto e unificato!)
      EFI_SRC="/tmp/coa/bootloaders/grub/x86_64-efi/monolithic/grubx64.efi"
      if [ -f "$EFI_SRC" ]; then
          cp "$EFI_SRC" /home/eggs/isodir/EFI/BOOT/BOOTX64.EFI
      fi

      # Generazione immagine FAT per EFI (12MB)
      dd if=/dev/zero of=/home/eggs/isodir/EFI/BOOT/efi.img bs=1M count=12
      mkfs.vfat /home/eggs/isodir/EFI/BOOT/efi.img
      mmd -i /home/eggs/isodir/EFI/BOOT/efi.img ::/EFI
      mmd -i /home/eggs/isodir/EFI/BOOT/efi.img ::/EFI/BOOT
      
      # Iniezione del binario nella partizione FAT
      if [ -f /home/eggs/isodir/EFI/BOOT/BOOTX64.EFI ]; then
          mcopy -i /home/eggs/isodir/EFI/BOOT/efi.img /home/eggs/isodir/EFI/BOOT/BOOTX64.EFI ::/EFI/BOOT/BOOTX64.EFI
      fi

  # ----------------------------------------------------------------------------
  # 3. GENERAZIONE MENU DI AVVIO E BRANDING
  # ----------------------------------------------------------------------------
  - name: "coa-live-menus"
    description: "Generazione dinamica dei menu di GRUB e ISOLINUX"
    action: "oa_shell"
    run_command: |
      set -e
      # 1. Variabili Universali
      VOL_ID="OA_LIVE"
      BOOT_PARAMS="{{ template "boot_params" . }}"
      WORK_DIR="/home/eggs/isodir"
      ASSETS_DIR="/etc/oa-tools.d/brain.d/assets"
      
      PRETTY=$(grep "PRETTY_NAME" /home/eggs/liveroot/etc/os-release | cut -d'"' -f2 || echo "OA Live")

      # 2. Creazione Directory
      mkdir -p ${WORK_DIR}/boot/grub
      mkdir -p ${WORK_DIR}/isolinux
      mkdir -p ${WORK_DIR}/EFI/BOOT

      # 3. Copia Assets Universale
      if [ -f "${ASSETS_DIR}/splash.png" ]; then
          cp "${ASSETS_DIR}/splash.png" ${WORK_DIR}/boot/grub/splash.png
          cp "${ASSETS_DIR}/splash.png" ${WORK_DIR}/isolinux/splash.png
      fi

      if [ -f "/usr/share/grub/unicode.pf2" ]; then
          cp /usr/share/grub/unicode.pf2 ${WORK_DIR}/boot/grub/font.pf2 2>/dev/null || true
      elif [ -f "${ASSETS_DIR}/unicode.pf2" ]; then
          cp "${ASSETS_DIR}/unicode.pf2" ${WORK_DIR}/boot/grub/font.pf2 2>/dev/null || true
      fi

      # 4. Generazione GRUB.cfg (Main)
      cat <<EOF > ${WORK_DIR}/boot/grub/grub.cfg
      set timeout=5
      set default=2

      insmod efi_gop
      insmod efi_uga
      insmod all_video
      insmod gfxterm
      insmod png
      insmod part_gpt
      insmod part_msdos
      insmod fat
      insmod iso9660

      search --no-floppy --set=root --label ${VOL_ID}

      if loadfont /boot/grub/font.pf2; then
          set gfxmode=auto
          terminal_output gfxterm
      fi

      background_image /boot/grub/splash.png
      set menu_color_normal=black/black
      set menu_color_highlight=white/black
      
      menuentry "--- Penguins eggs (COA/OA Edition) ---" {
          true
      }
      menuentry "" {
          true
      }
      menuentry "Start ${PRETTY}" {
          linux /live/vmlinuz ${BOOT_PARAMS}
          initrd /live/initrd.img
      }
      menuentry "Start ${PRETTY} - RAM mode" {
          linux /live/vmlinuz ${BOOT_PARAMS} toram
          initrd /live/initrd.img
      }
      EOF

      # 5. Generazione ISOLINUX.cfg (BIOS)
      cat <<EOF > ${WORK_DIR}/isolinux/isolinux.cfg
      UI vesamenu.c32
      TIMEOUT 50
      DEFAULT live

      MENU BACKGROUND splash.png
      MENU TITLE Penguins eggs (COA/OA edition)

      LABEL live
          MENU LABEL Start ${PRETTY}
          LINUX /live/vmlinuz
          APPEND ${BOOT_PARAMS}
          INITRD /live/initrd.img

      LABEL ram
          MENU LABEL Start ${PRETTY} - RAM mode
          LINUX /live/vmlinuz
          APPEND ${BOOT_PARAMS} toram
          INITRD /live/initrd.img
      EOF

      # 6. Generazione Trampolino EFI
      cat << 'EOF' > ${WORK_DIR}/EFI/BOOT/grub.cfg
      search --set=root --file /live/filesystem.squashfs
      set prefix=($root)/boot/grub
      configfile $prefix/grub.cfg
      EOF

  # ----------------------------------------------------------------------------
  # 4. IDENTITÀ UTENTE
  # ----------------------------------------------------------------------------
  - name: "coa-identity"
    description: "Iniezione dell'utente live e purificazione password"
    action: "oa_users"


  # ----------------------------------------------------------------------------
  # 5. INITRAMFS LIVE
  # ----------------------------------------------------------------------------
  - name: "coa-initrd"
    description: "Generazione dell'Initramfs specifico per l'ambiente live"
    action: "oa_shell"
    chroot: true
    run_command: |
{{ template "initramfs_cmd" . }}

  # ----------------------------------------------------------------------------
  # 6. ESTRAZIONE KERNEL E PRIVILEGI
  # ----------------------------------------------------------------------------
  - name: "coa-kernel-copy"
    description: "Copia dinamica di kernel e initrd nella root ISO"
    action: "oa_shell"
    run_command: |
{{ template "find_kernel_initrd" . }}
      if [ -n "$KERNEL_PATH" ]; then cp "$KERNEL_PATH" /home/eggs/isodir/live/vmlinuz; fi
      if [ -n "$INITRD_PATH" ]; then cp "$INITRD_PATH" /home/eggs/isodir/live/initrd.img; fi

  # ----------------------------------------------------------------------------
  # 7. PRIVILEGI USER live, AUTOLOGIN E TRUSTED DESKTOP LAUNCHER
  # ----------------------------------------------------------------------------
  - name: "coa-enable-live"
    description: "Configurazione privilegi, launcher fidato e autologin universale"
    action: "oa_shell"
    chroot: true
    run_command: |
      USER="live"
      
      # 7.1. Sudoers e Gruppi (Usa template per sudo/wheel)
      echo "${USER} ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/00-live
      chmod 0440 /etc/sudoers.d/00-live
      groupadd autologin 2>/dev/null || true
      usermod -aG {{ template "admin_group" . }},autologin ${USER} 2>/dev/null || true

      # 7.2. Creazione Icona Uovo (SVG 3D Golden Edition)
      ICON_PATH="/usr/share/icons/hicolor/scalable/apps/penguins-eggs.svg"
      mkdir -p $(dirname $ICON_PATH)
      cat << 'EOF' > $ICON_PATH
      <svg width="64" height="64" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="eggGrad" cx="30%" cy="30%" r="65%">
            <stop offset="0%" stop-color="#ffe066" />
            <stop offset="50%" stop-color="#f0ad4e" />
            <stop offset="100%" stop-color="#b87311" />
          </radialGradient>
        </defs>
        <ellipse cx="32" cy="59" rx="18" ry="3" fill="rgba(0,0,0,0.2)" />
        <path d="M 32 4 C 18 4, 8 24, 8 42 C 8 55, 18 60, 32 60 C 46 60, 56 55, 56 42 C 56 24, 46 4, 32 4 Z" fill="url(#eggGrad)" />
      </svg>
      EOF
      gtk-update-icon-cache /usr/share/icons/hicolor/ 2>/dev/null || true

      # 7.3. Desktop Launcher Certificato
      APP_DIR="/usr/share/applications"
      mkdir -p $APP_DIR /etc/skel/Desktop /home/${USER}/Desktop
      cat << EOF > $APP_DIR/install-system.desktop
      [Desktop Entry]
      Type=Application
      Version=1.0
      Name=Install System
      GenericName=Live Installer
      Comment=Install this system to your hard disk
      Exec=sudo eggs sysinstall calamares
      Icon=penguins-eggs
      Terminal=false
      Categories=System;
      EOF
      chmod +x $APP_DIR/install-system.desktop
      cp $APP_DIR/install-system.desktop /etc/skel/Desktop/
      cp $APP_DIR/install-system.desktop /home/${USER}/Desktop/
      chown -R ${USER}:${USER} /home/${USER}/Desktop
      chmod +x /home/${USER}/Desktop/install-system.desktop

      # 7.4. L'AGENTE SEGRETO (Bypass Sicurezza GIO/XFCE)
      mkdir -p /etc/xdg/autostart /usr/local/bin
      cat << 'EOF' > /usr/local/bin/oa-trust-desktop
      #!/bin/bash
      for i in {1..15}; do
          if pgrep -x xfdesktop >/dev/null || pgrep -x nautilus >/dev/null || pgrep -x nemo >/dev/null || pgrep -x caja >/dev/null || pgrep -f ding >/dev/null || pgrep -x plasmashell >/dev/null || pgrep -x pcmanfm >/dev/null || pgrep -x pcmanfm-qt >/dev/null; then
              break
          fi
          sleep 1
      done
      sleep 2
      if ! pgrep -x plasmashell > /dev/null; then
          LAUNCHER="$(xdg-user-dir DESKTOP 2>/dev/null || echo "$HOME/Desktop")/install-system.desktop"
          if [ -f "$LAUNCHER" ]; then
              gio set "$LAUNCHER" metadata::trusted yes 2>/dev/null
              gio set "$LAUNCHER" metadata::xfce-exe-checksum "$(sha256sum "$LAUNCHER" | awk '{print $1}')" 2>/dev/null
          fi
      fi
      EOF
      chmod +x /usr/local/bin/oa-trust-desktop
      cat << 'EOF' > /etc/xdg/autostart/trust-installer.desktop
      [Desktop Entry]
      Type=Application
      Name=Trust Installer
      Exec=/usr/local/bin/oa-trust-desktop
      Hidden=false
      NoDisplay=true
      EOF

      # 7.5. Autologin Universale (Forzato per tutte le distro)
      if [ -d /etc/lightdm ]; then
          passwd -d $USER 2>/dev/null || true
          usermod -U $USER 2>/dev/null || true
          
          if [ -f /etc/pam.d/lightdm-autologin ]; then
              sed -i '/pam_succeed_if.so.*user ingroup autologin/d' /etc/pam.d/lightdm-autologin
          fi
          
          SESSION=$(ls -1 /usr/share/xsessions/ 2>/dev/null | head -n 1 | sed 's/\.desktop//')
          
          if [ -f /etc/lightdm/lightdm.conf ]; then
              sed -i -e '/^[#]*autologin-user=/d' -e '/^[#]*autologin-user-timeout=/d' -e '/^[#]*autologin-session=/d' /etc/lightdm/lightdm.conf
              sed -i "/^\[Seat:\*\]/a autologin-user=$USER\nautologin-user-timeout=0\nautologin-session=${SESSION:-xfce}" /etc/lightdm/lightdm.conf
          fi
      fi
      
  # ----------------------------------------------------------------------------
  # 8. COMPRESSIONE FILESYSTEM.SQUASHFS
  # ----------------------------------------------------------------------------
  - name: "coa-squashfs"
    description: "Compressione del filesystem root in formato SquashFS"
    action: "oa_shell"
    run_command: |
      mksquashfs /home/eggs/liveroot /home/eggs/isodir/live/filesystem.squashfs \
        -comp zstd \
        -Xcompression-level 3 \
        -b 1M \
        -processors 4 \
        -noappend \
        -wildcards \
        -ef /tmp/coa/excludes.list \
        -p "mnt d 0755 root root" \
        -p "media d 0755 root root"
{{ template "squashfs_hooks" . }}

  # ----------------------------------------------------------------------------
  # 9. PACCHETTIZZAZIONE ISO XORRISO
  # ----------------------------------------------------------------------------
  - name: "coa-xorriso"
    description: "Generazione finale dell'immagine ISO ibrida (xorriso)"
    action: "oa_shell"
    run_command: |
      xorriso -as mkisofs -iso-level 3 -full-iso9660-filenames -volid 'OA_LIVE' \
      -eltorito-boot isolinux/isolinux.bin -eltorito-catalog isolinux/boot.cat \
      -no-emul-boot -boot-load-size 4 -boot-info-table \
      -isohybrid-mbr /tmp/coa/bootloaders/ISOLINUX/isohdpfx.bin \
      -eltorito-alt-boot -e EFI/BOOT/efi.img -no-emul-boot -isohybrid-gpt-basdat \
      -o ${ISO_OUTPUT} /home/eggs/isodir

  # ----------------------------------------------------------------------------
  # 10. PULIZIA
  # ----------------------------------------------------------------------------
  - name: "coa-cleanup"
    description: "Smontaggio e pulizia dell'ambiente di lavoro"
    action: "oa_umount"

# ==============================================================================
# 🎯 CALAMARES INSTALLER HOOKS
# ==============================================================================
install:
  - name: "coa-finalize"
    description: "Finalizzazione del target e rigenerazione bootloader host"
    action: "oa_shell"
    run_command: |
      #!/bin/bash
      set -e
      rm -f /etc/sudoers.d/00-live
{{ template "install_logic" . }}