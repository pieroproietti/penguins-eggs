pkgname=penguins-eggs
pkgver={{.BaseVersion}}
pkgrel={{.Rel}}
pkgdesc="penguins-eggs universal Linux remastering"
arch=('x86_64')
url="https://penguins-eggs.net"
license=('GPL3')
options=('!debug')

depends=(
	'archiso'
	'mkinitcpio-archiso'
	'arch-install-scripts'
	'bash-completion'
	'btrfs-progs'
	'curl'
	'dosfstools'
	'e2fsprogs'
	'efibootmgr'
	'git'
	'glibc'
	'gnupg'
	'grub'
	'libarchive'
	'libisoburn'
	'mkinitcpio-nfs-utils'
	'mtools'
	'nbd'
	'pv'
	'rsync'
	'squashfs-tools'
	'sudo'
	'wget'
	'yq'
	'qemu-guest-agent'
)

package() {
    # Tracciamo i confini
    mkdir -p "${pkgdir}/usr"
    mkdir -p "${pkgdir}/etc"

    # Usiamo $startdir per puntare alla root dello staging (/tmp/oa-stage-dir)
    cp -a "${startdir}/usr/"* "${pkgdir}/usr/"
    cp -a "${startdir}/etc/"* "${pkgdir}/etc/"
}
