pkgname=oa-tools-arch
pkgver={{.BaseVersion}}
pkgrel={{.Rel}}
pkgdesc="oa-tools universal Linux remastering"
arch=('x86_64')
url="https://penguins-eggs.net"
license=('GPL3')
options=('!debug')

depends=(
	'mkinitcpio-archiso'
	'arch-install-scripts'
	'bash-completion'
	'curl'
	'dosfstools'
	'efibootmgr'
	'git'
	'glibc'
	'gnupg'
	'grub'
	'jq'
	'libarchive'
	'libisoburn'
	'mtools'
	'pv'
	'rsync'
	'squashfs-tools'
	'sudo'
)

# Indichiamo a pacman che questo pacchetto sostituisce la vecchia guardia
conflicts=('penguins-eggs')
replaces=('penguins-eggs')

package() {
    # Tracciamo i confini
    mkdir -p "${pkgdir}/usr"
    mkdir -p "${pkgdir}/etc"

    # Usiamo $startdir per puntare alla root dello staging (/tmp/oa-stage-dir)
    cp -a "${startdir}/usr/"* "${pkgdir}/usr/"
    cp -a "${startdir}/etc/"* "${pkgdir}/etc/"
}
