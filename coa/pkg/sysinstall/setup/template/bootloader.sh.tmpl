#!/bin/bash
set -e

FAMILY="{{ .Family }}"
DISTRO_ID="{{ .ID }}"

echo "oa-bootloader: Avvio configurazione autonoma per OS Family: $FAMILY | OS ID: $DISTRO_ID"

# ----------------------------------------------------------------------------
# FUNZIONE: Generazione BLS (BootLoaderSpec) per Fedora/RedHat e openSUSE
# ----------------------------------------------------------------------------
generate_bls_entry() {
    if [[ "$FAMILY" == *"fedora"* ]] || [[ "$FAMILY" == *"redhat"* ]] || [[ "$FAMILY" == *"suse"* ]] || [[ "$FAMILY" == *"opensuse"* ]]; then
        echo "oa-bootloader: Generazione entry BLS nativa per $FAMILY..."
        
        # 1. Creiamo la directory e puliamo le vecchie entry
        mkdir -p /boot/loader/entries
        rm -f /boot/loader/entries/*.conf
        
        # 2. Ricaviamo la versione esatta del kernel (IGNORANDO I KERNEL RESCUE!)
        KVER=$(ls -1 /boot/vmlinuz-* 2>/dev/null | grep -v rescue | head -n 1 | sed 's|.*/vmlinuz-||')
        
        if [ -n "$KVER" ]; then
            # 3. Troviamo la partizione di root da fstab
            ROOT_PART=$(grep " / " /etc/fstab | grep -v "^#" | awk '{print $1}')
            if [[ "$ROOT_PART" == UUID=* ]]; then
                ROOT_UUID="$ROOT_PART"
            else
                ROOT_UUID="UUID=$(blkid -s UUID -o value $ROOT_PART)"
            fi
            
            # 4. Standard BLS: machine-id
            MACHINE_ID=$(cat /etc/machine-id 2>/dev/null || echo "oa-linux")
            
            # 5. Troviamo l'initrd corretto (ignorando i rescue)
            INITRD_FILE=$(ls -1 /boot/initramfs-${KVER}* /boot/initrd-${KVER}* 2>/dev/null | grep -v rescue | head -n 1 | xargs basename)
            
            # 6. FIX PERCORSO: Se /boot NON è una partizione separata, GRUB necessita del prefisso /boot
            BOOT_PREFIX=""
            if ! findmnt -M /boot >/dev/null 2>&1; then
                BOOT_PREFIX="/boot"
            fi
            
            # 7. Scrittura del file .conf per il BLS
            cat <<EOF > "/boot/loader/entries/${MACHINE_ID}-${KVER}.conf"
title $DISTRO_ID ($KVER)
version $KVER
linux $BOOT_PREFIX/vmlinuz-$KVER
initrd $BOOT_PREFIX/$INITRD_FILE
options root=$ROOT_UUID ro quiet
EOF
            echo "oa-bootloader: Entry BLS creata con successo ($BOOT_PREFIX/vmlinuz-$KVER)"
        else
            echo "ATTENZIONE: Impossibile trovare il kernel per generare la entry BLS!"
        fi
    fi
}
# ----------------------------------------------------------------------------

# 1. Rilevamento UEFI o BIOS
IS_UEFI=0
if [ -d /sys/firmware/efi ]; then
    IS_UEFI=1
    echo "oa-bootloader: Rilevato ambiente UEFI."
else
    echo "oa-bootloader: Rilevato ambiente BIOS/Legacy."
fi

# 2. Rilevamento Bootloader disponibili (Gestione Dinamica GRUB vs GRUB2)
HAS_BOOTCTL=0
if command -v bootctl &> /dev/null; then
    HAS_BOOTCTL=1
    echo "oa-bootloader: Rilevato systemd-boot (bootctl)."
fi

HAS_GRUB=0
GRUB_CMD="grub-install"
GRUB_MKCONFIG_CMD="grub-mkconfig"
GRUB_CFG_PATH="/boot/grub/grub.cfg"

# Controlliamo prima grub2 (Fedora, openSUSE)
if command -v grub2-install &> /dev/null; then
    HAS_GRUB=1
    GRUB_CMD="grub2-install"
    GRUB_MKCONFIG_CMD="grub2-mkconfig"
    GRUB_CFG_PATH="/boot/grub2/grub.cfg"
    
    # Assicuriamoci che la directory di destinazione esista
    mkdir -p /boot/grub2
    echo "oa-bootloader: Rilevato GRUB2 (Famiglia RedHat/SUSE)."
elif command -v grub-install &> /dev/null; then
    HAS_GRUB=1
    mkdir -p /boot/grub
    echo "oa-bootloader: Rilevato GRUB (Famiglia Debian/Arch)."
fi

# 3. Fix specifico initramfs (Bonifica dalla modalità Live)
if [ "$FAMILY" = "debian" ] || [ "$FAMILY" = "ubuntu" ]; then
    if [ -d /etc/initramfs-tools/conf.d ]; then
        echo "RESUME=none" > /etc/initramfs-tools/conf.d/resume
        update-initramfs -u || true
    fi
elif [[ "$FAMILY" == *"fedora"* ]] || [[ "$FAMILY" == *"suse"* ]] || [[ "$FAMILY" == *"opensuse"* ]]; then
    echo "oa-bootloader: Rigenerazione initramfs per $FAMILY (Dracut)..."
    # Creiamo un initramfs grasso e universale, rimuovendo la dipendenza live
    if command -v dracut &> /dev/null; then
        dracut -f --no-hostonly --omit "dmsquash-live livenet" || true
    else
        echo "ATTENZIONE: comando dracut non trovato!"
    fi
fi

# 4. Rilevamento SAFE MODE (Convivenza Multi-Boot)
SAFE_MODE=0
if [ $IS_UEFI -eq 1 ] && [ -d "/boot/efi/EFI" ]; then
    OTHER_OS=$(ls -1 /boot/efi/EFI 2>/dev/null | grep -ivE "boot|$DISTRO_ID|systemd" | wc -l || echo "0")
    if [ "$OTHER_OS" -gt 0 ]; then
        SAFE_MODE=1
        echo "oa-bootloader: [SAFE MODE] Rilevati altri OS nella partizione EFI. Disabilito l'hijack della NVRAM."
    fi
fi

# 5. Albero Decisionale Bootloader
if [ $IS_UEFI -eq 1 ]; then
    # --- GESTIONE UEFI ---
    if [ $HAS_BOOTCTL -eq 1 ] && { [ "$FAMILY" = "archlinux" ] || [ "$FAMILY" = "manjaro" ]; }; then
        echo "oa-bootloader: Installazione systemd-boot per famiglia Arch..."
        
        BOOTCTL_ARGS="--esp-path=/boot/efi"
        if [ $SAFE_MODE -eq 1 ]; then
            BOOTCTL_ARGS="$BOOTCTL_ARGS --no-variables"
        fi
        
        bootctl install $BOOTCTL_ARGS
        echo "oa-bootloader: Generazione configurazione per systemd-boot..."
        mkdir -p /boot/efi/loader/entries
        
        KERNEL_FILE=$(ls -1 /boot/vmlinuz-* 2>/dev/null | head -n 1 | xargs basename)
        INITRD_FILE=$(ls -1 /boot/initramfs-*.img 2>/dev/null | grep -v fallback | head -n 1 | xargs basename)
        
        if [ -z "$KERNEL_FILE" ]; then
            echo "ERRORE: Nessun kernel trovato in /boot!"
            exit 1
        fi

        echo "oa-bootloader: Copia del kernel e initramfs nella partizione EFI..."
        cp /boot/$KERNEL_FILE /boot/efi/
        cp /boot/$INITRD_FILE /boot/efi/
        
        UCODE_LINE=""
        if [ -f /boot/amd-ucode.img ]; then
            cp /boot/amd-ucode.img /boot/efi/
            UCODE_LINE="initrd  /amd-ucode.img"
        elif [ -f /boot/intel-ucode.img ]; then
            cp /boot/intel-ucode.img /boot/efi/
            UCODE_LINE="initrd  /intel-ucode.img"
        fi

        ROOT_PART=$(grep " / " /etc/fstab | grep -v "^#" | awk '{print $1}')
        
        if [ -z "$ROOT_PART" ]; then
            echo "ERRORE: Impossibile determinare Root UUID per systemd-boot!"
            exit 1
        fi

        cat <<EOF > /boot/efi/loader/entries/oa-linux.conf
title   OA Linux ($DISTRO_ID)
linux   /$KERNEL_FILE
$UCODE_LINE
initrd  /$INITRD_FILE
options root=$ROOT_PART rw
EOF

        cat <<EOF > /boot/efi/loader/loader.conf
default oa-linux.conf
timeout 5
console-mode max
editor yes
EOF
        echo "oa-bootloader: Entry systemd-boot generata ($KERNEL_FILE su $ROOT_PART)."
        
    elif [ $HAS_GRUB -eq 1 ]; then
        echo "oa-bootloader: Installazione $GRUB_CMD (EFI)..."
        
        GRUB_ARGS="--target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=$DISTRO_ID --recheck"
        if [ $SAFE_MODE -eq 1 ]; then
            GRUB_ARGS="$GRUB_ARGS --no-nvram"
        fi
        
        $GRUB_CMD $GRUB_ARGS
        
        if command -v update-grub &> /dev/null; then
            update-grub
        else
            generate_bls_entry
            $GRUB_MKCONFIG_CMD -o $GRUB_CFG_PATH
        fi
    else
        echo "ERRORE: Nessun bootloader (GRUB o systemd-boot) trovato nel sistema target!"
        exit 1
    fi
else
    # --- GESTIONE BIOS/LEGACY ---
    if [ $HAS_GRUB -eq 1 ]; then
        TARGET_DISK=$(grub-probe -t disk / 2>/dev/null || echo "/dev/sda")
        echo "oa-bootloader: Installazione $GRUB_CMD (Legacy) su $TARGET_DISK..."
        $GRUB_CMD --target=i386-pc --recheck "$TARGET_DISK"
        
        if command -v update-grub &> /dev/null; then
            update-grub
        else
            generate_bls_entry
            $GRUB_MKCONFIG_CMD -o $GRUB_CFG_PATH
        fi
    else
        echo "ERRORE: GRUB non installato. BIOS/Legacy richiede GRUB."
        exit 1
    fi
fi

# 6. Pulizia
echo "oa-bootloader: Pulizia artefatti live..."
rm -f /usr/local/bin/oa-trust-desktop
rm -f /etc/xdg/autostart/trust-installer.desktop
rm -f /usr/share/applications/install-system.desktop
rm -f /etc/sudoers.d/00-live

echo "oa-bootloader: Installazione bootloader completata."