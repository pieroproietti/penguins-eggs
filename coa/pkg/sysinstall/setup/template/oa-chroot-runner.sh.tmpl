#!/bin/bash

# Cerchiamo la radice: prima controlliamo se l'ambiente passa $ROOT, altrimenti usiamo il fallback
TARGET_ROOT=${ROOT}

if [ -z "$TARGET_ROOT" ]; then
    TARGET_ROOT=$(mount | grep proc | grep calamares | awk '{print $3}' | sed -e "s#/proc##g")
fi

if [ -z "$TARGET_ROOT" ]; then 
    TARGET_ROOT=$(ls -d /tmp/calamares-root-* 2>/dev/null | head -n 1)
fi

echo "chroot-runner: copia gli script in $TARGET_ROOT"
cp /etc/oa-tools.d/installer.d/oa-initramfs.sh "$TARGET_ROOT/tmp/"
cp /etc/oa-tools.d/installer.d/oa-bootloader.sh "$TARGET_ROOT/tmp/"

echo "chroot-runner: esegue gli script in $TARGET_ROOT"
chroot "$TARGET_ROOT" /bin/bash /tmp/oa-initramfs.sh
chroot "$TARGET_ROOT" /bin/bash /tmp/oa-bootloader.sh

# Genera le chiavi SSH solo se il pacchetto openssh-server è installato
if [ -x "$TARGET_ROOT/usr/bin/ssh-keygen" ]; then
    echo "chroot-runner: generazione chiavi SSH host..."
    chroot "$TARGET_ROOT" /usr/bin/ssh-keygen -A
else
    echo "chroot-runner: ssh-keygen non trovato, generazione ignorata."
fi

